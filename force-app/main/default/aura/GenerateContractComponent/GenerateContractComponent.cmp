<aura:component  controller="ZuoraContractGenerationController" implements="force:lightningQuickActionWithoutHeader,force:hasRecordId">
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="salesforceFileId" type="String" />
    <aura:attribute name="zuoraFileUrl" type="String" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:registerEvent name="ApplicationRefresgEvent" type="c:ApplicationRefresgEvent"/>


    <aura:html tag="style">
        .modal-body {
            position: relative;
        }
    </aura:html>

    <aura:if isTrue="{!v.isLoading}">
        <lightning:spinner alternativeText="Loading" size="large" />
    </aura:if>
</aura:component>