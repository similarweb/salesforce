<aura:component implements="flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes,force:hasRecordId" controller="NewRequestOverrideButtonController">
    <aura:handler name="init" value="{!this}" action="{!c.onInit}"/>
    <aura:attribute name="class" type="String" default="" />
    <aura:attribute name="width" type="Integer" default="50" />
    <aura:attribute name="animationClass" type="String" default="slds-fade-in-open" />
    <aura:attribute name="loadFinished" type="Boolean" default="false"/>
    <aura:attribute name="actionOpen" type="Boolean" default="false"/>
    
    <aura:attribute name="picklistValues" type="Object" />
    <aura:attribute name="oppType" type="String" />
    <aura:attribute name="selectedRecordType" type="String" default=""/>
    <aura:attribute name="errorMessage" type="String" default=""/>
    <aura:html tag="style">
        .cuf-content {
        	padding: 0 0rem !important;
        }
        .slds-p-around--medium {
        	padding: 0rem !important;
        }       
        .slds-modal__content{
            overflow-y:hidden !important;
            height:unset !important;
            max-height:unset !important;
        }
    </aura:html>
    <div>        
        <div class="{!if(v.loadFinished, '', 'invisible')}">
            <lightning:button label="New"  aura:id="addProducts" onclick="{!c.openAction}"/>
        </div>   
        <div>
            <section role="dialog" tabindex="-1" aria-modal="true" class="{!join(' ',
                                                                          'slds-modal',
                                                                          v.class,
                                                                          v.actionOpen?v.animationClass:''
                                                                          )}">
                <aura:if isTrue="{!v.actionOpen}">
                    <div class="slds-modal__container" style="{!'width:' + v.width + '%; max-width:unset'}">
                        <div class="modal-header slds-modal__header">
                            <aura:if isTrue="{!v.showCloseButton}">
                                <lightning:button class="slds-modal__close" onclick="{!c.onClose}" variant="bare">
                                    <lightning:icon iconName="utility:close" alternativeText="Close" size="small" />
                                </lightning:button>
                            </aura:if>
                            <h4 class="title slds-text-heading--medium" >New Request</h4>
                        </div>
                        <ui:scrollerWrapper aura:id="scrollerWrapper">
                            <div class="modal-body scrollable slds-modal__content slds-p-around-medium">
                                <fieldset class="slds-form-element slds-form-element_horizontal">
                                    <aura:if isTrue="{!not(empty(v.errorMessage))}">
                                        <div class="slds-notify slds-notify_alert slds-theme_alert-texture slds-theme_error" role="alert">
                                            <span class="slds-assistive-text">error</span>
                                            <h2>{!v.errorMessage}</h2>
                                        </div>
                                    </aura:if>
                                    <legend class="slds-form-element__legend slds-form-element__label">Select a record type</legend>
                                    <div class="slds-form-element__control">
                                        <aura:iteration items="{!v.picklistValues}" var="picklistValue" indexVar='indx'>
                                            <span class="slds-radio">
                                                <input type="radio" id="{!'radio-'+indx}" value="{!picklistValue.value}" name="options" onchange="{!c.selectRecordType}"/>
                                                <label class="slds-radio__label" for="{!'radio-'+indx}">
                                                    <span class="slds-radio_faux"></span>
                                                    <span class="slds-form-element__label">{!picklistValue.label}</span>
                                                </label>
                                            </span>
                                        </aura:iteration>
                                    </div>
                                </fieldset>
                            </div>
                        </ui:scrollerWrapper>
                        
                        <footer class="slds-modal__footer">
                            <lightning:button label="Cancel" aura:id="cancel" variant="neutral" onclick="{!c.cancel}" />
                            <lightning:button variant="brand" label="Next" onclick="{!c.createRecord}" disabled="{!empty(v.selectedRecordType)}"/>
                        </footer>
                    </div>            
                    
                    
                </aura:if>
            </section>
            <div class="{!join(' ',
                        'slds-backdrop',
                        v.actionOpen?'slds-backdrop_open':''
                        )}" onclick="{!c.cancel}"></div>
        </div>
    </div>
</aura:component>