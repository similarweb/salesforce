<aura:component>
    <aura:attribute name="quoteStatus" type="String" required="true"/>
    <aura:attribute name="subscriptionType" type="String" required="true"/>
    <aura:attribute name="zuoraVisualforceUrl" type="String" required="true"/>
    <aura:attribute name="documentType" type="String" required="true"/>
    <aura:attribute name="quoteRecordId" type="String" required="true"/>
    <aura:attribute name="paymentMethod" type="String" required="true"/>
    <aura:attribute name="paymentFrequency" type="String" required="true"/>
    <aura:attribute name="isDiscountApprove" type="Boolean" required="true"/>
    <aura:attribute name="paymentLink" type="String" required="true"/>
    <aura:attribute name="quoteRecordTypeReadOnlyId" default="012b0000000QNKCAA4" type="String"/>
    <aura:attribute name="recordTypeId" type="String" required="true"/>
    <aura:attribute name="flowMode" type="String" required="true"/>
    <aura:attribute name="isQuoteApprovalEnabled" type="Boolean"/>
    <aura:attribute name="isMsaSentToZuoraEnabled" type="Boolean"/>
    <aura:attribute name="isHitwiseAccount" type="Boolean"/>
    <aura:attribute name="isNewSubFromExistingAcc" type="Boolean"/>
    <aura:attribute name="isContractSignedManually" type="Boolean"/>
    <aura:attribute name="stepList" type="List"/>
    <aura:attribute name="hitwiseLink" type="String"/>
    <lightning:layout class="slds-p-vertical_small">
        <aura:if isTrue="{!and(v.isNewSubFromExistingAcc,notequals(v.paymentMethod,'Other'))}">
        <!-- <aura:if isTrue="true"> -->
            <aura:if isTrue="{!equals(v.paymentMethod,'Wire Transfer')}">
                <lightning:layoutItem class="slds-p-horizontal_small">
                    <c:GenerateContractComponentIconButton recordId="{!v.quoteRecordId}"
                                                            buttonLabel="{!if(equals(v.paymentMethod,'Wire Transfer'),'Proforma Invoice','Generate contract')}"
                                                            isDisabled="{!notequals(v.quoteStatus,'Terms Approved')}"
                                                            isPassed="{!equals(v.quoteStatus,'Proforma Invoice sent') || equals(v.quoteStatus,'Ready for Billing')  || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Contract Signed') || equals(v.quoteStatus,'Contract Signed Manually') || equals(v.quoteStatus,'Sent To Zuora')}"
                                                            finalizeQuote="{!true}"/>
                </lightning:layoutItem>
                <lightning:layoutItem class="slds-p-right_small">
                    <lightning:icon variant="inverse" iconName="utility:macros"/>
                </lightning:layoutItem>
            </aura:if>

            <lightning:layoutItem class="{!if(equals(v.paymentMethod,'Wire Transfer'), 'slds-p-right_small','slds-p-horizontal_small')}">
                <c:ReadyForBillingButton recordId="{!v.quoteRecordId}"
                                        isDisabled="{!if(equals(v.paymentMethod,'Wire Transfer'),notequals(v.quoteStatus,'Contract Signed Manually') &amp;&amp; notequals(v.quoteStatus,'Contract Signed') &amp;&amp; notequals(v.quoteStatus,'Proforma Invoice sent'), notequals(v.quoteStatus,'Contract Signed Manually') &amp;&amp;and(notequals(v.quoteStatus,'Terms Approved'),notequals(v.quoteStatus,'Deal Size Approved')))}"
                                        isPassed="{!equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.quoteStatus,'Sent To Zuora')}"
                                        />
            </lightning:layoutItem>

            <aura:if isTrue="{!v.isMsaSentToZuoraEnabled}">
                <lightning:layoutItem class="slds-p-right_small">
                    <lightning:icon variant="inverse" iconName="utility:macros"/>
                </lightning:layoutItem>
                <lightning:layoutItem class="slds-p-right_small">
                    <c:SubmitToZuoraButton  recordId="{!v.quoteRecordId}"
                                            isDisabled="{!(notequals(v.quoteStatus, 'Ready for Billing') &amp;&amp; not(v.isHitwiseAccount)) || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId)}"
                                            isPassed="{!equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Sent To Zuora')}"
                                            submitMode="Submit manually"
                                            />
                    
                </lightning:layoutItem>
            </aura:if>
            
            <div style="display: flex; margin-left: auto;">
                <aura:if isTrue="{!and(notequals(v.quoteStatus,v.stepList[0]),notequals(v.quoteStatus,'Sent To Zuora')) }">
                    <lightning:layoutItem class="slds-p-right_small" alignmentBump="left">
                        <c:ZuoraRecallButtonComponent   recordId="{!v.quoteRecordId}"
                                                        isDisabled="false"
                        />
                    </lightning:layoutItem>
                </aura:if>
                <aura:if isTrue="{!notequals(v.recordTypeId,v.quoteRecordTypeReadOnlyId)&amp;&amp;notequals(v.quoteStatus,'Sent To Zuora')&amp;&amp;notequals(v.quoteStatus,'Ready for Billing') || v.isMsaSentToZuoraEnabled || v.isSalesOps }">
                    <lightning:layoutItem class="slds-p-right_small"  alignmentBump="{!if(notequals(v.quoteStatus,v.stepList[0]), '','left')}">
                        <c:ZuoraCancelQuoteButton recordId="{!v.quoteRecordId}"/>
                    </lightning:layoutItem>
                </aura:if>
                <lightning:layoutItem class="slds-p-right_small" alignmentBump="{!if(notequals(v.quoteStatus,'Sent To Zuora'), '','left')}">
                    <c:ZuoraCloneQuoteIconButton isDisabled="{!equals(v.quoteStatus,'Terms Pending')}" zuoraVisualforceUrl="{!v.zuoraVisualforceUrl}" recordId="{!v.quoteRecordId}"/>
                </lightning:layoutItem>
            </div>

            <aura:set attribute="else">
                <aura:if isTrue="{!equals(v.flowMode,'NewFlow')}">
                    <aura:if isTrue="{!v.isQuoteApprovalEnabled}">
                        <lightning:layoutItem class="slds-p-horizontal_small">
                            <c:SubmitForApprovalIconButton  recordId="{!v.quoteRecordId}"
                                                            label="Deal Approval"
                                                            isDisabled="{!(notequals(v.quoteStatus,'New'))&amp;&amp;(notequals(v.quoteStatus,'Deal Size Rejected'))&amp;&amp;(notequals(v.quoteStatus,'Recalled')) }" 
                                                            isPending="{!equals(v.quoteStatus,'Deal Size Pending')}"
                                                            isRejected="{!equals(v.quoteStatus,'Deal Size Rejected')}"
                                                            isPassed="{!equals(v.quoteStatus,'Deal Size Approved') || equals(v.quoteStatus,'Terms Pending') || equals(v.quoteStatus,'Terms Approved') || equals(v.quoteStatus,'Terms Rejected') || equals(v.quoteStatus,'Proforma Invoice sent') || equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Contract Signed') || equals(v.quoteStatus,'Contract Signed Manually') || equals(v.quoteStatus,'Sent To Zuora')}"                              
                            />
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                    </aura:if>
                    <lightning:layoutItem class="{!if(v.isQuoteApprovalEnabled, 'slds-p-right_small', 'slds-p-horizontal_small')}">
                        <c:GenerateProposalsButton  quoteRecordId="{!v.quoteRecordId}"
                                                    isDisabled="{!equals(v.quoteStatus,'New') || equals(v.quoteStatus,'Deal Size Rejected') || equals(v.quoteStatus,'Recalled') || equals(v.quoteStatus,'Sent To Zuora') || equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Terms Pending')}"
                                                    isPassed="{!equals(v.quoteStatus,'Terms Approved')||equals(v.quoteStatus,'Terms Rejected') || equals(v.quoteStatus,'Terms Pending') || equals(v.quoteStatus,'Proforma Invoice sent') || equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Contract Signed') || equals(v.quoteStatus,'Contract Signed Manually') || equals(v.quoteStatus,'Sent To Zuora')}"
                        />
                    </lightning:layoutItem>
                    <aura:if isTrue="{!and((notequals(v.paymentMethod,'Credit Card')&amp;&amp;notequals(v.paymentMethod,'PayPal')),notequals(v.paymentMethod,'Wire Transfer'))}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:SubmitForApprovalIconButton  recordId="{!v.quoteRecordId}"
                                                            label="Finance Approval"
                                                            isDisabled="{!notequals(v.quoteStatus,'Deal Size Approved')&amp;&amp;notequals(v.quoteStatus,'Terms Rejected')}"
                                                            isPending="{!equals(v.quoteStatus,'Terms Pending')}"
                                                            isRejected="{!equals(v.quoteStatus,'Terms Rejected')}"
                                                            isPassed="{!equals(v.quoteStatus,'Terms Approved') || equals(v.quoteStatus,'Proforma Invoice sent') || equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Contract Signed') || equals(v.quoteStatus,'Contract Signed Manually') || equals(v.quoteStatus,'Sent To Zuora')}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <aura:if isTrue="{!and(v.isHitwiseAccount,equals(v.paymentMethod,'Other'))}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:PaymentLinkButton  recordId="{!v.quoteRecordId}"
                                                isDisabled="{!notequals(v.quoteStatus,'Terms Approved')&amp;&amp;notequals(v.quoteStatus,'Contract Signed Manually')&amp;&amp;notequals(v.quoteStatus,'Contract Signed')&amp;&amp;notequals(v.quoteStatus,'Ready for Billing')}"
                                                label="Payment link"
                                                isPassed="{!equals(v.quoteStatus,'Sent To Zuora')}"
                                                paymentLink="{!v.hitwiseLink}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <aura:if isTrue="{!or((notequals(v.paymentMethod,'Credit Card')&amp;&amp;notequals(v.paymentMethod,'PayPal')),and((equals(v.paymentMethod,'Credit Card')||equals(v.paymentMethod,'PayPal'))&amp;&amp;notequals(v.paymentFrequency,'Annual')&amp;&amp;notequals(v.paymentFrequency,'Every 2 Years')&amp;&amp;notequals(v.paymentFrequency,'Every 3 Years')))}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:GenerateContractComponentIconButton recordId="{!v.quoteRecordId}"
                                                                    buttonLabel="{!if(equals(v.paymentMethod,'Wire Transfer'),'Proforma Invoice','Generate contract')}"
                                                                    isDisabled="{!if(equals(v.paymentMethod,'Wire Transfer'),notequals(v.quoteStatus,'Terms Approved') &amp;&amp; notequals(v.quoteStatus,'Proforma Invoice sent'),notequals(v.quoteStatus,'Terms Approved')) || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId)}"
                                                                    isPassed="{!equals(v.quoteStatus,'Proforma Invoice sent') || equals(v.quoteStatus,'Ready for Billing')  || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Contract Signed') || equals(v.quoteStatus,'Contract Signed Manually') || equals(v.quoteStatus,'Sent To Zuora')}"
                                                                    finalizeQuote="{!true}"/>
                        </lightning:layoutItem>
                    </aura:if>
                    
                    <aura:if isTrue="{!not((equals(v.paymentMethod,'Credit Card')&amp;&amp;equals(v.paymentMethod,'PayPal'))&amp;&amp;equals(v.paymentFrequency,'Annual'))}">
        
                        <aura:if isTrue="{! (notequals(v.paymentMethod, 'Other') || equals(v.quoteStatus, 'Contract Signed Manually') || equals(v.quoteStatus, 'Ready for Billing') || equals(v.documentType, 'Service Order (Terms and Conditions attached)'))&amp;&amp;v.isContractSignedManually }">
                            <lightning:layoutItem class="slds-p-right_small">
                                <lightning:icon variant="inverse" iconName="utility:macros"/>
                            </lightning:layoutItem>
                             <lightning:layoutItem class="slds-p-right_small">
                                 <c:ReadyForBillingButton recordId="{!v.quoteRecordId}"
                                                          isDisabled="{!notequals(v.quoteStatus,'Proforma Invoice sent')&amp;&amp;notequals(v.quoteStatus,'Contract Signed Manually')&amp;&amp;notequals(v.quoteStatus,'Contract Signed')}"
                                                          isPassed="{!equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.quoteStatus,'Sent To Zuora')}"
                                                          />
                            </lightning:layoutItem>
                        </aura:if>
                        
                        <aura:if isTrue="{!equals(v.paymentMethod,'Other') &amp;&amp; or(not(v.isContractSignedManually),v.isMsaSentToZuoraEnabled) &amp;&amp; (notequals(v.quoteStatus,'Contract Signed Manually')&amp;&amp;notequals(v.documentType,'Service Order (Terms and Conditions attached)') || v.isMsaSentToZuoraEnabled)}">
                            <lightning:layoutItem class="slds-p-right_small">
                                <lightning:icon variant="inverse" iconName="utility:macros"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem class="slds-p-right_small">
                                <c:SubmitToZuoraButton  recordId="{!v.quoteRecordId}"
                                                       isDisabled="{!(notequals(v.quoteStatus,'Contract Signed') &amp;&amp; notequals(v.quoteStatus, 'Ready for Billing')) || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId)}"
                                                       isPassed="{!equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Sent To Zuora')}"
                                                       submitMode="Submit manually"
                                                       />
                                
                            </lightning:layoutItem>
                        </aura:if>
                        
                    </aura:if>
                    
                    <aura:if isTrue="{!and(!v.isHitwiseAccount,(equals(v.paymentMethod,'Credit Card')||equals(v.paymentMethod,'PayPal')))}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:PaymentLinkButton  recordId="{!v.quoteRecordId}"
                                                isDisabled="{!empty(v.paymentLink)}"
                                                label="Payment link"
                                                isPassed="{!equals(v.quoteStatus,'Sent To Zuora')}"
                                                paymentLink="{!v.paymentLink}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <aura:if isTrue="{!and(or(equals(v.paymentMethod,'Wire Transfer'),and(equals(v.paymentMethod,'Credit Card'),v.isMsaSentToZuoraEnabled)),v.isMsaSentToZuoraEnabled)}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:SubmitToZuoraButton  recordId="{!v.quoteRecordId}"
                                                    isDisabled="{!and(notequals(v.quoteStatus,'Approved By Billing'),notequals(v.quoteStatus,'Ready for Billing')&amp;&amp;or(!v.isMsaSentToZuoraEnabled,equals(v.quoteStatus,'Sent To Zuora')))}"
                                                    isPassed="{!equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Sent To Zuora')}"
                                                    submitMode="{!if(v.isMsaSentToZuoraEnabled,'Submit manually','Redirect to Zuora submit page')}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <div style="display: flex; margin-left: auto;">
                        <aura:if isTrue="{!and(notequals(v.quoteStatus,v.stepList[0]),notequals(v.quoteStatus,'Sent To Zuora')) }">
                            <lightning:layoutItem class="slds-p-right_small" alignmentBump="left">
                                <c:ZuoraRecallButtonComponent   recordId="{!v.quoteRecordId}"
                                                                isDisabled="false"
                                />
                                <!--{!notequals(v.quoteStatus,'Deal Size Pending')&amp;&amp;notequals(v.quoteStatus,'Deal Size Approved')&amp;&amp;notequals(v.quoteStatus,'Terms Rejected')&amp;&amp;notequals(v.quoteStatus,'Terms Pending')&amp;&amp;notequals(v.quoteStatus,'Terms Approved')}-->
                            </lightning:layoutItem>
                        </aura:if>
                        <aura:if isTrue="{!notequals(v.recordTypeId,v.quoteRecordTypeReadOnlyId)&amp;&amp;notequals(v.quoteStatus,'Sent To Zuora')&amp;&amp;notequals(v.quoteStatus,'Ready for Billing') || v.isMsaSentToZuoraEnabled || v.isSalesOps }">
                            <lightning:layoutItem class="slds-p-right_small"  alignmentBump="{!if(notequals(v.quoteStatus,v.stepList[0]), '','left')}">
                                <c:ZuoraCancelQuoteButton recordId="{!v.quoteRecordId}"/>
                            </lightning:layoutItem>
                        </aura:if>
                        <lightning:layoutItem class="slds-p-right_small" alignmentBump="{!if(notequals(v.quoteStatus,'Sent To Zuora'), '','left')}">
                            <c:ZuoraCloneQuoteIconButton isDisabled="{!equals(v.quoteStatus,'Terms Pending')}" zuoraVisualforceUrl="{!v.zuoraVisualforceUrl}" recordId="{!v.quoteRecordId}"/>
                        </lightning:layoutItem>
                    </div>
                </aura:if>
        
                <aura:if isTrue="{!equals(v.flowMode,'RegularFlow')}">
                    <lightning:layoutItem class="slds-p-horizontal_small">
                        <c:FinalizeQuoteButton  recordId="{!v.quoteRecordId}"
                                                isDisabled="{!notequals(v.quoteStatus,'New MSA')&amp;&amp;notequals(v.quoteStatus,'Rejected By Billing')}"
                                                isPassed="{!equals(v.quoteStatus,'Finalized') || equals(v.quoteStatus,'Pending Billing') || equals(v.quoteStatus,'Approved By Billing') || equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.quoteStatus,'Ready for Billing')}"
                        />
                    </lightning:layoutItem>
                    <lightning:layoutItem class="slds-p-right_small">
                        <lightning:icon variant="inverse" iconName="utility:macros"/>
                    </lightning:layoutItem>
                    <lightning:layoutItem class="slds-p-right_small">
                        <c:ReadyForBillingButton    recordId="{!v.quoteRecordId}"
                                                    isDisabled="{!notequals(v.quoteStatus,'Finalized')&amp;&amp;notequals(v.quoteStatus,'Rejected By Billing')}"
                                                    isPassed="{!equals(v.quoteStatus,'Ready for Billing') || equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.quoteStatus,'Approved By Billing')}"
                        />
                    </lightning:layoutItem>
                    <aura:if isTrue="{!or(equals(v.quoteStatus,'Approved By Billing'),v.isMsaSentToZuoraEnabled)}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:SubmitToZuoraButton  recordId="{!v.quoteRecordId}"
                                                    isDisabled="{!and(notequals(v.quoteStatus,'Approved By Billing'),notequals(v.quoteStatus,'Ready for Billing'))}"
                                                    isPassed="{!equals(v.quoteStatus,'Processed Directly in Zuora') || equals(v.recordTypeId,v.quoteRecordTypeReadOnlyId) || equals(v.quoteStatus,'Sent To Zuora')}"
                                                    submitMode="{!if(v.isMsaSentToZuoraEnabled,'Submit manually','Redirect to Zuora submit page')}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <aura:if isTrue="{!and(!v.isHitwiseAccount,(equals(v.paymentMethod,'Credit Card')||equals(v.paymentMethod,'PayPal')))}">
                        <lightning:layoutItem class="slds-p-right_small">
                            <lightning:icon variant="inverse" iconName="utility:macros"/>
                        </lightning:layoutItem>
                        <lightning:layoutItem class="slds-p-right_small">
                            <c:PaymentLinkButton  recordId="{!v.quoteRecordId}"
                                                isDisabled="{!empty(v.paymentLink)}"
                                                label="Payment link"
                                                isPassed="{!equals(v.quoteStatus,'Sent To Zuora')}"
                                                paymentLink="{!v.paymentLink}"
                            />
                        </lightning:layoutItem>
                    </aura:if>
                    <div style="display: flex; margin-left: auto;">
                        <aura:if isTrue="{!equals(v.quoteStatus,'Finalized') || equals(v.quoteStatus,'Deal Size Approved') || equals(v.quoteStatus,'Terms Approved') || equals(v.quoteStatus,'Deal Size Pending') || equals(v.quoteStatus,'Terms Pending')|| equals(v.quoteStatus,'Ready for Billing')}">
                            <lightning:layoutItem class="slds-p-right_small"> 
                                <c:ZuoraRecallButtonComponent   recordId="{!v.quoteRecordId}"
                                                                isDisabled="false"
                                />
                                <!-- {!notequals(v.quoteStatus,'Finalized')&amp;&amp;notequals(v.quoteStatus,'Deal Size Pending')&amp;&amp;notequals(v.quoteStatus,'Deal Size Approved')&amp;&amp;notequals(v.quoteStatus,'Terms Rejected')&amp;&amp;notequals(v.quoteStatus,'Terms Pending')&amp;&amp;notequals(v.quoteStatus,'Terms Approved')}-->
                            </lightning:layoutItem>
                        </aura:if>
                        <aura:if isTrue="{!notequals(v.quoteStatus,'Sent To Zuora') || v.isMsaSentToZuoraEnabled || v.isSalesOps }"> <!-- &amp;&amp;or(v.isMsaSentToZuoraEnabled,notequals(v.quoteStatus,'Ready for Billing') )  -->
                            <lightning:layoutItem class="slds-p-right_small"  >
                                <c:ZuoraCancelQuoteButton recordId="{!v.quoteRecordId}"/>
                            </lightning:layoutItem>
                        </aura:if>
                        <lightning:layoutItem class="slds-p-right_small" >
                            <c:ZuoraCloneQuoteIconButton isDisabled="{!equals(v.quoteStatus,'Terms Pending')}" zuoraVisualforceUrl="{!v.zuoraVisualforceUrl}" recordId="{!v.quoteRecordId}"/>
                        </lightning:layoutItem>
                    </div>
                </aura:if>
            </aura:set>
        </aura:if>
    </lightning:layout>
</aura:component>