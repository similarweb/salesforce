<aura:component  controller="ZuoraContractGenerationController" implements="force:lightningQuickActionWithoutHeader,force:hasRecordId,lightning:isUrlAddressable">
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="salesforceFileId" type="String" />
    <aura:attribute name="zuoraFileUrl" type="String" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <aura:html tag="style">
        .modal-body {
            position: relative;
        }
    </aura:html>
    <div>
        <aura:if isTrue="{!v.isLoading}">
            
                <lightning:spinner alternativeText="Loading" size="large" />
        </aura:if>
        <!-- <div aura:id="fileCard">
    
            <lightning:fileCard fileId="{!v.salesforceFileId}" 
                description="Quote contract preview"
                />
        </div> -->
    </div>
</aura:component>