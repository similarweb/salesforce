<aura:component  controller="ZuoraContractGenerationController">
<aura:attribute name="recordId" type="String" />    
<aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="salesforceFileId" type="String" />
    <aura:attribute name="zuoraFileUrl" type="String" />

    <!-- <div onclick="{!c.onButtonClick}" style="cursor: pointer;">
        <lightning:icon title="Preview Contract" iconName="action:preview" size="xx-small" alternativeText="Preview Contract"/>
    </div> -->
    <lightning:button variant="brand" label="Preview contract" onclick="{!c.onButtonClick}"/>
    <aura:if isTrue="{!v.isLoading}">    
        <lightning:spinner alternativeText="Loading" size="large" />
    </aura:if>
</aura:component>