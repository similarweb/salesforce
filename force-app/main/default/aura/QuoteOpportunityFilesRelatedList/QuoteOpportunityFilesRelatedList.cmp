<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId,force:hasSObjectName"
                access="global" 
                controller="QuoteOppFilesRelatedListController">

    <aura:attribute name="relatedOpportunityId" type="String"/>
    <aura:attribute name="isGreenLine" type="Boolean" default = "false"/>
    <aura:attribute name="isRelatedEnvelopesCompleted" type="Boolean" default = "true"/>
    <aura:attribute name="docusignLink" type="String"/>
    <aura:attribute name="opportunityAttachments" type="Object[]"/>
    <aura:attribute name="isMoreFiles" type="Boolean" default="false"/>
    <aura:attribute name="showModal" type="Boolean" default="false"/>
    <aura:attribute name="signatureDateMode" type="Boolean"/>
    <aura:attribute name="isSendToDocuSignAvailable" type="Boolean" default="false"/>
    <aura:attribute name="sObjectType" type="String" default="{!v.sObjectName}"/>
    <aura:attribute name="isDeleteModal" type="boolean" default="false"/>
    <aura:attribute name="isEditModal" type="boolean" default="false"/>
    <aura:attribute name="indexToDelete" type="String"/>
    <aura:attribute name="indexToEdit" type="String"/>
    <aura:attribute name="titleText" type="String" default="Undefined"/>
    <aura:attribute name="descriptionText" type="String"/>
    <aura:attribute name="createdDate" type="DateTime"/>
    <aura:attribute name="lastModDate" type="DateTime"/>


    <lightning:navigation aura:id="navService"/>
    <aura:handler name="init" value="{!this}" action="{!c.onInit}"/>
    <aura:handler event="c:ApplicationRefresgEvent" action="{!c.handleApplicationRefreshFired}"/>

    <aura:if isTrue="{!v.showModal}">
        <c:ZQuoteFileUpload quoteId="{!v.recordId}" oppId="{!v.relatedOpportunityId}" showModal="{!v.showModal}" signatureDateMode="{!v.signatureDateMode}"/>
    </aura:if>

    <div>
        <article class="slds-card slds-card_boundary headerBottomBorder forceRelatedListCardDesktop">
            <div class="slds-card__header slds-grid">
                <header class="slds-media slds-media_center slds-has-flexi-truncate">
                    <div class="slds-media__figure">
                        <span class="slds-icon_container slds-icon-standard-contact" title="contact">
                            <lightning:icon iconName="standard:file"/>
                            <!-- <span class="slds-assistive-text">contact</span> -->
                        </span>
                    </div>
                    <div class="slds-media__body">
                        <h2 class="slds-card__header-title">
                            <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" title="Files">
                                <aura:if isTrue="{!v.sObjectType == 'Case'}">
                                    <div class="slds-p-around_medium lgc-bg">
                                        Upload File(s) to Quote ({!v.isMoreFiles ? v.opportunityAttachments.length + '+' : v.opportunityAttachments.length})

                                        <lightning:helptext  class="slds-m-left_x-large slds-align-top"
                                                             content="Upload contract draft to this section ready to be sent for signatures."
                                        />
                                    </div>
                                    <aura:set attribute="else">
                                     <span>Notes &amp; Attachments {!if(v.sObjectType == 'Request__c', 'on a related quote','')} ({!if(v.isMoreFiles, v.opportunityAttachments.length + '+', v.opportunityAttachments.length) })</span>
                                    </aura:set>
                                </aura:if>
                            </a>
                        </h2>
                    </div>
                    <div class="slds-no-flex">
                        <aura:if isTrue="{!v.isRelatedEnvelopesCompleted}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.uploadButton}">Upload documents</button>
                        </aura:if>
                        <aura:if isTrue="{!v.isGreenLine &amp;&amp; v.sObjectType != 'Request__c' &amp;&amp; v.sObjectType != 'Case'}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.sendToDocuSign}">Send to DocuSign</button>
                        </aura:if>
                    </div>
                </header>
            </div>
            <div class="slds-card__body">
                <table class="slds-table slds-table_cell-buffer slds-no-row-hover slds-table_bordered slds-table_fixed-layout" role="grid">
                    <thead>
                        <tr class="slds-line-height_reset">
                            <th class="" scope="col">
                                <div class="slds-truncate" title="Title">Title</div>
                            </th>
                            <th class="" scope="col">
                                <div class="slds-truncate" title="Owner">Owner</div>
                            </th>
                            <th class="" scope="col">
                                <div class="slds-truncate" title="Last Modified">Last Modified</div>
                            </th>
                            <th class="" scope="col">
                                <div class="slds-truncate" title="Last Modified">Signature date</div>
                            </th>
                            <th class="" scope="col">
                                <div class="slds-truncate" title=""></div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <aura:iteration items="{!v.opportunityAttachments}" var="oppAtt_i">
                            <tr class="slds-hint-parent">
                                <th scope="row">
                                    <div class="slds-truncate" title="{!oppAtt_i.title}">
                                        <a href="javascript:void(0);" onclick="{!c.onFileItemClick}" tabindex="-1" data-index="{!_index}">
                                            <lightning:icon iconName="{!'doctype:' + oppAtt_i.lightningIconName}" alternativeText="Event" />
                                            {!oppAtt_i.title}
                                        </a>
                                    </div>
                                </th>
                                <td role="gridcell">
                                    <div class="slds-truncate" title="{!oppAtt_i.ownerName}">
                                        <a href="{!'/' + oppAtt_i.ownerId}" tabindex="-1">
                                            {!oppAtt_i.ownerName}
                                        </a>  
                                    </div>
                                </td>
                                <td role="gridcell">
                                    <div class="slds-truncate" title="lmd">
                                        
                                        <lightning:formattedDateTime value="{!oppAtt_i.lastModifiedDate}" year="numeric" month="numeric" day="numeric"  hour="2-digit" minute="2-digit"/>
                                    </div>
                                </td>
                                <td role="gridcell">
                                    <div class="slds-truncate" title="lmd">
                                        <lightning:formattedDateTime value="{!oppAtt_i.signatureDate}" year="numeric" month="numeric" day="numeric"/>
                                    </div>
                                </td>
                                <td role="gridcell">
                                    <div class="slds-clearfix">
                                        <div class="slds-float_right" data-index="{!_index}">
                                            <lightning:buttonMenu accesskey="{!_index}" aura:id="menu" alternativeText="Show menu" menuAlignment="right" onselect="{! c.onMenuItemSelect }">
                                                <lightning:menuItem value="{!'delete_' + _index}" label="Delete" accesskey="{!_index}"/>
                                                <lightning:menuItem value="{!'edit_' + _index}" label="Edit" accesskey="{!_index}"/>
                                            </lightning:buttonMenu>
                                        </div>
                                    </div>
                                </td>
                                <!-- <td role="gridcell">
                                    <div class="slds-truncate" title="size">
                                        <aura:if isTrue="{!oppAtt_i.isContentDocument}">
                                            {!oppAtt_i.contentSize}KB
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                </td> -->
                            </tr>
                        </aura:iteration>
                    </tbody>
                </table>
            </div>

            <div>
                <aura:if isTrue="{!v.isDeleteModal}">
                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                        <div class="modal-container slds-modal__container">
                            <header class="slds-modal__header">
                                <lightning:buttonIcon iconName="utility:close"
                                                        onclick="{! c.closeModal }"
                                                        alternativeText="close"
                                                        variant="bare-inverse"
                                                        class="slds-modal__close"/>
                                <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Delete File?</h2>
                            </header>
                            <div class="modal-body scrollable slds-modal__content slds-p-around--medium">

                                <p>Deleting a file also removes if from any records or posts its attached too.</p>

                            </div>
                            <footer class="slds-modal__footer slds-modal__footer_directional">
                                <lightning:button label="Cancel"
                                                  onclick="{!c.closeModal}"/>
                                 <lightning:button variant="brand"
                                                   label="Delete"
                                                   title="Delete"
                                                   onclick="{!c.onDeleteRecord}"/>
                            </footer>
                        </div>
                    </section>
                    <div class="slds-backdrop slds-backdrop_open"></div>
                </aura:if>
            </div>

            <div>
                <aura:if isTrue="{!v.isEditModal}">
                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                        <div class="modal-container slds-modal__container">
                            <header class="slds-modal__header">
                                <lightning:buttonIcon iconName="utility:close"
                                                        onclick="{! c.closeModal }"
                                                        alternativeText="close"
                                                        variant="bare-inverse"
                                                        class="slds-modal__close"/>
                                <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Edit File</h2>
                            </header>
                            <div class="modal-body scrollable slds-modal__content slds-p-around--medium">

                                <lightning:input name="titleInput" label="Title" required="true" value="{!v.titleText}" />
                                <lightning:textarea name="descriptionInput" label="Description" placeholder="type here..." value="{!v.descriptionText}"/>

                                <lightning:input type="datetime" name="createdInput" label="Created Date" disabled="true" value="{!v.createdDate}" />
                                <lightning:input type="datetime" name="lastModInput" label="Last Modified Date" disabled="true" value="{!v.lastModDate}" />

                            </div>
                            <footer class="slds-modal__footer slds-modal__footer_directional">
                                <lightning:button label="Cancel"
                                                  onclick="{!c.closeModal}"/>
                                 <lightning:button variant="brand"
                                                   label="Save"
                                                   title="Save"
                                                   onclick="{!c.onEditRecord}"/>
                            </footer>
                        </div>
                    </section>
                    <div class="slds-backdrop slds-backdrop_open"></div>
                </aura:if>
            </div>
            
            <footer class="slds-card__footer">
                <a class="slds-card__footer-action" onclick="{!c.onViewAllClick}" href="javascript:void(0);">View All
                    <span class="slds-assistive-text">Files</span>
                </a>
            </footer>
        </article>
    </div>
</aura:component>