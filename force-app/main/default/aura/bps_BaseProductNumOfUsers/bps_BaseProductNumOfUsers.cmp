<aura:component controller = "BaseProductSettingController">

    <aura:attribute name="baseProductFullName" type="String"/>    
    <aura:attribute name="numberOfUsers" type="Integer"/>    
    <aura:attribute name="isLoading" type="Boolean"/>

    <aura:registerEvent name="BaseProductValueSelectedEvent" type="c:bps_BaseProductValueSelected"/>
    
    <lightning:layout multipleRows="true" class="hh">

        <lightning:layoutItem size="12" class="slds-theme_shade rounded-borders_no-bottom ">
            <lightning:layout multipleRows="true" class="buttonL">
                <lightning:layoutItem size="8">
                    <div class="slds-p-around_medium slds-page-header__title">
                        Default Base Number of Users
                    </div>
                </lightning:layoutItem>
                <!--
                <lightning:layoutItem size="4" class="buttonItem">  
                    <lightning:buttonIcon iconName="utility:edit"  alternativeText="Edit value" onclick="{!c.onAddValuesClick}" class="ovrbtn"/>                                            
                </lightning:layoutItem>
                -->
            </lightning:layout>
            

        </lightning:layoutItem>

        <lightning:layoutItem size="12" class="rounded-borders">
        
            <div class="slds-theme_default slds-p-around_small slds-text-heading_medium rounded-borders ovr slds-is-relative">
                <aura:if isTrue="{!v.isLoading}">
                    <div class="sz">
                        <lightning:spinner alternativeText="" size="large" />
                    </div>
                    <aura:set attribute="else">
                        <lightning:select value="{!v.numberOfUsers}" name="select1" onchange="{!c.onNumOfUsersChange}">
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                            <option value="7">7</option>
                            <option value="8">8</option>
                            <option value="9">9</option>
                            <option value="10">10</option>
                            <option value="11">11</option>
                            <option value="12">12</option>
                            <option value="13">13</option>
                            <option value="14">14</option>
                            <option value="15">15</option>
                            <option value="16">16</option>
                            <option value="17">17</option>
                            <option value="18">18</option>
                            <option value="19">19</option>
                            <option value="20">20</option>
                            <option value="21">21</option>
                            <option value="22">22</option>
                            <option value="23">23</option>
                            <option value="24">24</option>
                            <option value="25">25</option>
                            <option value="26">26</option>
                            <option value="27">27</option>
                            <option value="28">28</option>
                            <option value="29">29</option>
                            <option value="30">30</option>
                        </lightning:select>
                    </aura:set>
                </aura:if>
            </div>                             

        </lightning:layoutItem>
    </lightning:layout>
</aura:component>