<aura:component implements="force:appHostable" 
                access="global">

    <aura:attribute name="shownBaseProductContractModal" type="Boolean" default="false"/>

    <aura:if isTrue="{!v.shownBaseProductContractModal}">
        <c:bps_BaseProductContractModal isShown="{!v.shownBaseProductContractModal}"/>
    </aura:if>
      
    <div class="slds-page-header">
        <p class="slds-page-header__title slds-truncate" title="">Base Product Setting</p>
        <div class="slds-grid slds-p-top_medium">                
            <div class="slds-col_bump-right slds-align-bottom">
                <div class="slds-grid">
                    <lightning:button onclick="{!c.onEditBaseProductClick}" variant="brand" label="Wording list" title="Wording list" />
                </div>
            </div>
        </div>
        
    </div> 
    
    <lightning:layout class="slds-p-top_small">
        <lightning:layoutItem size="4">
            <c:bps_BaseProductValuesList/>
        </lightning:layoutItem>

        <lightning:layoutItem size="8" class="slds-p-left--small">
            <c:bps_BaseProductValueInfo/>
        </lightning:layoutItem>
    </lightning:layout>
    
</aura:component>