public with sharing class ZuoraQuoteDateCalculationHelper {
  public static List<zqu__Quote__c> calculateDates(
    List<zqu__Quote__c> quoteList
  ) {
    List<zqu__Quote__c> quoteListToCalculate = new List<zqu__Quote__c>();
    for (zqu__Quote__c quote_i : quoteList) {
      if (
        quote_i.zqu__SubscriptionType__c == 'Amend Subscription' &&
        quote_i.zqu__StartDate__c == null
      ) {
        calculateDateForAmendQuote(quote_i);
      }
    }
    return quoteListToCalculate;
  }

  public static List<zqu__Quote__c> calculateDates(
    List<zqu__Quote__c> quoteList,
    Map<Id, SObject> existingRecords
  ) {
