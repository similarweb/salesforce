  public static zqu__Quote__c calculateDate(zqu__Quote__c quote) {
    System.debug('UPDATE CHANGE');
    quote.zqu__TermStartDate__c = Date.today();
    quote.zqu__Service_Activation_Date__c = Date.today();
    quote.zqu__StartDate__c = Date.today();
    quote.zqu__Customer_Acceptance_Date__c = Date.today();
    return quote;
  }

  public static zqu__Quote__c calculateDateForAmendQuote(zqu__Quote__c quote) {
    System.debug('INSERT CHANGE');
    quote.zqu__Service_Activation_Date__c = quote.zqu__SubscriptionTermStartDate__c;
    quote.zqu__StartDate__c = quote.zqu__SubscriptionTermStartDate__c;
    quote.zqu__Customer_Acceptance_Date__c = quote.zqu__SubscriptionTermStartDate__c;
    return quote;
  }

  public static zqu__Quote__c calculateDateDefaultQuote(zqu__Quote__c quote) {
    quote.zqu__TermStartDate__c = Date.today();
    quote.zqu__Service_Activation_Date__c = Date.today();
    quote.zqu__StartDate__c = Date.today();
    quote.zqu__Customer_Acceptance_Date__c = Date.today();
    return quote;
  }

  public static zqu__Quote__c calculateDateAmendQuote(
    zqu__Quote__c quote,
    Zuora__Subscription__c subscription
  ) {
    quote.zqu__SubscriptionTermStartDate__c = subscription.Zuora__SubscriptionStartDate__c;
    quote.zqu__SubscriptionTermEndDate__c = subscription.Zuora__SubscriptionEndDate__c;
    quote.zqu__StartDate__c = Date.today();
    quote.zqu__Customer_Acceptance_Date__c = Date.today();
    quote.zqu__Service_Activation_Date__c = Date.today();
    return quote;
  }

