      zqu__Quote__c oldQuote = (zqu__Quote__c) existingRecords.get(quote_i.Id);
      if (
        quote_i.zqu__SubscriptionType__c != 'Cancel Subscription' &&
        quote_i.zqu__ElectronicPaymentMethodId__c !=
        oldQuote.zqu__ElectronicPaymentMethodId__c
      ) {
        calculateDate(quote_i);
        quoteListToCalculate.add(quote_i);
      }
    }
