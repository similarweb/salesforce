    <start>
        <locationX>650</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_BeforeAccountAM</targetReference>
        </connector>
        <filterFormula>OR(
  ISCHANGED({!$Record.Assigned_CSA_Name__c}),
  ISCHANGED({!$Record.Assigned_CSA__c}),
  AND(
    ISCHANGED({!$Record.OwnerId}),
    OR(
        TEXT({!$Record.Owner.User_Business_Unit__c}) = &apos;SMB&apos;,
        TEXT({!$Record.Owner.User_Business_Unit__c}) = &apos;Enterprise&apos;
    )
  ),
  AND(
    TEXT({!$Record.Status__c}) = &apos;Active&apos;,
    {!$Record.BI_Data__r.ARR__c} &gt; 0,
    {!$Record.No_Touch_Account__c} = False,
    OR(
        TEXT({!$Record.Owner.Role_Type__c}) = &apos;CSM&apos;,
        TEXT({!$Record.Owner.Role_Type__c}) = &apos;AM&apos;
    ),
    OR(
        TEXT({!$Record.Owner.User_Business_Unit__c}) = &apos;SMB&apos;,
        TEXT({!$Record.Owner.User_Business_Unit__c}) = &apos;Enterprise&apos;
    )
  )
)</filterFormula>
        <object>Account</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
