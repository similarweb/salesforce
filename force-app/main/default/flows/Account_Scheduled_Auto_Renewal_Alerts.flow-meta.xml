        <text>&lt;p&gt;Hello {!$Record.Owner.FirstName} {!$Record.Owner.LastName},&amp;nbsp;&lt;/p&gt;&lt;p&gt;Your account {!$Record.Name} is scheduled for renewal in 70 days (on {!$Record.fr_Next_Renewal_Date__c}).&lt;/p&gt;&lt;p&gt;In 10 days, an automated email will be dispatched to the billing contact, admin user, and champion, reminding them about the upcoming auto-renewal, with you cc&apos;d.&lt;/p&gt;&lt;p&gt;If you prefer this account not to auto-renew and receive the reminder email, please deselect the Auto-renewal checkbox in your account settings.&lt;/p&gt;&lt;p&gt;{!$Record.Link_to_Account__c}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;&lt;img src=&quot;https://similarweb--full.sandbox.file.force.com/sfc/dist/version/renditionDownload?rendition=ORIGINAL_Jpg&amp;amp;versionId=068QI0000029oE9&amp;amp;operationContext=DELIVERY&amp;amp;contentId=05TQI000004Hco9&amp;amp;page=0&amp;amp;d=/a/QI000000mXhd/Kx30U9WsTszNc7mmO9hW.yOAVrM7SocZz5DHTOS3YEw&amp;amp;oid=00DQI000001VHqP&amp;amp;dpt=null&amp;amp;viewId=&quot;&gt;&lt;/p&gt;</text>
    </textTemplates>
