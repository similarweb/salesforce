        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;img src=&quot;https://similarweb--full.sandbox.file.force.com/sfc/dist/version/renditionDownload?rendition=ORIGINAL_Png&amp;amp;versionId=068QI0000026IkH&amp;amp;operationContext=DELIVERY&amp;amp;contentId=05TQI000004BM9N&amp;amp;page=0&amp;amp;d=/a/QI000000mBij/007J3BMiTqMIfV9HHwTKBZpngg2rsydxepMivQNAI4o&amp;amp;oid=00DQI000001VHqP&amp;amp;dpt=null&amp;amp;viewId==&quot;&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong style=&quot;font-size: 16px; font-family: sans-serif; color: rgb(9, 37, 64);&quot;&gt;Your subscription will auto-renew on {!$Record.fr_Next_Renewal_Date__c}&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;Hello,&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;We wanted to let you know that your Similarweb account will automatically renew on {!$Record.fr_Next_Renewal_Date__c}.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;No action from you is required– you can keep accessing Similarweb as usual.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;If you do not wish your Similarweb subscription to automatically renew, reach out to your account manager directly.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;Best,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 11pt; font-family: sans-serif; color: rgb(9, 37, 64); background-color: transparent;&quot;&gt;The Similarweb Team&lt;/span&gt;&lt;/p&gt;</text>
