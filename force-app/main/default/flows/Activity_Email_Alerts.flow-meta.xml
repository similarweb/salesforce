    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
(NOT(CONTAINS([Task].Description,&quot;Do you need help with Google Analytics&quot;)) ),
         OR(
               ISNEW(),
               ischanged([Task].Description)
              ),

        CONTAINS([Task].Subject,&quot;Intercom &quot;),
     
     IF(
          not(isblank([Task].AccountId )),
           IF(
                [Task].Account.Owner.SYSProfileName__c=&apos;SW CSM Internal&apos;,
                TRUE,
                FALSE
               ),
            False
          )
) </stringValue>
            </value>
        </processMetadataValues>
