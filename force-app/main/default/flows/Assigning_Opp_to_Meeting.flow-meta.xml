<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <decisions>
        <name>Found_an_Opp</name>
        <label>Found an Opp.</label>
        <locationX>489</locationX>
        <locationY>429</locationY>
        <defaultConnectorLabel>[Default Outcome]</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>VarOpportunityID</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Related_Opp_Exists</name>
        <label>Related Opp Exists</label>
        <locationX>499</locationX>
        <locationY>204</locationY>
        <defaultConnector>
            <targetReference>Search_for_relevant_Opps</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>VarExistingRelatedOpp</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>Exists</label>
        </rules>
    </decisions>
    <description>When meeting is created.</description>
    <formulas>
        <name>Last7Days</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 7</expression>
    </formulas>
    <interviewLabel>Assigning Opp to Meeting {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Assigning Opp to Meeting</label>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Existing_Related_Opps</name>
        <label>Existing Related Opps</label>
        <locationX>504</locationX>
        <locationY>89</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Related_Opp_Exists</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Related_Meeting__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>VarMeetingID</elementReference>
            </value>
        </filters>
        <object>Opportunity</object>
        <outputAssignments>
            <assignToReference>VarExistingRelatedOpp</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <name>Search_for_relevant_Opps</name>
        <label>Search for relevant Opps.</label>
        <locationX>490</locationX>
        <locationY>328</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Found_an_Opp</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>VarAccountID</elementReference>
            </value>
        </filters>
        <filters>
            <field>CreatedDate</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>VarMeetingDate</elementReference>
            </value>
        </filters>
        <filters>
            <field>Related_Meeting__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <outputAssignments>
            <assignToReference>VarOpportunityID</assignToReference>
            <field>Id</field>
        </outputAssignments>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
    </recordLookups>
    <recordUpdates>
        <name>Relate_Opp_to_Meeting</name>
        <label>Relate Opp to Meeting</label>
        <locationX>499</locationX>
        <locationY>657</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>VarMeetingID</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Related_Opportunity__c</field>
            <value>
                <elementReference>VarOpportunityID</elementReference>
            </value>
        </inputAssignments>
        <object>Meeting__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update</name>
        <label>Update</label>
        <locationX>499</locationX>
        <locationY>541</locationY>
        <connector>
            <targetReference>Relate_Opp_to_Meeting</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>VarOpportunityID</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Related_Meeting__c</field>
            <value>
                <elementReference>VarMeetingID</elementReference>
            </value>
        </inputAssignments>
        <object>Opportunity</object>
    </recordUpdates>
