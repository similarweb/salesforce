    <environments>Default</environments>
    <formulas>
        <name>Billing_Group_From_ToAddress_Formula</name>
        <dataType>String</dataType>
        <expression>IF(
   {!record_Case.Source:EmailMessage.ToAddress} = &quot;billing@similarweb.com&quot;,
    &quot;Billing&quot;,

    IF(
       {!record_Case.Source:EmailMessage.ToAddress}= &quot;billing-us@similarweb.com&quot;,
        &quot;Billing US&quot;,

        IF(
 {!record_Case.Source:EmailMessage.ToAddress} = &quot;billing-int@similarweb.com&quot;,
            &quot;Billing INT&quot;,

            IF(
                {!record_Case.Source:EmailMessage.ToAddress} = &quot;billing-apac@similarweb.com&quot;,
                &quot;Billing APAC&quot;,

                /* Default Value if None Match */
                TEXT({!record_Case.Group__c})
            )
        )
    )
)</expression>
    </formulas>
    <formulas>
        <name>Case_Type_Invoicing_Portals_Formula</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    CONTAINS(LOWER({!record_Case.Subject}), &quot;ariba&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;coupa&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;monto&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;sap&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;bill.com&quot;),
    CONTAINS(LOWER({!record_Case.Description}), &quot;ariba&quot;),
    CONTAINS(LOWER({!record_Case.Description}), &quot;coupa&quot;),
    CONTAINS(LOWER({!record_Case.Description}), &quot;monto&quot;),
    CONTAINS(LOWER({!record_Case.Description}), &quot;sap&quot;),
    CONTAINS(LOWER({!record_Case.Description}), &quot;bill.com&quot;)
)</expression>
    </formulas>
    <formulas>
        <name>Case_Type_Payment_Processor_Formula</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;bluesnap&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;stripe&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;vantiv&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;worldpay&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;amex&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;chargeback&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;dispute&quot;),
    CONTAINS(LOWER({!record_Case.SuppliedEmail}), &quot;dlocal&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;bluesnap&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;stripe&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;vantiv&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;worldpay&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;amex&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;chargeback&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;dispute&quot;),
    CONTAINS(LOWER({!record_Case.Subject}), &quot;dlocal&quot;)

)</expression>
    </formulas>
    <formulas>
        <name>Subject_Contains_HR</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;End of Employment&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;New Employee&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;Change in Role&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;Change in Reporting Line&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;Return from Maternity Leave&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;Relocation&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;Baby boy&quot;)),
    CONTAINS(LOWER({!record_Case.Subject}), LOWER(&quot;baby girl&quot;))
)</expression>
    </formulas>
