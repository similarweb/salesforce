    <description>MIS-6987 Complete &quot;Pending Requester&quot; Status Exceeding x Days for salesops and deal desk CASE record type
MIS-6790  - remove salesops email 2 case</description>
    <environments>Default</environments>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <description>MIS-6987 Complete &quot;Pending Requester&quot; Status Exceeding x Days for salesops and deal desk CASE record type</description>
        <name>Pending_Requester_Count_fr</name>
        <dataType>Date</dataType>
        <expression>IF(
TEXT({!$Record.Status})=&apos;Pending Requester&apos;, 
  IF( {!$Record.RecordType.Name}=&apos;Deal Desk&apos;, TODAY()+10, TODAY()+3), null

)</expression>
    </formulas>
    <formulas>
        <name>Subject_Contains_HR</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;End of Employment&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;New Employee&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;Change in Role&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;Change in Reporting Line&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;Return from Maternity Leave&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;Relocation&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;Baby boy&quot;)),
    CONTAINS(LOWER({!$Record.Subject}), LOWER(&quot;baby girl&quot;))
)</expression>
    </formulas>
