        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Case_Sub_Type__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Salesops_sub_type</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Case_Resolution__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Requester Didn&apos;t Respond</stringValue>
            </value>
        </assignmentItems>
