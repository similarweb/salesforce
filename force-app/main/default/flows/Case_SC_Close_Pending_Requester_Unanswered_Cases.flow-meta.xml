    <assignments>
        <name>CAssign_completed_DD_case_values</name>
        <label>\ssign completed DD case values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Case_Resolution__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Requester Didn&apos;t Respond</stringValue>
            </value>
