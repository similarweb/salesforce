    <decisions>
        <name>Deal_Size_Splash</name>
        <label>Deal Size Splash</label>
        <locationX>275</locationX>
        <locationY>384</locationY>
        <defaultConnector>
            <targetReference>New_Closed_won</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Under $250K</defaultConnectorLabel>
        <rules>
            <name>Big_Deal_250K</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ARR__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
