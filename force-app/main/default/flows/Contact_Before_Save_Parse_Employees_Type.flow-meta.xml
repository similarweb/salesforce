    <description>Parses SI_Employees_Type__c (format: &quot;number-number&quot;) and stores the left value in Employees_Min__c and the right value in Employees_Max__c. If the value is null or not in the expected format, both fields are set to null.</description>
    <environments>Default</environments>
    <formulas>
        <description>Extracts the number after the dash from SI_Employees_Type__c</description>
        <name>fr_EmployeesMax</name>
        <dataType>Number</dataType>
        <expression>VALUE(MID({!$Record.SI_Employees_Type__c}, FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) + 1, LEN({!$Record.SI_Employees_Type__c})))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Extracts the number before the dash from SI_Employees_Type__c</description>
        <name>fr_EmployeesMin</name>
        <dataType>Number</dataType>
        <expression>VALUE(LEFT({!$Record.SI_Employees_Type__c}, FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) - 1))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Checks if SI_Employees_Type__c is in valid &quot;number-number&quot; format: not blank, contains a dash not at start or end, and left value is not greater than right value</description>
        <name>fr_IsValidFormat</name>
        <dataType>Boolean</dataType>
        <expression>AND(
  NOT(ISBLANK({!$Record.SI_Employees_Type__c})),
  FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) &gt; 1,
  FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) &lt; LEN({!$Record.SI_Employees_Type__c}),
  VALUE(LEFT({!$Record.SI_Employees_Type__c}, FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) - 1)) &lt;= VALUE(MID({!$Record.SI_Employees_Type__c}, FIND(&quot;-&quot;, {!$Record.SI_Employees_Type__c}) + 1, LEN({!$Record.SI_Employees_Type__c})))
)</expression>
    </formulas>
