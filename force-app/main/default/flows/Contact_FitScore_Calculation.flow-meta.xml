    <formulas>
        <name>fr_cause_for_log</name>
        <dataType>String</dataType>
        <expression>IF(
  ISNEW(),
  &apos;Record is new first time getting Fit Score&apos;,
  IF(
    ischanged({!$Record.MailingCountry }),
    &apos;Country changed from &apos; + {!$Record__Prior.MailingCountry} + &quot; to &quot; + {!$Record.MailingCountry},
    IF(
      ischanged({!$Record.MailingCountryCode }),
      &apos;MailingCountryCode changed from &apos; + text({!$Record__Prior.MailingCountryCode}) + &quot; to &quot; + text({!$Record.MailingCountryCode}),
      IF(
        ischanged({!$Record.department__c }),
        &apos;department__c changed from &apos; + text({!$Record__Prior.department__c}) + &quot; to &quot; + {!Get_FitScore.Var_Department},
        IF(
          ischanged({!$Record.Department_Other_Description__c }),
          &apos;Department_Other_Description__c changed from &apos; + {!$Record__Prior.Department_Other_Description__c} + &quot; to &quot; + {!$Record.Department_Other_Description__c},
          IF(
            ischanged({!$Record.Employees_Min_FR__c }),
            &apos;Employees_Min_FR__c changed from &apos; + text({!$Record__Prior.Employees_Min_FR__c}) + &quot; to &quot; + text({!$Record.Employees_Min_FR__c}),
            IF(
              ischanged({!$Record.Email_address_domain_type__c }),
              &apos;Email_address_domain_type__c changed from &apos; + text({!$Record__Prior.Email_address_domain_type__c}) + &quot; to &quot; + text({!$Record.Email_address_domain_type__c}),
              IF(
                ischanged({!$Record.Email_Address_Domain_Type_Details__c }),
                &apos;Email_Address_Domain_Type_Details__c changed from &apos; + {!$Record__Prior.Email_Address_Domain_Type_Details__c} + &quot; to &quot; + {!$Record.Email_Address_Domain_Type_Details__c},
                IF(
                  ischanged({!$Record.Clean_Domain__c }),
                  &apos;Clean_Domain__c changed from &apos; + {!$Record__Prior.Clean_Domain__c} + &quot; to &quot; + {!$Record.Clean_Domain__c},
                  IF(
                    ischanged({!$Record.sw_industry__c }),
                    &apos;sw_industry__c changed from &apos; + ({!$Record__Prior.sw_industry__c}) + &quot; to &quot; + {!Get_FitScore.Var_SW_Industry},
                    IF(
                      ischanged({!$Record.Business_Unit__c }),
                      &apos;Business_Unit__c changed from &apos; + ({!$Record__Prior.Business_Unit__c}) + &quot; to &quot; + ({!$Record.Business_Unit__c}),
                      IF(
                        ischanged({!$Record.Secondary_email__c }),
                        &apos;Secondary_email__c changed from &apos; + {!$Record__Prior.Secondary_email__c} + &quot; to &quot; + {!$Record.Secondary_email__c},
                        IF(
                          ischanged({!$Record.website__c }),
                          &apos;website__c changed from &apos; + {!$Record__Prior.website__c} + &quot; to &quot; + {!$Record.website__c},
                          IF(
                            ischanged({!$Record.Title }),
                            &apos;Title changed from &apos; + {!$Record__Prior.Title} + &quot; to &quot; + {!$Record.Title},
                            IF(
                              ischanged({!$Record.Use_of_Similarweb__c }),
                              &apos;Use_of_Similarweb__c changed from &apos; + text({!$Record__Prior.Use_of_Similarweb__c}) + &quot; to &quot; + text({!$Record.Use_of_Similarweb__c}),
                              IF(
                                ischanged({!$Record.Seniority__c }),
                                &apos;Seniority__c changed from &apos; + text({!$Record__Prior.Seniority__c}) + &quot; to &quot; + {!Get_FitScore.Var_Seniority},
                                IF(
                                  ischanged({!$Record.Quiz_Data_Incomplete__c}),
                                  &apos;Quiz_Data_Incomplete__c changed to &apos; + {!$Record.Quiz_Data_Incomplete__c},
                                  Null
)))))))))))))))))</expression>
