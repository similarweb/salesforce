    <description>MIS-7609 Remove Product Sold
MIS-6753 Added next steps and product sold from Meeting
MIS-5207 Fix Type
MIS-5021 Business Unit STRAT - creates Upsell
MIS-4517 CSM with Upsell
MIS-1578 SMB AM Meeting to create 10% Opp
+ &apos;Primary Contact&apos; lookup on Opportunity population
New opp record type = new sale/upsell/
+ MIS-2090 - Closing meeting error</description>
    <environments>Default</environments>
    <formulas>
        <name>AccountOwnerResellerForm</name>
        <dataType>Boolean</dataType>
        <expression>CONTAINS({!VarOwnerRoleName}, &quot;Reseller&quot;)</expression>
    </formulas>
    <formulas>
        <name>CloseDateFormula</name>
        <dataType>Date</dataType>
        <expression>IF(ISBLANK({!VarCloseddate}),TODAY()+30,{!VarCloseddate})</expression>
    </formulas>
    <formulas>
        <name>ContactExistsForm</name>
        <dataType>Boolean</dataType>
        <expression>LEN({!VarContactID})&gt;10</expression>
    </formulas>
    <formulas>
        <description>MIS-6753</description>
        <name>FR_Next_Steps_255_Chars</name>
        <dataType>String</dataType>
        <expression>LEFT({!VarNextSteps}, 255)</expression>
    </formulas>
    <formulas>
        <description>MIS-5021
returns New Sell or Upsell based on the Account Business Unit</description>
        <name>fr_Opportunity_Type</name>
        <dataType>String</dataType>
        <expression>IF(
  TEXT({!Get_Account_BU.Business_Unit__c}) = &apos;Strategic&apos;,
  &quot;Upsell&quot;,
  &quot;New Sale&quot;
)</expression>
    </formulas>
    <formulas>
        <name>ISCSM</name>
        <dataType>Boolean</dataType>
        <expression>CONTAINS({!VarOwnerRoleName}, &quot;CSM&quot;)</expression>
    </formulas>
    <formulas>
        <name>OwnerIsSales_or_Reseller</name>
        <dataType>Boolean</dataType>
        <expression>OR(
Contains({!VarOwnerRoleName}, &quot;Sales&quot;) ,
Contains({!VarOwnerRoleName}, &quot;Reseller&quot;) ,
Contains({!VarOwnerRoleName}, &quot;CSM&quot;) ,
Contains({!VarOwnerRoleName}, &quot;Japan&quot;) ,
Contains({!VarOwnerRoleName}, &quot;Gaprise&quot;),
CONTAINS({!VarOwnerProfile}, &quot;SW Management&quot;)
   )</expression>
    </formulas>
    <formulas>
        <name>RT_Set_Form</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!VarOwnerRoleName},&quot;Inside&quot;),&quot;012b0000000M3zVAAS&quot;,

IF(CONTAINS({!VarMeetingRT_ID},&quot;012b0000000cffr&quot;),&quot;012b0000000M3zVAAS&quot;,&quot;012b0000000M3zQAAS&quot;))</expression>
    </formulas>
    <formulas>
        <name>SDR_Exists</name>
        <dataType>Boolean</dataType>
        <expression>LEN({!VarSDR_ID})&gt;10</expression>
    </formulas>
    <formulas>
        <name>SWIndustryExistsForm</name>
        <dataType>Boolean</dataType>
        <expression>LEN({!VarAccountSWIndustry})&gt;3</expression>
    </formulas>
    <formulas>
        <name>TodayPlus40</name>
        <dataType>Date</dataType>
        <expression>TODAY()+40</expression>
    </formulas>
    <formulas>
        <name>TodayPlus90</name>
        <dataType>Date</dataType>
        <expression>TODAY()+90</expression>
    </formulas>
