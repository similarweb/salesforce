    <decisions>
        <name>Which_Department_Was_Tagged</name>
        <label>Which Department Was Tagged?</label>
        <locationX>578</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>None</defaultConnectorLabel>
        <rules>
            <name>Salesops</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Body</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>@salesops</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Prefill_Related_Records</targetReference>
            </connector>
            <label>Salesops</label>
        </rules>
    </decisions>
    <description>MIS-6800 - remove email sent to salesops</description>
    <environments>Default</environments>
    <formulas>
        <name>CaseRecordLinkFormula</name>
        <dataType>String</dataType>
        <expression> LEFT({!$Api.Partner_Server_URL_610}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_610})) + {!NewCaseVar.Id}</expression>
    </formulas>
    <formulas>
        <name>CaseSubject</name>
        <dataType>String</dataType>
        <expression>{!$User.FirstName} + &apos; &apos;+{!$User.LastName} + &apos; tagged Salesops in Chatter&apos;</expression>
    </formulas>
    <formulas>
        <name>QueueNameSelection</name>
        <dataType>String</dataType>
        <expression>CASE({!CaseRecordType},
&apos;Salesops&apos;,&apos;SalesOps Cases&apos;, null)</expression>
    </formulas>
