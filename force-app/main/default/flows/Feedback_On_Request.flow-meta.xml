        <locationX>251</locationX>
        <locationY>486</locationY>
        <connector>
            <targetReference>Feedback_Screen</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>VarRequestID</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Sent to customer</stringValue>
            </value>
        </inputAssignments>
        <object>Request__c</object>
    </recordUpdates>
