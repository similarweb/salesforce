<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <apiVersion>49.0</apiVersion>
    <choices>
        <name>Change_Request_Status_to_Sent_to_Customer</name>
        <choiceText>Change Request Status to Sent to Customer</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Change Status</stringValue>
        </value>
    </choices>
    <choices>
        <name>Don_t_add_feedback_exit_flow</name>
        <choiceText>Don&apos;t add feedback exit flow</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Exit</stringValue>
        </value>
    </choices>
    <decisions>
        <name>Check_request_status</name>
        <label>Check request status</label>
        <locationX>447</locationX>
        <locationY>95</locationY>
        <defaultConnector>
            <targetReference>Feedback_not_eligible</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not sent yet</defaultConnectorLabel>
        <rules>
            <name>Sent_to_customer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>VarRequestStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sent to customer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Feedback_Screen</targetReference>
            </connector>
            <label>Sent to customer</label>
        </rules>
    </decisions>
    <decisions>
        <name>Next_Step_Junc</name>
        <label>Next Step</label>
        <locationX>259</locationX>
        <locationY>358</locationY>
        <defaultConnector>
            <targetReference>Update_Request_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Change Status</defaultConnectorLabel>
        <rules>
            <name>Leave_Flow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Next_step</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Exit</stringValue>
                </rightValue>
            </conditions>
            <label>Leave Flow</label>
        </rules>
    </decisions>
    <description>Request Project</description>
    <dynamicChoiceSets>
        <name>GeneralFeedback</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
