    <assignments>
        <name>Update_First_Last_Name</name>
        <label>Update First + Last Name</label>
        <locationX>176</locationX>
        <locationY>311</locationY>
        <assignmentItems>
            <assignToReference>$Record.FirstName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Capitalize_First_Name</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.LastName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Capitalize_Last_Name</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>Migrated from Workflow: &quot;Capitalize First and Last Name Lead&quot;</description>
    <environments>Default</environments>
    <formulas>
        <name>Capitalize_First_Name</name>
        <dataType>String</dataType>
        <expression>UPPER(LEFT({!$Record.FirstName},1)) +  RIGHT({!$Record.FirstName},LEN({!$Record.FirstName}) - 1)</expression>
    </formulas>
    <formulas>
        <name>Capitalize_Last_Name</name>
        <dataType>String</dataType>
        <expression>UPPER(LEFT({!$Record.LastName},1)) + RIGHT({!$Record.LastName},LEN({!$Record.LastName}) - 1)</expression>
    </formulas>
