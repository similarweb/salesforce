    <formulas>
        <name>fr_User_is_Rep</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  CASESAFEID({!$User.ProfileId}) = &apos;00eb00000015tcAAAQ&apos; /* SW Client Services / Support*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00eb0000000hqVGAAY&apos; /* SW CSM Internal*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00eb0000000ZODsAAO&apos; /* SW Management*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00e67000000iJB2AAM&apos; /* SW MIR*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00eb0000000ZOE2AAO&apos; /* SW Sales External*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00eb0000000dZwnAAE&apos; /* SW Sales Internal*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00e67000000iJAxAAM&apos; /* SW Sales Internal - STRAT*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00eb00000015tL7AAI&apos; /* SW SDR*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00e67000000du9BAAQ&apos; /* SW SDR Extended*/,
  CASESAFEID({!$User.ProfileId}) = &apos;00e67000000InlZAAS&apos; /* SW Support*/
 )</expression>
    </formulas>
    <formulas>
        <description>Check if the owner profile is integration, admin. sales ops or marketing ops and if yes then true</description>
        <name>Ownerprofile</name>
        <dataType>Boolean</dataType>
        <expression>IF( OR(
CONTAINS( {!$Record.Owner:User.Profile.Name} , &quot;SalesOps&quot;),CONTAINS( {!$Record.Owner:User.Profile.Name}, &quot;Marketing&quot;),CONTAINS( {!$Record.Owner:User.Profile.Name}, &quot;Integration&quot;)),true,false)</expression>
    </formulas>
