    <formulas>
        <description>MIS-5826</description>
        <name>Contact_MQL_Status</name>
        <dataType>String</dataType>
        <expression>IF(
    OR(
        AND(
            TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;A&apos;, {!$Record.Contact_Related_To__r.BI_Data__r.Intent_Score__c} &gt;= 4),
        AND(
            TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;B&apos;, {!$Record.Contact_Related_To__r.BI_Data__r.Intent_Score__c} &gt;= 7),
        AND(
            TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;C&apos;, {!$Record.Contact_Related_To__r.BI_Data__r.Intent_Score__c} &gt;= 7)
    ), 
    &apos;Hard MQL&apos;,
    
    IF(
        OR(
            TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;A&apos;,
            AND(
                  TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;B&apos;, {!$Record.Contact_Related_To__r.BI_Data__r.Intent_Score__c} &gt;= 4),
            AND(
                  TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;D&apos;, {!$Record.Contact_Related_To__r.BI_Data__r.Intent_Score__c} &gt;= 7)
        ), 
        &apos;Soft MQL&apos;,
        
        IF(
            OR(
                TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;B&apos;,
                TEXT({!$Record.Contact_Related_To__r.SW_Fit_Score__c}) = &apos;C&apos;
