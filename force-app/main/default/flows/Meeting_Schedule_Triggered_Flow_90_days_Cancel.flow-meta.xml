        </rules>
        <rules>
            <name>Age_89</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Fr_MeetingAge</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>89.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Cancelled_meeting_after_90_days</targetReference>
            </connector>
            <label>Age &gt; 89</label>
        </rules>
    </decisions>
    <description>MIS-2200

Age = 89 days -&gt; Send email alert
Age &gt;= 90 -&gt; Cancel a meeting

Age = TODAY - Meeting Date</description>
    <formulas>
