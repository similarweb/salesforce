    <apiVersion>54.0</apiVersion>
    <description>If &apos;Status&apos; = Pending or Rescheduling and &apos;CreatedBy.FirstName&apos; does not contain &apos;Integration&apos; and &apos;CreatedBy.LastName&apos; does not contain &apos;Integration&apos; and &apos;CreatedBy.Profile.Name&apos; does not equal &apos;Administrator&apos; - execute Scheduled Path 2 and 7 days after &apos;Meeting Date&apos;</description>
    <environments>Default</environments>
    <interviewLabel>Meeting - Time-based - Meeting Pending or Rescheduling - 2 days/week overdue (Creator and Creator Manager) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Meeting - Time-based - Meeting Pending or Rescheduling - 2 days/week overdue (Creator and Creator Manager)</label>
    <processMetadataValues>
