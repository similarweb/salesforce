    <start>
        <locationX>336</locationX>
        <locationY>27</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND(
NOT(CONTAINS( {!$Record.CreatedBy.Profile.Name},&apos;System Administrator&apos;)),  
NOT(CONTAINS( {!$Record.CreatedBy.Profile.Name},&apos;Integration&apos;)),
NOT(CONTAINS( {!$Record.CreatedBy.FirstName},&apos;Integration&apos;)),
NOT(CONTAINS( {!$Record.CreatedBy.LastName},&apos;Integration&apos;)),
OR(
ISPICKVAL({!$Record.Status__c}, &apos;Pending&apos;),
ISPICKVAL({!$Record.Status__c}, &apos;Rescheduling&apos;)
),
OR(
{!$Record.CreatedBy.Manager.IsActive} = true,
{!$Record.CreatedBy.IsActive} = true,
NOT(ISBLANK({!$Record.Creator_Manager_Email__c}))
)
)</filterFormula>
        <object>Meeting__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
