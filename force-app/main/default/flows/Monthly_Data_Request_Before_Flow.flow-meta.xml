    <description>Test for Shai&apos;s update</description>
    <environments>Default</environments>
    <formulas>
        <description>Calculate the additional Payment above the fix monthly payment in case the monthly DAU was higher than the Fixed monthly.</description>
        <name>For_Additional_DAU_Threshold_Calc</name>
        <dataType>Currency</dataType>
        <expression>IF( 
{!$Record.AVG_Data_Units__c} -{!$Record.Rate__r.Fixed_Monthly_DAU__c}&lt;{!$Record.Rate__r.DAU_Threshold__c},0,
FLOOR({!For_DAU_Floor_Calc})*{!$Record.Rate__r.Payment_Threshold__c}
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>In case the Contract is Monthly fix payment, we need to calculate how much to pay according to the fix DAU and Payment thresholds.</description>
        <name>For_Calculate_Fix_Payment_Calc</name>
        <dataType>Currency</dataType>
        <expression>IF( 
 {!$Record.AVG_Data_Units__c} &lt;{!$Record.Rate__r.Fixed_Monthly_DAU__c},{!$Record.Rate__r.Fixed_Monthly_Payment__c},
{!$Record.Rate__r.Fixed_Monthly_Payment__c} +{!For_Additional_DAU_Threshold_Calc}
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Calculate the payment of the MDR when there is a &quot;Second Rate&quot; on the related Rate. 
Format is: DAU till the Monthly Fix DAU*Rate + (DAU - Monthly Fix DAU)*Second Rate</description>
        <name>For_Calculate_Second_Rate</name>
        <dataType>Currency</dataType>
        <expression>IF( 
{!$Record.AVG_Data_Units__c}&lt;{!$Record.Rate__r.Fixed_Monthly_DAU__c},/*Standard Calculation:*/{!$Record.AVG_Data_Units__c}*{!$Record.Data_Rate__c},/*Second Rate Calculation:*/
{!$Record.Rate__r.Fixed_Monthly_DAU__c}*{!$Record.Data_Rate__c} +({!$Record.AVG_Data_Units__c}-{!$Record.Rate__r.Fixed_Monthly_DAU__c})*{!$Record.Rate__r.Second_Rate__c}
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>The number represents the bulks of additional DAU (above the monthly fix) that we need to pay for.</description>
        <name>For_DAU_Floor_Calc</name>
        <dataType>Number</dataType>
        <expression>({!$Record.AVG_Data_Units__c}-{!$Record.Rate__r.Fixed_Monthly_DAU__c})/{!$Record.Rate__r.DAU_Threshold__c}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Auto populate MDR Name on creation/when adding the related &quot;Rate&quot;.</description>
        <name>For_MDR_Name</name>
        <dataType>String</dataType>
        <expression>{!$Record.Rate__r.Name} +&quot; &quot;+ {!For_MM_YYYY}</expression>
    </formulas>
    <formulas>
        <name>For_MM_YYYY</name>
        <dataType>String</dataType>
        <expression>TEXT(MONTH(DATEVALUE({!For_NOW}))) +&quot;/&quot;+ TEXT(YEAR(DATEVALUE({!For_NOW})))</expression>
    </formulas>
    <formulas>
        <name>For_NOW</name>
        <dataType>DateTime</dataType>
        <expression>ADDMONTHS(NOW(), -1)</expression>
    </formulas>
    <formulas>
        <name>For_Request_Payment_Calculation</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.AVG_Data_Units__c}*{!$Record.Data_Rate__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>For_Status_Calc</name>
        <dataType>String</dataType>
        <expression>IF(
ISNULL({!$Record.AVG_Data_Units__c}),&apos;Open&apos;,&apos;Calculated&apos;)</expression>
    </formulas>
