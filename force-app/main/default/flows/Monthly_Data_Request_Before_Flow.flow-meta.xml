    <decisions>
        <description>In case there is a second Rate on the related &quot;Rate&quot; record, the calculation should be according the Monthly Fix DAU threshold and both Rates.</description>
        <name>Is_there_a_Second_Rate</name>
        <label>Is there a Second Rate?</label>
        <locationX>182</locationX>
        <locationY>803</locationY>
        <defaultConnector>
