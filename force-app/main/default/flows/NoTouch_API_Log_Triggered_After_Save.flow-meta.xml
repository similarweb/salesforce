    <decisions>
        <description>MIS-7106
MIS-5404
MIS-5041</description>
        <name>What_Scenario</name>
        <label>What Scenario</label>
        <locationX>506</locationX>
        <locationY>384</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Scenario_1_4</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 1</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 4</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Recipient_Emails_1_4</targetReference>
            </connector>
            <label>Scenario 1 &amp; 4</label>
        </rules>
        <rules>
            <name>Scenario_2_5_Option_1</name>
            <conditionLogic>(1 OR 2) AND (((3 OR 4 OR 5) AND 6) OR (7 AND 8))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 2</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 5</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Matched_Account_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Matched_Account_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Ongoing Outbound</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Matched_Account_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending Meeting</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NT_Subscription_FirstCharge_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Matched_Account_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Deal in Closing Pipeline</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NT_Subscription_FirstCharge_Date__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Recipient_Emails_2_5_option_1</targetReference>
            </connector>
            <label>Scenario 2 &amp; 5 - Option 1</label>
        </rules>
        <rules>
            <name>Scenario_2_5_Option_2</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 2</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Scenario__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scenario 5</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NT_Subscription_FirstCharge_Date__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Recipient_Emails_2_5_option_2</targetReference>
            </connector>
            <label>Scenario 2 &amp; 5 - Option 2</label>
        </rules>
    </decisions>
