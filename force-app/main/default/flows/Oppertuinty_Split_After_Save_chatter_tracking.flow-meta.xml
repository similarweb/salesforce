            </conditions>
            <conditions>
                <leftValueReference>$Record.SplitPercentage</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.SplitPercentage</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Change_in_Opp_split</targetReference>
            </connector>
            <label>Changes in opportunity split</label>
        </rules>
    </decisions>
