    <decisions>
        <name>Changed_opportunity</name>
        <label>Changed opportunity split</label>
        <locationX>182</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Changes_in_opportunity_split</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SplitPercentage</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
