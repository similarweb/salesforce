    <formulas>
        <name>AccClientCRMCalc</name>
        <dataType>String</dataType>
        <expression>IF({!RequestCRM}, {!Client_CRM}, {!Get_opp.Account.Client_CRM__c})</expression>
    </formulas>
    <formulas>
        <name>CountryFilterCalc</name>
        <dataType>String</dataType>
        <expression>IF({!RequestCountryFilter}, {!Please_Enter_The_Relevant_Country_Filter_Names}, {!Get_opp.Country_Filter__c})</expression>
    </formulas>
    <formulas>
        <name>OppClientCRMCalc</name>
        <dataType>String</dataType>
        <expression>IF({!RequestCRM}, {!Client_CRM}, {!Get_opp.Client_CRM__c})</expression>
    </formulas>
    <formulas>
        <name>RequestCountryFilter</name>
        <dataType>Boolean</dataType>
        <expression>!ISBLANK({!Get_AddOnType_Country_opp_product.Id}) &amp;&amp; ISBLANK({!Get_opp.Country_Filter__c})</expression>
    </formulas>
    <formulas>
        <name>RequestCRM</name>
        <dataType>Boolean</dataType>
        <expression>!ISBLANK({!Get_Sales_Intelligence_opp_product.Id}) &amp;&amp; (
   ISBLANK({!Get_opp.Client_CRM__c}) || ISBLANK({!Get_opp.Account.Client_CRM__c})
)</expression>
    </formulas>
