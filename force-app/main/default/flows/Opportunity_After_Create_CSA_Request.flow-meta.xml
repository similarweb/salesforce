    <formulas>
        <description>checks if the Opp division is in the Resellers list</description>
        <name>fr_isReseller</name>
        <dataType>Boolean</dataType>
        <expression>CONTAINS(&quot;Reseller - India - Altudo:Reseller - Turkey-CloudyFlex:Reseller - ANZ-Trellian:Reseller - Italy - Nubo&quot;,text({!$Record.Opportunity_Division__c}))</expression>
    </formulas>
    <formulas>
        <description>for Rule *CR*</description>
        <name>Request_Type_Formula_CR</name>
        <dataType>String</dataType>
        <expression>IF
(
{!$Record.ARR__c} &gt;= 30000,
&quot;Standard&quot;,
&quot;Growth&quot;
)</expression>
    </formulas>
