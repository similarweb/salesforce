    <decisions>
        <name>Check_if_non_ops_OR_non_admin_user</name>
        <label>Check if non ops OR non admin user</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_if_a_field_was_changed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>User_is_Admin_OR_Ops</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Profile.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>System Administrator</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Profile.Name</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>SW SalesOps</stringValue>
                </rightValue>
            </conditions>
            <label>User is Admin OR Ops</label>
        </rules>
    </decisions>
    <description>MIS-8188</description>
    <environments>Default</environments>
    <formulas>
        <description>This formula generates a dynamic audit log that tracks changes for the following 13 fields: Account AM, Assigned CSM Name, Stage, Forecasting Status, Amount, Close Date, Cycle Price, Cycle, Cycle Price Local, Max ARR, Type, Record Type, and Owner. It uses ISCHANGED logic to ensure only modified fields are listed, keeping the output clean. For every change detected, it displays the field name followed by the &quot;Previous value&quot; and &quot;New value&quot; on a new line. It automatically handles data conversion for picklists, dates, and currency fields to ensure the information is human-readable.</description>
        <name>Changed_fields_text_formula</name>
        <dataType>String</dataType>
        <expression>IF(ISCHANGED({!$Record.Account_AM__c}), 
   &quot;Account AM: Previous value: &quot; &amp; {!$Record__Prior.Account_AM__c} &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; {!$Record.Account_AM__c} &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Assigned_CSM_Name__c}), 
   &quot;Assigned CSM: Previous value: &quot; &amp; {!$Record__Prior.Assigned_CSM_Name__c} &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; {!$Record.Assigned_CSM_Name__c} &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.StageName}), 
   &quot;Stage: Previous value: &quot; &amp; TEXT({!$Record__Prior.StageName}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.StageName}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Similarweb_Forecasting_status__c}), 
   &quot;Forecasting Status: Previous value: &quot; &amp; TEXT({!$Record__Prior.Similarweb_Forecasting_status__c}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Similarweb_Forecasting_status__c}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Amount}), 
   &quot;Amount: Previous value: &quot; &amp; TEXT({!$Record__Prior.Amount}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Amount}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.CloseDate}), 
   &quot;Close Date: Previous value: &quot; &amp; TEXT({!$Record__Prior.CloseDate}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.CloseDate}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Cycle_Price__c}), 
   &quot;Cycle Price: Previous value: &quot; &amp; TEXT({!$Record__Prior.Cycle_Price__c}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Cycle_Price__c}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Cycle__c}), 
   &quot;Cycle: Previous value: &quot; &amp; TEXT({!$Record__Prior.Cycle__c}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Cycle__c}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Cycle_Price_Local__c}), 
   &quot;Cycle Price Local: Previous value: &quot; &amp; TEXT({!$Record__Prior.Cycle_Price_Local__c}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Cycle_Price_Local__c}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Max_ARR__c}), 
   &quot;Max ARR: Previous value: &quot; &amp; TEXT({!$Record__Prior.Max_ARR__c}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Max_ARR__c}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.Type}), 
   &quot;Type: Previous value: &quot; &amp; TEXT({!$Record__Prior.Type}) &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; TEXT({!$Record.Type}) &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.RecordTypeId}), 
   &quot;Record Type ID: Previous value: &quot; &amp; {!$Record__Prior.RecordTypeId} &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; {!$Record.RecordTypeId} &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;) &amp;

IF(ISCHANGED({!$Record.OwnerId}), 
   &quot;Owner ID: Previous value: &quot; &amp; {!$Record__Prior.OwnerId} &amp; &apos;, &apos; &amp; &quot;New value: &quot; &amp; {!$Record.OwnerId} &amp; &apos;&lt;br&gt;&lt;br&gt;&apos;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>EmailBody</name>
        <dataType>String</dataType>
        <expression>&apos;Hi!&apos;
+BR()
+&apos;Please note that the following fields for the following opportunity has been updated:&apos;+BR()
+&apos;Opportunity name: &apos;+{!$Record.Name}+BR()
+&apos;Close date: &apos;+TEXT({!$Record.CloseDate})+BR()
+&apos;Last Modified by: &apos;+{!$User.FirstName}+&apos; &apos;+{!$User.LastName}+BR()
+{!Changed_fields_text_formula}</expression>
    </formulas>
    <formulas>
