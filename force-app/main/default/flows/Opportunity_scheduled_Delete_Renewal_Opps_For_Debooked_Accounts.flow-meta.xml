        <name>Q_Calculation</name>
        <dataType>Boolean</dataType>
        <expression>( YEAR(TODAY()) * 4 + CEILING(MONTH(TODAY()) / 3) )
&gt;
(
  YEAR( DATEVALUE({!$Record.Collection_Status_Debooked_Timestamp__c}) ) * 4
  + CEILING( MONTH( DATEVALUE({!$Record.Collection_Status_Debooked_Timestamp__c}) ) / 3 )
  + 2
)</expression>
