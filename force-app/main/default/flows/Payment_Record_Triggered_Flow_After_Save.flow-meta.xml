    <decisions>
        <description>MQ-1445 (Payment: Status EQUALS Processed) AND (Payment: Amount GREATER THAN 241) AND (Payment: Amount NOT EQUAL TO 499) AND (Billing Account: Account Owner Role EQUALS Resellers - ANZ - Trellian)</description>
        <name>decision_RuleSTSuccessfulTrellianPayment</name>
        <label>*Rule (ST)* - Successful Payment</label>
        <locationX>402</locationX>
        <locationY>671</locationY>
        <defaultConnector>
            <targetReference>Rule_PP_Procceced_Payments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>False</defaultConnectorLabel>
        <rules>
            <name>Successful_Trellian_Payment</name>
            <conditionLogic>(1 OR 2) AND 3 AND 4 AND 5 AND 6</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Processed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Amount__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>241.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Amount__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <numberValue>499.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__BillingAccount__r.Account_Owner_Role__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Trellian</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>emailalert_STSuccessfulPaymentAlertTrellian</targetReference>
            </connector>
            <label>Successful Trellian Payment</label>
        </rules>
