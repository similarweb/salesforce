    <formulas>
        <name>Account_Subscription_Renewal_Date_Calculation</name>
        <dataType>Date</dataType>
        <expression>IF (
   {!Get_Account_Subscription_Product_Charge.Zuora__BillingPeriod__c} = &apos;Annual&apos; , 
      ADDMONTHS({!$Record.Zuora__Effective_Date__c}, 12), IF(
   {!Get_Account_Subscription_Product_Charge.Zuora__BillingPeriod__c} = &apos;Month&apos; , 
      ADDMONTHS({!$Record.Zuora__Effective_Date__c},1), 
   {!$Record.Zuora__Account__r.Subscription_Renewal_Date__c}
))</expression>
