    <environments>Default</environments>
    <formulas>
        <name>Email_Amendment_Subject</name>
        <dataType>String</dataType>
        <expression>&apos;Amendment &apos;+{!Record.zqu__Account__r.Name}+&apos;:&apos; + {!CurrentSolutionType} +&apos; purchase in Q2C from Similarweb&apos;</expression>
    </formulas>
    <formulas>
        <name>Email_New_Sale_Subject</name>
        <dataType>String</dataType>
        <expression>&apos;New Sale &apos;+{!Record.zqu__Account__r.Name}+ &apos;:&apos;  + {!CurrentSolutionType} +&apos;  purchase in Q2C from Similarweb&apos;</expression>
    </formulas>
    <formulas>
        <name>QuoteBusinessTypepicklistlable</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!Record.zqu__QuoteBusinessType__c}) = &apos;New&apos;,&apos;New Sale&apos;,TEXT({!Record.zqu__QuoteBusinessType__c}) )</expression>
    </formulas>
    <formulas>
        <name>RecipientListFormula</name>
        <dataType>String</dataType>
        <expression>IF(
{!CurrentSolutionType} = &apos;Admetricks&apos;, &apos;anamaria.labra@similarweb.com,pato.delsol@similarweb.com&apos;,
IF({!CurrentSolutionType} = &apos;42matters&apos;,  &apos;ivan.delchev@similarweb.com&apos;,
IF({!CurrentSolutionType} = &apos;TSM&apos;,  &apos;Sales@thesearchmonitor.com,support@thesearchmonitor.com&apos;,
IF({!CurrentSolutionType} = &apos;Newslever&apos;,  &apos;keith.graham@similarweb.com,amber.herndon@similarweb.com,amber@newslever.com&apos; 
,&apos;&apos;)
)))</expression>
    </formulas>
    <formulas>
        <name>RecordLinkVar</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_260})) &amp; {!Record.Id}</expression>
    </formulas>
    <formulas>
        <name>SolutionTypeFound</name>
        <dataType>String</dataType>
        <expression>IF({!Found_42matters_QRP}=true, &apos;42matters&apos;, 
IF({!Found_Admetricks_QRP}=true,&apos;Admetricks&apos;,
IF({!Found_Newslever_QRP}=true,&apos;Newslever&apos;,
IF({!Found_The_Search_Monitor_QRP}=true,&apos;The Search Monitor&apos;,&apos;&apos;
))))</expression>
    </formulas>
