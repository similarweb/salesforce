    <formulas>
        <name>Quantity_check_country</name>
        <dataType>String</dataType>
        <expression>IF(
  
       AND(  CONTAINS(TEXT({!$Record.zqu__QuoteRatePlan__r.zqu__Product__r.AddOnType__c}), &quot;CountryTier&quot;)

, ISBLANK(        {!$Record.Country_Filter__c}   ) )

,
       
    &quot;error&quot;,
    &quot;success&quot;
)</expression>
    </formulas>
