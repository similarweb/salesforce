    <decisions>
        <description>Check if the charge is updated charge the quantity is updated</description>
        <name>Is_quantity</name>
        <label>Is quantity from original</label>
        <locationX>50</locationX>
        <locationY>503</locationY>
        <defaultConnector>
            <targetReference>Copy_2_of_Conversions_error</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Null_outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>Null outcome</label>
        </rules>
        <rules>
            <name>The_updated_quantity_is_equal_to_original</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.zqu__Quantity__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get.Updated_quantity__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_success_value</targetReference>
            </connector>
            <label>The updated quantity is equal to original</label>
        </rules>
    </decisions>
    <decisions>
        <name>Quantity_check_for_multi_attribution</name>
        <label>Quantity check for multi attribution</label>
        <locationX>314</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>change_to_sucsess</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CountryTier</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AppsCF</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AppInCFTier</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Conversions</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Datasets</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ManagedServices</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.zqu__ProductRatePlanCharge__r.zqu__ProductRatePlan__r.zqu__Product__r.AddOnType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AggregatedGeo</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get</targetReference>
            </connector>
            <label>change to success</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
