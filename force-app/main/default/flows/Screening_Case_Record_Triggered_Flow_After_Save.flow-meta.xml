    <description>+ MIS-1310</description>
    <formulas>
        <name>formula_KYCFirstRED</name>
        <dataType>Boolean</dataType>
        <expression>IF(
{!$Record.tr_wc1__Sanctions__c} + {!$Record.tr_wc1__Sanctions_For_Positive__c} + {!$Record.tr_wc1__Other_Bodies__c} + {!$Record.tr_wc1__Other_Bodies_For_Positive__c} &gt; 0,
true,
false
)</expression>
    </formulas>
    <formulas>
        <name>formula_KYCFirstREDPrior</name>
        <dataType>Boolean</dataType>
        <expression>IF(
{!$Record__Prior.tr_wc1__Sanctions__c} + {!$Record__Prior.tr_wc1__Sanctions_For_Positive__c} + {!$Record__Prior.tr_wc1__Other_Bodies__c} + {!$Record__Prior.tr_wc1__Other_Bodies_For_Positive__c} &gt; 0,
true,
false
)</expression>
    </formulas>
