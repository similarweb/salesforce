    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
ISCHANGED( [Opportunity].StageName ),
ISPICKVAL([Opportunity].StageName, &apos;Closed Won&apos;),
ISBLANK(TEXT([Opportunity].Account.Primary_Use_Case__c )),
ISBLANK([Opportunity].Account.Secondary_Use_Case__c ),
NOT(ISPICKVAL([Opportunity].Account.Status__c ,&apos;Active&apos;)),
NOT(ISPICKVAL([Opportunity].Account.Status__c ,&apos;Cancelled&apos;)),
NOT(ISPICKVAL([Opportunity].Account.Status__c ,&apos;Part Of Another Subscription&apos;))
)
</stringValue>
            </value>
        </processMetadataValues>
