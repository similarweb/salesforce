    <decisions>
        <description>MQ-1445 Once Subscription Status changes to &apos;Cancelled&apos; and related account owner is not Salesforce Admin user (username &lt;&gt; salesops@similarweb.com) -&gt; send email alert to account owner</description>
        <name>decision_RuleCASubscriptionCancelled</name>
        <label>*Rule (CA)* - Subscription Cancelled</label>
        <locationX>1260</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Auto_Renewal</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>False</defaultConnectorLabel>
        <rules>
            <name>outcome_TrueSubscriptionCancelled</name>
            <conditionLogic>(1 OR 2) AND 3 AND NOT(4) AND 5</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>cancelled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__Account__r.Owner.Username</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>salesops@similarweb.com</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Zuora__TermSettingType__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>EVERGREEN</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>emailalert_CASubscriptionCancelled</targetReference>
            </connector>
            <label>True (Subscription Cancelled)</label>
        </rules>
    </decisions>
