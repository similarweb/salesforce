    <description>Currently Account TCV
Only Calculates when StartDate has come to past and EndDate is in the future, regardless of Subscription Status.</description>
    <formulas>
        <name>CalculatedAmount</name>
        <dataType>Currency</dataType>
        <expression>{!NumberOfMonths}*{!SubsSobject.Zuora__MRR__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>CalculatedAmountbyRenewalTerm</name>
        <dataType>Currency</dataType>
        <expression>VALUE(LEFT({!SubsSobject.Zuora__RenewalTerm__c},2))*{!SubsSobject.Zuora__MRR__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>NumberOfMonths</name>
        <dataType>Number</dataType>
        <expression>IF(LEN({!SubsSobject.Zuora__InitialTerm__c})=8,
VALUE(LEFT({!SubsSobject.Zuora__InitialTerm__c},1)),
VALUE(LEFT({!SubsSobject.Zuora__InitialTerm__c},2)))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>TermInMonths</name>
        <dataType>Boolean</dataType>
        <expression>RIGHT({!SubsSobject.Zuora__InitialTerm__c},6)=&quot;Months&quot;</expression>
    </formulas>
