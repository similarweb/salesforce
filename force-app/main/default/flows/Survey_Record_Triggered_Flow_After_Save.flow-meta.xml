                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NPS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GF_Lead_or_Contact</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
