    <description>updated to run on tasks created after 01/08/25 to avoid failures
MIS-7654
MIS-7156
MIS-5708
MIS-4859</description>
    <environments>Default</environments>
    <formulas>
        <description>MIS-4859</description>
        <name>NOW_Minus_1_Business_Day</name>
        <dataType>DateTime</dataType>
        <expression>NOW()-{!X1_Business_Day_to_Skip}</expression>
    </formulas>
    <formulas>
        <description>MIS-4859</description>
        <name>X1_Business_Day_to_Skip</name>
        <dataType>Number</dataType>
        <expression>CASE(WEEKDAY(DATEVALUE({!$Record.CreatedDate)}),
1, 1,
2, 1,
3, 1,
4, 1,
5, 1,
6, 3,
7, 2, 0
)</expression>
        <scale>0</scale>
    </formulas>
