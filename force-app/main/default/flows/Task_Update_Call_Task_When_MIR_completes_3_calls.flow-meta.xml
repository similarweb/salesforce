    <description>MIS-2826</description>
    <environments>Default</environments>
    <formulas>
        <description>Subject CONTAINS “Outbound call (completed)” 
AND 
Call Tags CONTAINS
“Not Interested” || “Wrong/Bad Number” || “Unqualified” || “Hung up/Ask to stop calling” || “HO” 
|| “Don’t Speak English” || “Meeting Reminder”</description>
        <name>Completed_Call_Conditions_Formula</name>
        <dataType>Boolean</dataType>
        <expression>CONTAINS({!$Record.Subject}, &apos;Outbound call (completed)&apos;)
&amp;&amp;
(
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Not Interested&apos;) || 
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Wrong/Bad Number&apos;) || 
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Unqualified&apos;) ||
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Hung up/Ask to stop calling&apos;) ||
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;HO&apos;) ||
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Don’t Speak English&apos;) ||
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Meeting Reminder&apos;) 
)</expression>
    </formulas>
    <formulas>
        <name>Counter_For_Main_Call_Task_Formula</name>
        <dataType>Number</dataType>
        <expression>VALUE(RIGHT({!Get_Main_Call_Task.Subject}, 1)) + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Last_24_Hours</name>
        <dataType>DateTime</dataType>
        <expression>{!$Flow.CurrentDateTime} - 1</expression>
    </formulas>
    <formulas>
        <name>New_Subject_Formula</name>
        <dataType>String</dataType>
        <expression>&quot;New Inbound Lead Call - Today: &quot; + TEXT({!Counter_For_Main_Call_Task_Formula})</expression>
    </formulas>
    <formulas>
        <name>Today_Minus_14_Days</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 14</expression>
    </formulas>
    <formulas>
        <description>Today + 2 Days without Saturday and Sunday</description>
        <name>Today_Plus_2_Days_Formula</name>
        <dataType>Date</dataType>
        <expression>CASE (
WEEKDAY(TODAY()),
5,TODAY() + 4,
6,TODAY() + 4, 
TODAY() + 2
)</expression>
    </formulas>
    <formulas>
        <description>Subject CONTAINS:  “No Conversation” / “Left Message” / “Call: No Answer” / “Outbound call (unanswered)” / “Call - Attempt” / “Call: Busy” / “Call: Left Voicemail” / “Call: Rejected”
OR
( 
Subject CONTAINS “Outbound call (completed)” 
AND  
Call Tags CONTAINS “No Answer” / “Follow Up” / “Go Straight to Voicemail” / “Reschedule”
)</description>
        <name>Unanswered_Call_Conditions_Formula</name>
        <dataType>Boolean</dataType>
        <expression>(
CONTAINS({!$Record.Subject}, &apos;No Conversation&apos;) || CONTAINS({!$Record.Subject}, &apos;Left Message&apos;) || CONTAINS({!$Record.Subject}, &apos;Call: No Answer&apos;) || CONTAINS({!$Record.Subject}, &apos;Outbound call (unanswered)&apos;) || CONTAINS({!$Record.Subject}, &apos;Call - Attempt&apos;) || CONTAINS({!$Record.Subject}, &apos;Call: Busy&apos;) || CONTAINS({!$Record.Subject}, &apos;Call: Left Voicemail&apos;) || CONTAINS({!$Record.Subject}, &apos;Call: Rejected&apos;)
)
||
(
CONTAINS({!$Record.Subject}, &apos;Outbound call (completed)&apos;)
&amp;&amp;
(
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;No Answer&apos;) || 
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Follow Up&apos;) || 
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Go Straight to Voicemail&apos;) ||
CONTAINS({!$Record.cloudtalk__CallTags__c}, &apos;Reschedule&apos;)
)
)</expression>
    </formulas>
