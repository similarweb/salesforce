<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Days_In_Trial__c</fullName>
    <description>Counts the current day in the trial</description>
    <externalId>false</externalId>
    <formula>If(NT_status__c= &quot;Trial&quot;,(Today()+1)-DATEVALUE(First_No_Touch_Pro_Purchase_Date__c) ,null)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Days In Trial</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
