<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MIR_accounts_ownership</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
$Profile.Name = &quot;SW Sales Internal&quot;,
ISCHANGED(OwnerId),
NOT(CONTAINS(PRIORVALUE(Owner_Division__c), &quot;MIR&quot;)),
NOT(CONTAINS(PRIORVALUE(Owner_Division__c), &quot;SDR&quot;)),


$User.Id = OwnerId
)</errorConditionFormula>
    <errorMessage>You don&apos;t have an access to transfer this record</errorMessage>
</ValidationRule>
