<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>User_is_Owner__c</fullName>
    <description>Check if the running User is the Contact Owner or the Contact Owner&apos;s Manager/2nd or 3rd Manager. MIS-2454</description>
    <externalId>false</externalId>
    <formula>$User.Id = OwnerId ||
$User.Id=Owner.ManagerId ||
$User.Id=Owner.Manager.ManagerId ||
$User.Id=Owner.Manager.Manager.ManagerId</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>User is Owner</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
