<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Was_contacted__c</fullName>
    <description>Checks if the contact had tasks</description>
    <externalId>false</externalId>
    <formula>IF( Closed_Tasks_Counter__c  +  Open_Tasks_Counter__c  &gt; 0, &quot;Contacted&quot;, &quot;Not contacted&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Was contacted</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
