<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Deprioritized_MIR_Status_without_Reason</fullName>
    <active>false</active>
    <description>MIS-4660</description>
    <errorConditionFormula>ISPICKVAL(Deprioritized_Reason__c, &quot;&quot;)
&amp;&amp;
 ISCHANGED(MIR_Status__c)  
	&amp;&amp;
	 ISPICKVAL(MIR_Status__c , &quot;Deprioritized&quot;)</errorConditionFormula>
    <errorMessage>You must specify Deprioritized Reason when selecting &quot;Deprioritized&quot; MIR Status</errorMessage>
</ValidationRule>
