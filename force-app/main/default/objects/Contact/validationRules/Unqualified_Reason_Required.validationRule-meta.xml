<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Unqualified_Reason_Required</fullName>
    <active>true</active>
    <description>MIS-1190 MIS-1193</description>
    <errorConditionFormula>AND(
ISCHANGED(Status__c),
ISPICKVAL(Status__c, &quot;Unqualified&quot;),
ISBLANK(Unqualified_Reason__c)
)</errorConditionFormula>
    <errorDisplayField>Unqualified_Reason__c</errorDisplayField>
    <errorMessage>Unqualified Reason is required</errorMessage>
</ValidationRule>
