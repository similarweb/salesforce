<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>User_is_Owner__c</fullName>
    <description>Check if the running User is the Lead Owner or the Lead Owner&apos;s Manager/2nd or 3rd Manager. MIS - 2454</description>
    <externalId>false</externalId>
    <formula>$User.Id = Owner:User.Id ||
$User.Id=Owner:User.ManagerId ||
$User.Id=Owner:User.Manager.ManagerId ||
$User.Id=Owner:User.Manager.Manager.ManagerId</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>User is Owner</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
