<?xml version="1.0" encoding="UTF-8"?>
<ListView xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Brendan_Call_View</fullName>
    <columns>FULL_NAME</columns>
    <columns>LEAD.EMAIL</columns>
    <columns>LEAD.COMPANY</columns>
    <columns>LEAD.PHONE</columns>
    <columns>LEAD.MOBILE_PHONE</columns>
    <filterScope>Everything</filterScope>
    <filters>
        <field>LEAD.PHONE</field>
        <operation>notEqual</operation>
    </filters>
    <filters>
        <field>LEAD.MOBILE_PHONE</field>
        <operation>notEqual</operation>
    </filters>
    <filters>
        <field>Visits_over_time_monthly__c</field>
        <operation>greaterThan</operation>
        <value>80000</value>
    </filters>
    <filters>
        <field>LEAD.LEAD_SOURCE</field>
        <operation>equals</operation>
        <value>Pro</value>
    </filters>
    <filters>
        <field>Country_Region__c</field>
        <operation>equals</operation>
        <value>northamerica</value>
    </filters>
    <filters>
        <field>LEAD.LAST_ACTIVITY</field>
        <operation>lessThan</operation>
        <value>LAST_N_DAYS:30</value>
    </filters>
    <label>Brendan Call View</label>
</ListView>
