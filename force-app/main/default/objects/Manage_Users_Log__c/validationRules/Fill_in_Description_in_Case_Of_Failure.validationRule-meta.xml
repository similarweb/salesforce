<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Fill_in_Description_in_Case_Of_Failure</fullName>
    <active>true</active>
    <errorConditionFormula>ISCHANGED( Status__c ) 
&amp;&amp;
TEXT(PRIORVALUE(Status__c)) = &apos;Failed&apos;
&amp;&amp;
LEN( Description_for_Fixing_Failure__c ) = 0</errorConditionFormula>
    <errorDisplayField>Description_for_Fixing_Failure__c</errorDisplayField>
    <errorMessage>Please fill in the Description for the steps taken to solve the failure.</errorMessage>
</ValidationRule>
