<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ENT_CSM_can_use_only_AE</fullName>
    <active>false</active>
    <errorConditionFormula>AND( 
ISNEW(), 
RecordType.DeveloperName  != &apos;0123E000000YF8l&apos;, 
CONTAINS($UserRole.DeveloperName,&apos;ENT&apos;), 
CONTAINS($UserRole.DeveloperName,&apos;CSM&apos;) 
)</errorConditionFormula>
    <errorMessage>Enterprise Account Executives can use only &quot;AE&quot; Record Type</errorMessage>
</ValidationRule>
