<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Only_ENT_CSM_use_AE_Record_Type</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISNEW(),
    RecordTypeId = &apos;0123E000000YF8l&apos;, 
    NOT(CONTAINS($UserRole.DeveloperName,&apos;ENT&apos;)),
    NOT(CONTAINS($UserRole.DeveloperName,&apos;CSM&apos;))
   )</errorConditionFormula>
    <errorMessage>Only Enterprise Account Executives can use this Record Type</errorMessage>
</ValidationRule>
