<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Primary_solution_not_same_as_Secondary</fullName>
    <active>true</active>
    <description>Prevents users from selecting the same value in both fields</description>
    <errorConditionFormula>AND( 
    NOT(ISBLANK(TEXT(Primary_Solution__c ))), 
    NOT(ISBLANK(TEXT(Secondary_Solution__c))), 
    TEXT(Primary_Solution__c )=TEXT(Secondary_Solution__c) 
   )</errorConditionFormula>
    <errorDisplayField>Secondary_Solution__c</errorDisplayField>
    <errorMessage>Primary and Secondary solutions cannot be the same</errorMessage>
</ValidationRule>
