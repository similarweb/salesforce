<?xml version="1.0" encoding="UTF-8"?>
<ListView xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Copy_of_10_that_we_should_close</fullName>
    <booleanFilter>(1 AND (2 or 7) and 3 AND 4 AND 5) or (1 AND (2 or 7) and 4 AND 5 and 6)</booleanFilter>
    <columns>CORE.USERS.FULL_NAME</columns>
    <columns>OPPORTUNITY.NAME</columns>
    <columns>ACCOUNT.NAME</columns>
    <columns>OPPORTUNITY.CREATED_DATE</columns>
    <columns>OPPORTUNITY.STAGE_NAME</columns>
    <columns>Age__c</columns>
    <columns>ARR__c</columns>
    <columns>OPPORTUNITY.CLOSE_DATE</columns>
    <columns>OPPORTUNITY.LAST_ACTIVITY</columns>
    <filterScope>Team</filterScope>
    <filters>
        <field>OPPORTUNITY.STAGE_NAME</field>
        <operation>equals</operation>
        <value>Prospect</value>
    </filters>
    <filters>
        <field>Opportunity_Division__c</field>
        <operation>contains</operation>
        <value>ENT Sales - Europe,ENT Sales - France,ENT Sales - US,Global Sales - Agencies,Global Sales - Europe,Global Sales - Investors,Global Sales - US,Reseller - ANZ - Direct,Reseller - Brazil,Reseller - Japan,SMB Sales - ROW,SMB Sales - US</value>
    </filters>
    <filters>
        <field>Age__c</field>
        <operation>greaterOrEqual</operation>
        <value>45</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.TYPE</field>
        <operation>equals</operation>
        <value>New Sale</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.LAST_ACTIVITY</field>
        <operation>notEqual</operation>
        <value>LAST_N_DAYS:30</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.CLOSE_DATE</field>
        <operation>equals</operation>
        <value>THIS_MONTH</value>
    </filters>
    <filters>
        <field>Opportunity_Division__c</field>
        <operation>equals</operation>
        <value>Channel Sales,Reseller - Brazil,Reseller - Iberia-Digital Ventures,Reseller - Iberia-DigitalVentures,Reseller - India-eDynamics,Reseller - Italy-GlobalDots,Reseller - SEA-Maestros,Reseller - Turkey-CloudyFlex</value>
    </filters>
    <label>Copy of 10% that we should close</label>
</ListView>
