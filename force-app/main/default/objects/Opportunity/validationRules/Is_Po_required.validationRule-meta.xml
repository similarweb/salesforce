<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_Po_required</fullName>
    <active>true</active>
    <description>MQ-2126</description>
    <errorConditionFormula>and (ISchanged (Po_Number__c),not(isblank(Po_Number__c)), Not(ISPICKVAL( Do_customer_have_PO__c , &quot;Yes&quot;) ))</errorConditionFormula>
    <errorDisplayField>Do_customer_have_PO__c</errorDisplayField>
    <errorMessage>Please  change Is a PO required to yes</errorMessage>
</ValidationRule>
