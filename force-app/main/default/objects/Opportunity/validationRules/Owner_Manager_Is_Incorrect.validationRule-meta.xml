<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Owner_Manager_Is_Incorrect</fullName>
    <active>true</active>
    <errorConditionFormula>Owner_s_Manager__c != Owner.ManagerId &amp;&amp; ISCHANGED(Owner_s_Manager__c)</errorConditionFormula>
    <errorDisplayField>Owner_s_Manager__c</errorDisplayField>
    <errorMessage>Opportunity Owner Manager must be the same person as Owner&apos;s Manager</errorMessage>
</ValidationRule>
