<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Logo_Rights_Upon_Winning</fullName>
    <active>false</active>
    <errorConditionFormula>ISPICKVAL(StageName , &quot;Closed Won&quot;)&amp;&amp;LEN(TEXT( Logo_Rights__c ))&lt;3&amp;&amp;
