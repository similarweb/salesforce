<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Feedback_Notes_Required</fullName>
    <active>true</active>
    <description>Feedback Notes Required when score is &lt;7.</description>
    <errorConditionFormula>IF(CASE( General_Feedback_Rate__c , &quot;1&quot;, &quot;TRUE&quot;, &quot;2&quot;, &quot;TRUE&quot;, &quot;3&quot;, &quot;TRUE&quot;, &quot;4&quot;, &quot;TRUE&quot;, &quot;5&quot;, &quot;TRUE&quot;, &quot;6&quot;, &quot;TRUE&quot; 
,&quot;FALSE&quot;)=&quot;TRUE&quot;,TRUE,FALSE) &amp;&amp; 
ISBLANK( Additional_Feedback_Notes__c ) &amp;&amp; 
NOT($Profile.Id=&apos;00eb0000000oBvcAAE&apos;)</errorConditionFormula>
    <errorDisplayField>Additional_Feedback_Notes__c</errorDisplayField>
    <errorMessage>When the &quot;General Feedback&quot; is less than 7 &quot;Additional Feedback Notes&quot; are required.</errorMessage>
</ValidationRule>
