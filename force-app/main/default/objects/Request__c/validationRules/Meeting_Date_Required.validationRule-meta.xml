<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Meeting_Date_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    RecordType.DeveloperName = &apos;Strategic_Consultant&apos;,
    Client_Meeting_Scheduled__c = true,
    ISBLANK(Meeting_Date__c)
)</errorConditionFormula>
    <errorDisplayField>Meeting_Date__c</errorDisplayField>
    <errorMessage>Please populate Meeting Date</errorMessage>
</ValidationRule>
