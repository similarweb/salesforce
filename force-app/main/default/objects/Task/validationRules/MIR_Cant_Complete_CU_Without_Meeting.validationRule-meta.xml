<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MIR_Cant_Complete_CU_Without_Meeting</fullName>
    <active>true</active>
    <description>MIS-4859</description>
    <errorConditionFormula>RecordType.DeveloperName =&apos;Contact_Us_Task&apos;  &amp;&amp;
 ISBLANK(Related_Meeting__c)  &amp;&amp;
