                function populateLookups(){
                    let billingAccountId = "{!$CurrentPage.parameters.billingAccountId}";
                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.CreateQuotePageController.getSoldToAndBillToByEmail}',
                        billingAccountId,
                        function(result, event){
                            if (event.status && result) {
                                let soldToContactId = result.soldToContactId ? result.soldToContactId : '';
                                let soldToContactName = result.soldToContact ? result.soldToContact : '';
                                let billToContactId = result.billToContactId ? result.billToContactId : '';
                                let billToContactName = result.billToContact ? result.billToContact : '';

                                var soldToLabelElement = findElementByContainingPharse('label', 'text()', 'Admin User');
                                var soldToIdInputElementDisplay = getSoldToIdInputFromLabelElement(soldToLabelElement,'targetNameDisplay');
                                var soldToIdInputElementId = getSoldToIdInputFromLabelElement(soldToLabelElement);
                                var billToLabelElement = findElementByContainingPharse('label', 'text()', 'Bill to Contact');
                                var billToIdInputElementDisplay = getSoldToIdInputFromLabelElement(billToLabelElement,'targetNameDisplay');
                                var billToIdInputElementId = getSoldToIdInputFromLabelElement(billToLabelElement);
                                soldToIdInputElementId.value = soldToContactId;
                                billToIdInputElementId.value = billToContactId;
                                soldToIdInputElementDisplay.value = soldToContactName;
                                billToIdInputElementDisplay.value = billToContactName;


                            } else {
                                console.log('exception on server');
                            }
                        }
                    );
                }



