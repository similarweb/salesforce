                function getSoldToIdInputFromLabelElement(soldToLabelElement,idAttribute){
                    if(!idAttribute){
                        idAttribute = "targetId";
                    }
                    var parentThNode = soldToLabelElement.parentNode;
                    var parentTrNode = soldToLabelElement.parentNode.parentNode;
                    if(parentTrNode.tagName != 'TR'){
                        parentThNode = parentTrNode;
                        parentTrNode = parentTrNode.parentNode;
                    }
                    if (!parentTrNode) {
                        return '';
                    }
                    var indexOfLabel = Array.from(parentTrNode.childNodes).indexOf(parentThNode);
                    if (indexOfLabel < 0) {
                        return '';
                    }
                    var soldToNode = parentTrNode.childNodes[indexOfLabel + 1];
                    if (!soldToNode) {
                        return '';
                    }
                    var soldToNodeDivEl = soldToNode.querySelector('div[id]');
                    if (!soldToNodeDivEl) {
                        return;
                    }
                    var idInput = soldToNodeDivEl.querySelector('[id*="'+idAttribute+'"]');
                    return idInput;
                }

