                function setElementsAsReadonly(listOfElements){
                    var listOfElementsClone = Array.from(listOfElements);

                    for(let el of listOfElementsClone){
                        var tag = el.tagName;
                        if(tag == 'SELECT'){
                            createSpan(el,true);
                        }else if(tag == 'INPUT'){
                            if(el.type == 'checkbox'){
                                el.disabled = true;
                            } else if(el.type == 'text'){
                                createSpan(el,true);
                            }
                        }else if(tag == 'IMG'){
                            el.style.display = 'none';
                        }

                        function createSpan(elem,isSelect){
                            var inputValue;
                            if(elem.value.length == 0){
                                inputValue = '-';
                            } else{
                                inputValue = elem.value;
                            }
                            var newEl = document.createElement('span');
                            newEl.innerHTML = inputValue;
                            newEl.dataset.mode='readOnly';
                            if(elem.style.display == 'none'){
                                return;
                            } else {
                                elem.style.display = 'none';
                                for (const requiredBlockEl_i of elem.parentNode.getElementsByClassName('requiredBlock')) {
                                    requiredBlockEl_i.style.display = 'none';
                                }
                                elem.parentNode.appendChild(newEl);
                            }
                        }
                    }
                }

                function setElementsAsWriteable(listOfElements){
                    let listOfElementsClone = Array.from(listOfElements);

                    for(let el of listOfElementsClone){
                        let parentNode = el.parentNode;
                        var spanElArr = parentNode.getElementsByTagName('span');
                        var allInputs = parentNode.getElementsByTagName("input");
                        var allSelects = parentNode.getElementsByTagName("select");
                        var requiredFields = parentNode.querySelectorAll(".requiredBlock");
                        var allImgs = parentNode.getElementsByTagName("img");
                        for (const spanEl_i of spanElArr) {
                            spanEl_i.style.display = 'none';
                        }
                        for (const ipuntEl_i of allInputs) {
                            if (ipuntEl_i.style.display == 'none') {
                                ipuntEl_i.style.display = 'inline-block';
                            }
                        }
                        for (const selectEl_i of allSelects) {
                            if (selectEl_i.style.display == 'none') {
                                selectEl_i.style.display = 'inline-block';
                            }
                        }
                        for (const requiredEl_i of requiredFields) {
                            if (requiredEl_i.style.display == 'none') {
                                requiredEl_i.style.display = 'block';
                            }
                        }
                    }
                }

                function setCustomerRequestToPayImmediatelyCheckbox(){
                    const businessType = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__QuoteBusinessType__c]'));
                    if(businessType){
                        const isRenewalBusinessType = checkIfQuoteBusinessTypeIsRenewal(businessType);
                        if(isRenewalBusinessType){
                            const subTermStartDate = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]'));
                            if(subTermStartDate){
                                const subscriptionTermStartDate = new Date(subTermStartDate);

                                let currentDate = new Date();
                                const subscriptionTermStartDateRangeStart = currentDate.addDays(-7);
                                const subscriptionTermStartDateRangeEnd = currentDate.addDays(7);
                                const isDateInRange = ((subscriptionTermStartDateRangeStart.getTime() < subscriptionTermStartDate.getTime())&& (subscriptionTermStartDate.getTime() < subscriptionTermStartDateRangeEnd.getTime()));
                                if(isDateInRange){
                                    disableCustomerRequestsToPayImmedately();
                                } else {
                                    changeDisableOfField('Customer_requests_to_pay_immediately__c', true);
                                }
                            }
                        } else {
                            changeDisableOfField('Customer_requests_to_pay_immediately__c', true);
                        }
                    }
                }

                function checkIfQuoteBusinessTypeIsRenewal(businessType){
                    const CO_TERM_UPSELL_RENEWAL = 'Co-Term Upsell + Renewal';
                    const FEATURE_UPDATE_RENEWAL = 'Feature Update + Renewal (with/without upsell)';
                    const RENEWAL = 'Renewal (with/without upsell)';

                    const isCoTermRenewal = (businessType == CO_TERM_UPSELL_RENEWAL);
                    const isFeatureRenewal = (businessType == FEATURE_UPDATE_RENEWAL);
                    const isRenewal = (businessType == RENEWAL);
                    return isCoTermRenewal || isFeatureRenewal || isRenewal;
                }

                function disableCustomerRequestsToPayImmedately(){
                    setQuoteFieldNew('Customer_requests_to_pay_immediately__c',false);
                    changeDisableOfField('Customer_requests_to_pay_immediately__c', false);
                }

                //onClickNextButton();
                onClickCancelButton();

                function handleContractEffectiveDateChange(paymentMethod, quoteBusinessType){
                    if(paymentMethod == 'Credit Card' || paymentMethod == 'PayPal'){
                        if(quoteBusinessType == 'Renewal (with/without upsell)'){
                            changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                            setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                            changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        } else {
                            changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                            changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                        }
                    } else if(paymentMethod == 'Wire Transfer'){
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                        if(quoteBusinessType == 'Feature Update'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                        } else if(quoteBusinessType == 'Co-Term Upsell'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Signature Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                        } else if(quoteBusinessType == 'Renewal (with/without upsell)'){
                            changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                            setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                            changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        }
                    } else if(paymentMethod == 'Other') {
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                        if(quoteBusinessType == 'Feature Update'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                        } else if(quoteBusinessType == 'Co-Term Upsell'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        } else if(quoteBusinessType == 'Co-Term Upsell + Renewal'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        } else if(quoteBusinessType == 'Feature Update + Renewal (with/without upsell)'){
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        } else if(quoteBusinessType == 'Renewal (with/without upsell)'){
                            changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                            setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                            changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                            setQuoteFieldNew('Contract_Start_Upon__c','Start Date');
                            changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                        }
                    }
                }

                function changeProductPicklist(){
                    let isSalesOpsEnabled = "{!isSalesOpsEnabled}";
                    if(isSalesOpsEnabled == "false"){
                        let productTypeAmendmentSpanList = document.querySelectorAll('[data-field-name=Product_Type_Amendment__c]');
                        if(productTypeAmendmentSpanList != undefined && productTypeAmendmentSpanList.length > 0){
                            let productTypeAmendmentNode = getQuoteFileNodeNew(productTypeAmendmentSpanList);
                            removePicklistValueUtil(productTypeAmendmentNode, 'Marketing');
                            removePicklistValueUtil(productTypeAmendmentNode, 'Research');
                            /*Itzik Winograd 2022-03-07 MQ-1443: Remove "Investors" and "Sales" for non-salesops-profile users. */
                            removePicklistValueUtil(productTypeAmendmentNode, 'Investors');
                            removePicklistValueUtil(productTypeAmendmentNode, 'Sales');
                        }
                    }
                }

