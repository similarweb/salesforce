<apex:page standardController="zqu__Quote__c" tabStyle="zqu__Quote__c" sidebar="false" extensions="CreateQuoteAmendPageController,CreateQuotePageController">
    <apex:includeScript value="{!$Resource.UtilJS}"/>
    <apex:composition template="zqu__QuoteWizardTemplateNoForm" >
        <apex:define name="PageBody" >
            <apex:outputText value="{!zqu__Quote__c.zqu__SubscriptionTermStartDate__c}" rendered="false"/>
            <zqu:CreateQuote subscriptionId="{!$CurrentPage.parameters.subscriptionId}"
                             billingAccountId="{!$CurrentPage.parameters.billingAccountId}"
                             opportunityId="{!$CurrentPage.parameters.oppId}"
                             crmAccountId="{!$CurrentPage.parameters.crmAccountId}"
                             renderBackButton="true"
                             title="Create Quote" />
            <style>
                ul.defaultUl {
                    list-style-type: disc !important;
                    list-style-position: inside !important;
                }
            </style>
            <script>
                Date.prototype.addDays = function(days) {
                    var date = new Date(this.valueOf());
                    date.setDate(date.getDate() + days);
                    return date;
                }
                Date.prototype.addMonths = function(months) {
                    var date = new Date(this.valueOf());
                    date.setDate(date.getMonth() + months);
                    return date;
                }
                var certNodeName;
                var certNode = getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=zqu__Certificate_ID__c]"));
                if (certNode) {
                    certNodeName = certNode.name;
                }
                var companyNodeName;
                var companyNode = getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=Company_Vat_ID__c]"));
                if (companyNode) {
                    companyNodeName = companyNode.name;
                }
                var taxCountriesWithNoValidation = ['Israel','United Kingdom', 'Malaysia', 'Indonesia', 'Singapore'];
                removeAllChildFromNode(companyNode.parentNode.parentNode);
                changeDisplayOfFieldNew('zqu__Amendment_Name__c',false,true);
                var subEndDateInitalValue = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermEndDate__c]'));
                var packageAmendmentsByPackage;
                getPackageAmendmentsByPackage();
                var isLoading = true;
                var quoteExist = isQuoteExist();
                changeDisplayOfFieldUtil('Special_Payment_Terms_Details_Amend__c',false,false,true);
                changeDisplayOfFieldUtil('Pre_Approved_Migration__c', false, true, true);
                invoiceOwnerObserver();
                packageAmendObserver();
                productCompabilityAmendObserver();
                listenPackagePicklist();
                var quoteId="{!zqu__Quote__c.Id}";
                setFieldAsReadOnly('payment_frequency1__c');
                changeDisplayOfField('JP_Parent_Name__c',false, true, true);
                changeDisplayOfField('Legacy_or_New_solution_deal__c',false,true,false);
                changeDisplayOfField('New_solution_use_case__c',false,true,false);
                setMandatoryOfFieldId('zqu__ValidUntil__c',false);
                setMandatoryOfFieldId('Amendment_Renewal_Start_Date__c',false);
                setMandatoryOfFieldId('Amendment_Initial_Term__c',false);
                setMandatoryOfFieldId('Amendment_Renewal_Term__c',false);
                setMandatoryOfFieldId('Renewal_Fee__c',false);
                changeDisplayOfField('Customer_Type__c',true);
                changeDisplayOfField('Company_Vat_ID__c',true);
                removeCurrencyNoneValue();
                hideBaseProductPicklist();
                listenSubscriptionStartDate();
                listenStartDateField();
                listenSoldToField();
                listenBillToField();
                listenIfBillingAccIsSelectedAmend();
                listenCustomerTypePicklist();
                listenCertificateIdField();
                listenNewTermTotalField();
                listenRenewalConfirmationField();
                listenDocumentTypePicklist();
                hideToDeleteSection();
                addHelpTextToLookups();
                addHelpTextToCurrency();
                listenPaymentMethodPicklist();
                listenAmendRenewalPaymentMethodPicklist(quoteExist);
                listenAmendRenewalInitialTerm(quoteExist);
                listenContractStartUponPicklist();
                listenPaymentTypePicklist();
                listenAmendRenewalPaymentTypePicklist(quoteExist);
                listenPaymentTermPicklist();
                listenAmendRenewalPaymentTermPicklist();
                listenPaymentFrequencyPicklist();
                listenAmendRenewalPaymentFrequencyPicklist();
                listenJpParentPicklist();
                listenDocumentLanguagePicklist();
                listenInitialTerm(quoteExist);
                listenAmendmentInitialTerm(quoteExist);
                changeSizeOfSpecificInputFields();
                setDefaultValues(quoteExist);
                changeAllPicklists();
                hideAllBufferSection();
                initializePackagePicklists();
                reorderProposalInformationSection();
                listenQuoteBusinessTypeField();
                listenMigrationToNewSolutionField();
                listenPackageAmendment();
                setFieldsAsReadOnly();
                newSolutionUseCaseObserver();
                packageObserver();
                productCompabilityObserver();
                amendmentNameMaxLength();
                setFieldAsReadOnly('Amendment_Renewal_Payment_Method__c');
                listenTrialQuoteCheckbox(quoteExist);
                removeRenewalPaymentTermPicklistValues();
                listenAdditionalServicesPicklistUtil();
                listenPercentageNewTermTotalField();
                getCountrySubsidiary();
                existingQuoteLogic();
                populateLookups();
                var groupDescription = "{!groupDescription}";
                populateGroupDescriptionUtil(groupDescription);
                rankRangerCheck();


                function isQuoteExist(){
                    var quoteId = '{! zqu__Quote__c.Id }';
                    return !!quoteId;
                };
                function rankRangerCheck(){
                    let isUserRoleRankRanger = {!isUserRoleRankRanger};
                    if(!isUserRoleRankRanger){
                        removePicklistValue(document.querySelector("[data-field-name=Product_Type_Amendment__c]").parentNode.querySelector("select"),'Rank Ranger');
                    }
                }

                if(!isQuoteExist()){
                    changeDisplayOfFieldUtil('Feature_Update_Reason__c', false);
                }

                function invoiceOwnerObserver(){
                    var elem = document.querySelector('[data-id=customRenderedInvoiceOwner]').parentNode;
                    if (!elem) {
                        return;
                    }
                    var observer2 = new MutationObserver(callback2)
                        .observe(elem, {childList : true});

                    function callback2(mutations, observer2) {
                        var jpParentSpanList = document.querySelectorAll('[data-field-name=JP_Parent_Name__c]');
                        var selectValue = getQuoteFieldValue(jpParentSpanList);
                        var invoiceOwnerNode = document.querySelector('[data-id=customRenderedInvoiceOwner]');
                        if(selectValue == 'Gaprise inc.'){
                            if (invoiceOwnerNode) {
                                invoiceOwnerNode.style.display='none';
                                let gapriseIncAccId="{!gapriseIncAccId}";
                                let gapriseIncAccName="{!gapriseIncAccName}";
                                if (gapriseIncAccId && gapriseIncAccName) {
                                    var inputIdArr = invoiceOwnerNode.querySelectorAll('input[id*=targetId]');
                                    if (inputIdArr && inputIdArr[0]) {
                                        inputIdArr[0].value=gapriseIncAccId;
                                    }
                                    var inputNameArr = invoiceOwnerNode.querySelectorAll('input[id*=targetName]');
                                    if (inputNameArr && inputNameArr[0]) {
                                        inputNameArr[0].value=gapriseIncAccName;
                                    }
                                    var inputNameDisplayArr = invoiceOwnerNode.querySelectorAll('input[id*=targetNameDisplay]');
                                    if (inputNameDisplayArr && inputNameDisplayArr[0]) {
                                        inputNameDisplayArr[0].value=gapriseIncAccName;
                                    }
                                }
                            }

                        } else {
                            if (invoiceOwnerNode) {
                                invoiceOwnerNode.style.display='none';
                                var inputIdArr = invoiceOwnerNode.querySelectorAll('input[id*=targetId]');
                                if (inputIdArr && inputIdArr[0]) {
                                    inputIdArr[0].value='';
                                }
                                var inputNameArr = invoiceOwnerNode.querySelectorAll('input[id*=targetName]');
                                if (inputNameArr && inputNameArr[0]) {
                                    inputNameArr[0].value='';
                                }
                                var inputNameDisplayArr = invoiceOwnerNode.querySelectorAll('input[id*=targetNameDisplay]');
                                if (inputNameDisplayArr && inputNameDisplayArr[0]) {
                                    inputNameDisplayArr[0].value='';
                                }
                            }
                        }
                    }
                }

                function listenTrialQuoteCheckbox(quoteExist){
                    var trialQuoteSpanList = document.querySelectorAll('[data-field-name=Trial_Quote__c]');
                    if(trialQuoteSpanList != undefined &&  trialQuoteSpanList.length > 0){
                        var trialQuoteSpanList = document.querySelectorAll('[data-field-name=Trial_Quote__c]');
                        var checboxValue = getQuoteFieldValue(trialQuoteSpanList);
                        onTrialQuoteCheckboxChange(checboxValue, false);
                        getQuoteFileNode(trialQuoteSpanList).onchange = function(){
                            selectValue = event.target.checked;
                            onTrialQuoteCheckboxChange(selectValue, true);

                        };


                        function onTrialQuoteCheckboxChange(selectValue, isChange)  {
                            changeDisplayOfFieldNew('Trial_End_Date__c', selectValue);
                            if (selectValue) {
                                setQuoteFieldNew('zqu__QuoteBusinessType__c','Feature Update');
                                setMandatoryOfFieldId('Trial_End_Date__c',true);
                                setFieldAsReadOnly('zqu__QuoteBusinessType__c');

                                let trialEndDate = new Date(Date.now());
                                trialEndDate.setDate(trialEndDate.getDate() + 7);
                                let trialEndDateElement = document.querySelectorAll('[data-field-name=Trial_End_Date__c]');
                                if(trialEndDateElement !== undefined && trialEndDateElement.length > 0){
                                    let trialEndDateNode = getQuoteFileNodeNew(trialEndDateElement);
                                    (trialEndDateNode.closest("span")).querySelector('.dateFormat').style.display = 'none';
                                    let datePickerSpan = document.createElement('span');
                                    datePickerSpan.id = 'datePickerSpan';
                                    let a = document.createElement('a');
                                    a.href = "javascript:DatePicker.insertDate('" + getFormattedDate(trialEndDate) + "', '" + trialEndDateNode.id + "', " + true + ");";
                                    a.innerHTML = "[ " + getFormattedDate(trialEndDate) + " ]";
                                    datePickerSpan.appendChild(a);
                                    trialEndDateNode.parentNode.appendChild(datePickerSpan);
                                }
                                setFieldAsMandatoryRequired('Feature_Update_Reason__c', false);
                                changeDisplayOfFieldUtil('Feature_Update_Reason__c', false);
                            } else {
                                setFieldAsEditable('zqu__QuoteBusinessType__c');
                                setMandatoryOfFieldId('Trial_End_Date__c',false);
                                const businessType = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__QuoteBusinessType__c]'));
                                if(businessType === 'Feature Update'){
                                    changeDisplayOfFieldUtil('Feature_Update_Reason__c', true);
                                    setFieldAsMandatoryRequired('Feature_Update_Reason__c', true);
                                }
                            }
                        }
                    }
                }

                function amendmentNameMaxLength(){
                    var dfn = document.querySelector("[data-field-name='zqu__Amendment_Name__c']");
                    if(!dfn) {
                        return;
                    }
                    var node = dfn.parentNode;
                    var el = node.querySelector('input');
                    if(!el) {
                        return;
                    }
                    el.maxLength = '80';
                    el.value = el.value.substring(0, 80);
                    el.value = el.value.substring(0, el.value.lastIndexOf(' '));
                }

                function initializePackagePicklists(){
                    var legacyOrNewSolution = '{!legacyOrNewSolution}';
                    if (legacyOrNewSolution) {
                        setQuoteFieldNew('Legacy_or_New_solution_deal__c', legacyOrNewSolution);
                    } else if(quoteId){
                        isLoading = true;
                    } else {
                        isLoading = false;
                    }
                }

                function htmlDecode(input) {
                    var doc = new DOMParser().parseFromString(input, "text/html");
                    return doc.documentElement.textContent;
                }

                /**
                 * Function for adding an instuctions field to Amend Proposal Information section
                 * UPDATES: MQ-1324 - Add instruction field before Feature Update Reason Field
                 */
                function reorderProposalInformationSection(){
                    var amendProposaInformation = getQuoteSection('amend_proposal_information');
                    if (!amendProposaInformation) {
                        return;
                    }
                    var quoteBussinessTypeDataArr = getQuoteFieldData('zqu__QuoteBusinessType__c');
                    var tbodyEl;
                    var tbodyTagList = amendProposaInformation.getElementsByTagName('tbody');
                    if (tbodyTagList && tbodyTagList.length > 0) {
                        tbodyEl = tbodyTagList[0];
                    } else {
                        return;
                    }
                    var trLast = document.createElement('tr');
                    var th = document.createElement('th');
                    th.classList.add('labelCol');
                    th.classList.add('vfLabelColTextWrap');
                    var label = document.createElement('label');
                    label.innerHTML = 'Instructions';
                    th.appendChild(label);

                    var td = document.createElement('td');
                    td.classList.add('dataCol');
                    var spanEl = document.createElement('span');
                    spanEl.id = 'businessIntruction';
                    spanEl.classList.add();
                    setInstructionByQuoteBusinessType(spanEl, quoteBussinessTypeDataArr[1].getElementsByTagName('select')[0].value);

                    td.appendChild(spanEl);

                    trLast.appendChild(th);
                    trLast.appendChild(td);

                    let nodeToInsert;
                    let featureUpdateReasonField = document.querySelectorAll('[data-field-name=Feature_Update_Reason__c]');
                    if (featureUpdateReasonField !== undefined && featureUpdateReasonField.length > 0) {
                        nodeToInsert = getQuoteFileNodeNew(featureUpdateReasonField);
                    } else {
                        nodeToInsert = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=Migrating_to_New_Soultion__c]'));
                    }
                    tbodyEl.insertBefore(trLast,nodeToInsert.closest('tr'));
                }

                function setInstructionByQuoteBusinessType(spanEl, businessType){
                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.CreateQuoteAmendPageController.getInstructionForBusinessType}',
                        businessType,
                        function(result, event){
                            if (event.status) {
                                spanEl.innerHTML = htmlDecode(result).replace('<ul>','<ul class="defaultUl">');
                            } else if (event.type === 'exception') {
                            } else {
                            }
                        }
                    );
                }

                function listenQuoteBusinessTypeField(){
                    var quoteBusinessTypeSpanList = document.querySelectorAll('[data-field-name=zqu__QuoteBusinessType__c]');
                    if(quoteBusinessTypeSpanList != undefined &&  quoteBusinessTypeSpanList.length > 0){
                        var selectValue = getQuoteFieldValueNew(quoteBusinessTypeSpanList);
                        setInstruction(selectValue,false);
                        getQuoteFileNodeNew(quoteBusinessTypeSpanList).onchange = function(){
                            selectValue = event.target.value;
                            setInstruction(selectValue,true);
                        };

                        function setInstruction(selectValue,isOnChange){
                            if (selectValue != undefined) {
                                var paymentMethodSpanList = document.querySelectorAll('[data-field-name=zqu__PaymentMethod__c]');
                                var paymentMethodSelectValue = getQuoteFieldValueNew(paymentMethodSpanList);
                                if(paymentMethodSelectValue == 'Other' && selectValue == 'Renewal (with/without upsell)'){
                                    setFieldAsEditable('zqu__PaymentTerm__c');
                                } else {
                                    setFieldAsReadOnly('zqu__PaymentTerm__c');
                                }
                                var spaneEl = document.getElementById('businessIntruction');
                                setInstructionByQuoteBusinessType(spaneEl, selectValue);
                                var paymentMethodValue = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__PaymentMethod__c]'));
                                handleContractEffectiveDateChange(paymentMethodValue, selectValue);
                                changeDisplayOfFieldNew('Trial_Quote__c', selectValue == 'Feature Update');
                                setFieldAsReadOnly('Payment_Type__c');
                                setFieldAsReadOnly('payment_frequency1__c');
                                let specificBillingPeriod = "{!specificBillingPeriod}";
                                setPaymentFrequencyPicklistValueUtil(specificBillingPeriod);
                                if (selectValue == 'Co-Term Upsell + Renewal' || selectValue == 'Feature Update + Renewal (with/without upsell)') {
                                    listenAmendRenewalPaymentFrequencyPicklist();
                                    changeDisplayOfSection('Renewal_Information',true);
                                    changeDisplayOfFieldUtil('Special_Frequency_Reason__c',false,false,true);
                                    var relatedSubscriptionApexDateTimeRaw = '{!subscription.Zuora__NextRenewalDate__c}';
                                    var relatedSubscriptionDate = new Date(relatedSubscriptionApexDateTimeRaw);
                                    if(relatedSubscriptionApexDateTimeRaw && relatedSubscriptionApexDateTimeRaw.length > 0 ){
                                        let amendmentRenewalStartdate = new Date(relatedSubscriptionDate.getTime() + Math.abs(relatedSubscriptionDate.getTimezoneOffset()*60000));
                                        setQuoteFieldNew('Amendment_Renewal_Start_Date__c',getFormattedDate(amendmentRenewalStartdate));
                                    }
                                    var subscriptionTermStartDate = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=Amendment_Renewal_Start_Date__c]'));
                                    var nodeArr = [subscriptionTermStartDate];
                                    setElementsAsReadonly(nodeArr);
                                    (subscriptionTermStartDate.closest("span")).querySelector('.dateFormat').style.display = 'none';
                                    setFieldAsReadOnly('Amendment_Renewal_Payment_Type__c');
                                    setMandatoryOfFieldId('Renewal_Fee__c',true);
                                    setMandatoryOfFieldId('Amendment_Renewal_Start_Date__c',true);
                                    setMandatoryOfFieldId('Amendment_Initial_Term__c',true);
                                    setMandatoryOfFieldId('Amendment_Renewal_Term__c',true);
                                    var paymentTypeSpanList = document.querySelectorAll('[data-field-name=Amendment_Renewal_Payment_Type__c]');
                                    var paymentTypeValue = getQuoteFieldValue(paymentTypeSpanList);
                                    let paymentTerm = "{!paymentTerm}";
                                    populateRenewalPaymentTermUtil(paymentTypeValue,false,paymentTerm);
                                    let paymentFrequencySpanList = getQuoteFieldValue(document.querySelectorAll('[data-field-name=payment_frequency1__c]')); // MQ-1687
                                    setQuoteFieldNew('Amendment_Renewal_Payment_Frequency__c', paymentFrequencySpanList); // MQ-1687
                                } else {
                                    changeDisplayOfSection('Renewal_Information',false);
                                    setQuoteFieldNew('Amendment_Renewal_Start_Date__c','');
                                    setMandatoryOfFieldId('Amendment_Renewal_Start_Date__c',false);
                                    setMandatoryOfFieldId('Amendment_Initial_Term__c',false);
                                    setMandatoryOfFieldId('Amendment_Renewal_Term__c',false);
                                    setMandatoryOfFieldId('Renewal_Fee__c',false);

                                    var subscriptionTermStartDate = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=Amendment_Renewal_Start_Date__c]'));
                                    var nodeArr = [subscriptionTermStartDate];
                                    setElementsAsWriteable(nodeArr);
                                }
                                if (selectValue == 'Renewal (with/without upsell)') {
                                    listenPaymentFrequencyPicklist();
                                    listenPaymentTermPicklist();
                                    var relatedSubscriptionApexDateTimeRaw = '{!subscription.Zuora__NextRenewalDate__c}';
                                    var relatedSubscriptionDate = new Date(relatedSubscriptionApexDateTimeRaw);
                                    if(relatedSubscriptionApexDateTimeRaw && relatedSubscriptionApexDateTimeRaw.length > 0 ){
                                        setQuoteFieldNew('Amendment_Renewal_Start_Date__c',getFormattedDate(relatedSubscriptionDate));
                                    }
                                    setFieldAsEditable('zqu__InitialTerm__c');
                                    setFieldAsEditable('zqu__RenewalTerm__c');
                                    setFieldAsEditable('payment_frequency1__c');
                                    setMandatoryOfFieldId('Renewal_Fee__c',true);
                                    let defaultPaymentMethod = "{!defaultPaymentMethod}";
                                    if(isOnChange){
                                        let termStartDate = "{!termStartDate}";
                                        var relatedSubscriptionDateUnfixed = new Date(termStartDate);
                                        var relatedSubscriptionDate = new Date(relatedSubscriptionDateUnfixed.getTime() + Math.abs(relatedSubscriptionDateUnfixed.getTimezoneOffset()*60000));
                                        let subStartDateSpan = document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]');
                                        if(subStartDateSpan !== undefined && subStartDateSpan.length > 0){
                                            let subStartDateNode = getQuoteFileNodeNew(subStartDateSpan);
                                            javascript:DatePicker.insertDate(subEndDateInitalValue, subStartDateNode.id, true);
                                        }
                                        setQuoteFieldNew('contractEffectiveInput', subEndDateInitalValue,'data-id');
                                        var serviceActivationFieldNode = document.querySelector('[data-id=serviceActivationInput]');
                                        if (serviceActivationFieldNode) {
                                            serviceActivationFieldNode.value = subEndDateInitalValue;
                                        }
                                        var customerAcceptanceFieldNode = document.querySelector('[data-id=customerAcceptanceInput]');
                                        if (customerAcceptanceFieldNode) {
                                            customerAcceptanceFieldNode.value = subEndDateInitalValue;
                                        }
                                    }
                                    changeDisplayOfFieldNew('contractEffectiveInput',false,true,false,'data-id');

                                    var subscriptionTermStartDate = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]'));
                                    var nodeArr = [subscriptionTermStartDate];
                                    setElementsAsReadonly(nodeArr);
                                    (subscriptionTermStartDate.closest("span")).querySelector('.dateFormat').style.display = 'none';
                                    var renewalConfirmationValue = getQuoteFieldValueUtil(document.querySelectorAll('[data-field-name=Renewal_by_client_confirmation__c]'));
                                    onChangeRenewalConfirmationUtil(renewalConfirmationValue);
                                } else {
                                    let initialTerm = "{!initialTerm}";
                                    let renewTerm = "{!renewTerm}";
                                    let paymentTerm = "{!paymentTerm}";
                                    setAmendmentRenewalPaymentTerm();
                                    let defaultPaymentMethod = "{!defaultPaymentMethod}";
                                    /*
                                    10 June 2020 - Vadim
                                    setQuoteFieldNew('zqu__InitialTerm__c',initialTerm);
                                    */
                                    if(renewTerm && renewTerm.length > 0){
                                        setQuoteFieldNew('zqu__RenewalTerm__c',renewTerm);
                                    }
                                    if(paymentMethodValue!=defaultPaymentMethod){
                                        setQuoteFieldNew('zqu__PaymentMethod__c',defaultPaymentMethod);
                                    }
                                    setQuoteFieldNew('zqu__PaymentTerm__c',paymentTerm);
                                    setFieldAsReadOnly('zqu__InitialTerm__c');
                                    setFieldAsReadOnly('zqu__RenewalTerm__c');
                                    setFieldAsReadOnly('zqu__PaymentMethod__c');
                                    setFieldAsReadOnly('payment_frequency1__c');
                                    setFieldAsReadOnly('Payment_Type__c');

                                    let termStartDate = "{!termStartDate}";
                                    var relatedSubscriptionDateUnfixed = new Date(termStartDate);
                                    var relatedSubscriptionDate = new Date(relatedSubscriptionDateUnfixed.getTime() + Math.abs(relatedSubscriptionDateUnfixed.getTimezoneOffset()*60000));
                                    changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                                    if (selectValue && termStartDate && (!quoteId || isOnChange)) {
                                        let subStartDateNode = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]'));
                                        if(subStartDateNode != undefined && subStartDateNode.length > 0){
                                            javascript:DatePicker.insertDate(getFormattedDate(relatedSubscriptionDate), subStartDateNode.id, true);
                                        }
                                    }
                                    let amendPaymentMethodSpanList = document.querySelectorAll('[data-field-name=Amendment_Renewal_Payment_Method__c]');
                                    let amendPaymentMethodSelectValue = getQuoteFieldValueNew(amendPaymentMethodSpanList);
                                    reorderRenewalSectionByAmendRenewalPaymentMethod(amendPaymentMethodSelectValue);

                                    var subscriptionTermStartDate = getQuoteFileNodeNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]'));
                                    var nodeArr = [subscriptionTermStartDate];
                                    setElementsAsWriteable(nodeArr);
                                }
                                if(selectValue == 'Feature Update'){
                                    changeDisplayOfFieldUtil('Feature_Update_Reason__c', true);
                                    setFieldAsMandatoryRequired('Feature_Update_Reason__c', true);

                                } else {
                                    setFieldAsMandatoryRequired('Feature_Update_Reason__c', false);
                                    changeDisplayOfFieldUtil('Feature_Update_Reason__c', false);
                                }

                                paymentMethodValue = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__PaymentMethod__c]'));
                                changeDisplayOfFieldNew('Renewal_Fee__c',selectValue == 'Renewal (with/without upsell)' || selectValue == 'Co-Term Upsell + Renewal' || selectValue == 'Feature Update + Renewal (with/without upsell)');
                                changeDisplayOfFieldNew('Percentage_New_Term_Total__c',selectValue == 'Renewal (with/without upsell)' || selectValue == 'Co-Term Upsell + Renewal' || selectValue == 'Feature Update + Renewal (with/without upsell)');
                                changeDisplayOfFieldNew('Current_Contract_TCV__c',selectValue == 'Renewal (with/without upsell)' || selectValue == 'Co-Term Upsell + Renewal' || selectValue == 'Feature Update + Renewal (with/without upsell)',true);
                                setFieldAsReadOnly('Current_Contract_TCV__c');

                                const CO_TERM_UPSELL_RENEWAL = 'Co-Term Upsell + Renewal';
                                const FEATURE_UPDATE_RENEWAL = 'Feature Update + Renewal (with/without upsell)';
                                const RENEWAL = 'Renewal (with/without upsell)';

                                const isCoTermRenewal = (selectValue == CO_TERM_UPSELL_RENEWAL);
                                const isFeatureRenewal = (selectValue == FEATURE_UPDATE_RENEWAL);
                                const isRenewal = (selectValue == RENEWAL);
                                const isRenewalDuplicationLayout = isCoTermRenewal || isFeatureRenewal || isRenewal;
                                if(isRenewalDuplicationLayout){
                                    changeDisplayOfFieldNew('Customer_requests_to_pay_immediately__c',true);
                                } else {
                                    changeDisplayOfFieldNew('Customer_requests_to_pay_immediately__c',false);
                                }

                                const initialTerm = "{!initialTerm}";
                                const amendmentRenewalPaymentFrequency = "{!amendmentRenewalPaymentFrequency}";
                                const paymentType = "{!paymentType}";
                                setFeatureCoTermRenewalFieldsEditableUtil(selectValue, initialTerm, amendmentRenewalPaymentFrequency, paymentType);
                                setStraightRenewalFieldsEditableUtil(selectValue, amendmentRenewalPaymentFrequency, paymentType);

                                if(isRenewal){
                                    checkPaymentMethod();
                                }
                                setCustomerRequestToPayImmediatelyCheckbox();
                                let relatedStartDateTimeRaw = '{!relatedStartDate}';
                                if(relatedStartDateTimeRaw){
                                    let relatedStartDate = new Date(relatedStartDateTimeRaw);
                                    var relatedStartDateTimeZone = new Date(relatedStartDate.getTime() + Math.abs(relatedStartDate.getTimezoneOffset()*60000));
                                    setQuoteFieldNewUtil('contractEffectiveInput', getFormattedDate(relatedStartDateTimeZone),'data-id');
                                    setQuoteFieldNewUtil('customerAcceptanceInput', getFormattedDate(relatedStartDateTimeZone),'data-id');
                                    setQuoteFieldNewUtil('serviceActivationInput', getFormattedDate(relatedStartDateTimeZone),'data-id');
                                }
                                displayOrNotRenewalConfirmationUtil(true, null);
                                var isRenewalByClientConfirmation = getQuoteFieldValueUtil(document.querySelectorAll('[data-field-name=Renewal_by_client_confirmation__c]'));
