                                let gapriseIncAccName="{!gapriseIncAccName}";
                                if (gapriseIncAccId && gapriseIncAccName) {
                                    var inputIdArr = invoiceOwnerNode.querySelectorAll('input[id*=targetId]');
                                    if (inputIdArr) {
