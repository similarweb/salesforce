                function setFieldAsRequired(spanElement, fieldTag){
                    var parent = spanElement.parentNode;
                    var requiredInputArr = spanElement.parentNode.querySelectorAll('div.requiredInput');
                    if (!requiredInputArr || requiredInputArr.length < 1) {
                        if(fieldTag == 'textarea'){
                            var inputNodeArr = spanElement.parentNode.getElementsByTagName('textarea');
                        } else {
                            var inputNodeArr = spanElement.parentNode.getElementsByTagName('input');
                        }

                        if (!inputNodeArr || inputNodeArr.length < 1) {
                            return;
                        }
                        var inputNode = inputNodeArr[0];
                        parent.removeChild(inputNode);
                        var requiredInput = document.createElement("div");
                        requiredInput.classList.add('requiredInput');
                        var requiredBlock = document.createElement("div");
                        requiredBlock.classList.add('requiredBlock');
                        requiredInput.appendChild(requiredBlock);
                        requiredInput.appendChild(inputNode);
                        parent.appendChild(requiredInput);
                    }
                }

                function setPicklistAsRequired(spanElement){
                    var parent = spanElement.parentNode;
                    var requiredPicklistArr = spanElement.parentNode.querySelectorAll('div.requiredInput');
                    if (!requiredPicklistArr || requiredPicklistArr.length < 1) {
                        var picklistNodeArr = spanElement.parentNode.getElementsByTagName('select');
                        if (!picklistNodeArr || picklistNodeArr.length < 1) {
                            return;
                        }
                        var picklistNode = picklistNodeArr[0];
                        parent.removeChild(picklistNode);
                        var requiredPicklist = document.createElement("div");
                        requiredPicklist.classList.add('requiredInput');
                        var requiredBlock = document.createElement("div");
                        requiredBlock.classList.add('requiredBlock');
                        requiredPicklist.appendChild(requiredBlock);
                        requiredPicklist.appendChild(picklistNode);
                        parent.appendChild(requiredPicklist);
                    }
                }

                function setFieldDatasetMode(spanElement, mode){
                    var parent = spanElement.parentNode;
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    inputNode.dataset.mode = mode;
                }

                function setFieldAsNotRequired(spanElement, fieldTag){
                    var parent = spanElement.parentNode;
                    var requiredInputArr = parent.getElementsByTagName('div');
                    if (!requiredInputArr || requiredInputArr.length < 1) {
                        return;
                    }
                    requiredInputArr[0].classList.remove('requiredInput');

                    var requiredInput = requiredInputArr[0];

                    if(fieldTag == 'textarea'){
                        var inputNodeArr = requiredInput.getElementsByTagName('textarea');
                    } else {
                        var inputNodeArr = requiredInput.getElementsByTagName('input');
                    }
                    if (!inputNodeArr || inputNodeArr.length < 1) {
                        return;
                    }
                    var inputNode = inputNodeArr[0];
                    parent.appendChild(inputNode.cloneNode());
                    parent.removeChild(requiredInput);
                }

                function setPicklistAsNotRequired(spanElement){
                    var parent = spanElement.parentNode;
                    var requiredPicklistArr = parent.getElementsByTagName('div');
                    if (!requiredPicklistArr || requiredPicklistArr.length < 1) {
                        return;
                    }
                    requiredPicklistArr[0].classList.remove('requiredPicklist');

                    var requiredPicklist = requiredPicklistArr[0];

                    var picklistNodeArr = requiredPicklist.getElementsByTagName('select');
                    if (!picklistNodeArr || picklistNodeArr.length < 1) {
                        return;
                    }
                    var picklistNode = picklistNodeArr[0];
                    parent.appendChild(picklistNode.cloneNode(true));
                    parent.removeChild(requiredPicklist);
                }

