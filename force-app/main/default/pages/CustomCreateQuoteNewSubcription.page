                                }
                                var inputNameArr = invoiceOwnerNode.querySelectorAll('input[id*=targetName]');
                                if (inputNameArr) {
                                    inputNameArr[0].value='';
                                }
                                var inputNameDisplayArr = invoiceOwnerNode.querySelectorAll('input[id*=targetNameDisplay]');
                                if (inputNameDisplayArr) {
                                    inputNameDisplayArr[0].value='';
                                }
                            }
                        }
                    }
                }

