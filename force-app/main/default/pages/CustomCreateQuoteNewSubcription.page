                function newSolutionUseCaseObserver (){
                    var elem;
                    for (const span_i of document.querySelector("[data-field-name=New_solution_use_case__c]").parentNode.getElementsByTagName('span')) {
                        if (!span_i.dataset.elem) {
                            elem = span_i;
                            break;
                        }
                    }
                    if (!elem) {
                        return;
                    }
                    var observer = new MutationObserver(callback)
                        .observe(elem, {childList : true});

                    function callback(mutations, observer) {
                        var target = mutations[0].target;
                        mutations.forEach(function(mutation) {
                            renamePicklistValue(getRequiredQuoteFileNode(document.querySelectorAll("[data-field-name=New_solution_use_case__c]")),'--none--','Please Select');
                            getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=New_solution_use_case__c]")).classList.add('PICKLIST');
                            getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=New_solution_use_case__c]")).classList.add('slds-input');
                            changeSizeOfSpecificInputFields();
                            let isSalesOpsEnabled = "{!isSalesOpsEnabled}";
                            if(isSalesOpsEnabled == "false"){
                                removePicklistValue(document.querySelector("[data-field-name=New_solution_use_case__c]").parentNode.querySelector("select"),'Research AI');
                                removePicklistValue(document.querySelector("[data-field-name=New_solution_use_case__c]").parentNode.querySelector("select"),'Digital Suite');
                                removePicklistValue(document.querySelector("[data-field-name=New_solution_use_case__c]").parentNode.querySelector("select"),'Digital Marketing');
                            }
                        });
                    }
                }

