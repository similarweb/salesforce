                            if (!taxCountriesWithNoValidation.includes(certificateIdNode.dataset.country)) {
                                if (selectValue) {
                                    validateCertificateId(selectValue,soldToIdInputElement.value,event.target);
                                } else {
                                    clearMessage();
                                }
                            }
                        };

                        function getCertificateIdNode(certificateIdSpanList){
                            var parent = certificateIdSpanList[0].parentNode;
                            var inputNode;
                            for (const node_i of parent.childNodes) {
                                if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                                    inputNode = node_i;
                                }
                            }
                            if (!inputNode) {
                                return;
                            } else {
                                return inputNode
                            }
                        }
                    }
                }

