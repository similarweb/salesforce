                function setAccessibleCurrencies(subsidiary){
                    isDefaultCurrencySet = true;
                    var currencyList = getQuoteFileNodeNew(document.querySelectorAll('[data-id=customRenderedCurrency]'));
                    var currenciesList = JSON.parse('{!currenciesList}');
                    var quoteCurrencies = JSON.parse('{!quoteCurrencies}');
                    for(let curr of currenciesList){
                        let showTheOption = false;
                        let currentQuoteCurrency = quoteCurrencies[subsidiary];
                        if(currentQuoteCurrency && currentQuoteCurrency.Applicable_Currencies__c.includes(curr)){
                            showTheOption = true;
                        }
                        changePicklistOptionVisibility(currencyList,curr,showTheOption);
                        if(currencyList != undefined && currencyList != null && currentQuoteCurrency){
                            if(currentQuoteCurrency.Default_Currency__c == curr){
                                currencyList.value = curr;
                            }
                        }
                    }
