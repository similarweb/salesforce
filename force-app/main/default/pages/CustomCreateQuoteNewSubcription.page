                function handleCertificateIdSwitch(){
                    const multiSubSpanList = document.querySelectorAll('[data-field-name=MultiSubscription__c]');
                    const trialSpanList = document.querySelectorAll('[data-field-name=Trial_Quote__c]');
                    let isTrailChecked;
