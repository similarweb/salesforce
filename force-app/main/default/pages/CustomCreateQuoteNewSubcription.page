                onClickNextButton(nextButtonClickEdit, undefined, undefined, true);
                onClickCancelButton();

                function nextButtonClickEdit() {
                    let shouldContinue = false;
                    let soldToLabelElement = findElementByContainingPharse('label', 'text()', 'Admin User');
                    let soldToIdInputElementId = getSoldToIdInputFromLabelElement(soldToLabelElement);
                    let soldToId = soldToIdInputElementId.value;  

                    let certificateId;
                    let certificateIdSpanList = document.querySelectorAll('[data-field-name=zqu__Certificate_ID__c]');
                    if (certificateIdSpanList && certificateIdSpanList.length > 0) {
                        certificateId = getQuoteFieldValueNew(certificateIdSpanList);
                        certificateId = certificateId && certificateId.trim() === '' ? undefined : certificateId;
                    }
                    
                    let customerType;
                    let customerTypeSpanList = document.querySelectorAll('[data-field-name=Customer_Type__c]');
                    if (customerTypeSpanList && customerTypeSpanList.length > 0) {
                        customerType = getQuoteFieldValueNew(customerTypeSpanList);
                    }
                    if (validateCertificateIdForIndia(soldToId, customerType, certificateId)) {
                        shouldContinue = true;
                    }
                    if (shouldContinue) {
                        nextButtonClick();
                    }
                }

                function validateCertificateIdForIndia(soldToId, customerType, certificateId, certificateIdSpanList) {

                    if (soldToId && customerType === 'Company' && !certificateId) {
                        Visualforce.remoting.Manager.invokeAction(
                            '{!$RemoteAction.CreateQuotePageController.checkSoldToCountry}',
                            soldToId,
                            getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=package__c]")).value,
                            function(result, event) {
                                if (event.status) {
                                    let countryName = result ? result.soldToContactCountry : null;
                                    if (countryName === 'India') {
                                        displayErrorMessage(['If VAT Id is selected as yes, Please fill in certificate ID']);
                                        return false;
                                    }
                                }
                                return true;
                            },
                            { escape: false }
                        );
                    }
                    else {
                        return true;
                    }
                }

                function setFieldDatasetCountry(spanElement, country){
                    var parent = spanElement.parentNode;
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    inputNode.dataset.country = country;
                }

                function populateBillToFromParentAccount(parentAccountName){
                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.CreateQuotePageController.getBillToFromParentAccountName}',
                        parentAccountName,
                        function(result , event){
                            if(event.status && result){
                                let billToContactId = result.billToContactId ? result.billToContactId : '';
                                let billToContactName = result.billToContact ? result.billToContact : '';
                                var billToLabelElement = findElementByContainingPharse('label', 'text()', 'Bill to Contact');
                                var billToIdInputElementDisplay = getSoldToIdInputFromLabelElement(billToLabelElement,'targetNameDisplay');
                                var billToIdInputElementId = getSoldToIdInputFromLabelElement(billToLabelElement);
                                billToIdInputElementId.value = billToContactId;
                                // billToIdInputElementDisplay.disabled = fromMultiSub ? true : false;
                                billToIdInputElementDisplay.value = billToContactName;

                            }else {
                                console.log('exception on server');
                            }
                        });
                }
                function populateLookups(parentBiilingAccountId,fromMultiSub){
                    let currentBillingAccountId = "{!$CurrentPage.parameters.billingAccountId}";
                    let parentOrCurrentBillingAccount = currentBillingAccountId != undefined && currentBillingAccountId != null && currentBillingAccountId != '' ? currentBillingAccountId : parentBiilingAccountId != undefined && parentBiilingAccountId != null && parentBiilingAccountId != '' ? parentBiilingAccountId : null;
                    if(parentOrCurrentBillingAccount){
                        Visualforce.remoting.Manager.invokeAction(
                            '{!$RemoteAction.CreateQuotePageController.getSoldToAndBillToByEmail}',
                            parentOrCurrentBillingAccount,
                            function(result, event){
                                if (event.status && result) {
                                    let soldToContactId = result.soldToContactId ? result.soldToContactId : '';
                                    let soldToContactName = result.soldToContact ? result.soldToContact : '';
                                    let billToContactId = result.billToContactId ? result.billToContactId : '';
                                    let billToContactName = result.billToContact ? result.billToContact : '';

                                    var soldToLabelElement = findElementByContainingPharse('label', 'text()', 'Admin User');
                                    var soldToIdInputElementDisplay = getSoldToIdInputFromLabelElement(soldToLabelElement,'targetNameDisplay');
                                    var soldToIdInputElementId = getSoldToIdInputFromLabelElement(soldToLabelElement);
                                    var billToLabelElement = findElementByContainingPharse('label', 'text()', 'Bill to Contact');
                                    var billToIdInputElementDisplay = getSoldToIdInputFromLabelElement(billToLabelElement,'targetNameDisplay');
                                    var billToIdInputElementId = getSoldToIdInputFromLabelElement(billToLabelElement);
                                    soldToIdInputElementId.value = fromMultiSub ? soldToIdInputElementId.value : soldToContactId;
                                    soldToIdInputElementDisplay.value = fromMultiSub ? soldToIdInputElementDisplay.value : soldToContactName;
                                    billToIdInputElementId.value = billToContactId;
                                    billToIdInputElementDisplay.disabled = fromMultiSub ? true : false;
                                    billToIdInputElementDisplay.value = billToContactName;


                                } else {
                                    console.log('exception on server');
                                }
                            }
                        );
                    }
                }
