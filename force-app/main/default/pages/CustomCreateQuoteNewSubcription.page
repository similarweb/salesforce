                        certificateIdNode.onchange = function(){
                            if (event.target.dataset.mode != 'certificateId') {
                                return;
                            }
                            selectValue = event.target.value;
                            var soldToLabelElement = findElementByContainingPharse('label', 'text()', 'Admin User');
                            var soldToIdInputElement = getSoldToIdInputFromLabelElement(soldToLabelElement);
                            if (!soldToIdInputElement) {
                                return;
