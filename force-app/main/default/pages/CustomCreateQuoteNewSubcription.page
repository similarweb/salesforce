                                    }
                                    var inputNameDisplayArr = invoiceOwnerNode.querySelectorAll('input[id*=targetNameDisplay]');
                                    if (inputNameDisplayArr) {
                                        inputNameDisplayArr[0].value=gapriseIncAccName;
                                    }
                                }
                            }

                        } else if(prosusAccId){
                            if (invoiceOwnerNode) {
                                invoiceOwnerNode.style.display='none';
                                if (prosusAccId && prosusAccName) {
                                    var inputIdArr = invoiceOwnerNode.querySelectorAll('input[id*=targetId]');
                                    if (inputIdArr) {
                                        inputIdArr[0].value=prosusAccId;
                                    }
                                    var inputNameArr = invoiceOwnerNode.querySelectorAll('input[id*=targetName]');
                                    if (inputNameArr) {
