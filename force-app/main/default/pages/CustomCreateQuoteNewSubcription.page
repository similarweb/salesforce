                function listenCompanyLegalName() {
                    const observer = new MutationObserver((mutationsList, observer) => {
                        // Iterate over each mutation that was observed
                        for (const mutation of mutationsList) {
                            // Check if new nodes have been added
                            if (mutation.type === 'childList') {
                                // Try to select the span element first
                                const spanElement = document.querySelector('span[data-field-name="Company_Legal_Name__c"]');
                                console.log('Span Element:', spanElement); // Debugging log to check the span element

                                // If the span element is found
                                if (spanElement) {
                                    // Navigate to the parent <td> and then find the input within it
                                    const parentTd = spanElement.closest('td.data2Col');
                                    console.log('Parent TD:', parentTd); // Debugging log to check the parent TD element

                                    if (parentTd) {
                                        const inputElement = parentTd.querySelector('input.STRING.slds-input');
                                        console.log('Input Element:', inputElement); // Debugging log to check the input element

                                        if (inputElement) {
                                            // Add the event listener to the input element
                                            inputElement.addEventListener('input', function(event) {
                                                console.log('Input value changed to:', event.target.value);
                                                changeBillingCompanyName(event.target.value);
                                            });
                                            // Stop observing since the element is now present and the listener is added
                                            observer.disconnect();
                                        }
                                    }
                                }
                            }
                        }
                    });

                    // Start observing the document's body for changes in the DOM
                    observer.observe(document.body, {
                        childList: true, // Observe direct children
                        subtree: true   // Observe all descendants as well
                    });
                }
