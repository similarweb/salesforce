                        isTrailChecked = trialSpanList[0].parentNode.childNodes[0].checked;
                    }
                    let isMultiChecked;
                    if(multiSubSpanList && multiSubSpanList.length > 0){
                        multiSubSpanList[0].parentNode.childNodes[0].checked = isTrailChecked != null && isTrailChecked != undefined && isTrailChecked ? false :  multiSubSpanList[0].parentNode.childNodes[0].checked;
                        isMultiChecked = multiSubSpanList[0].parentNode.childNodes[0].checked;
                    }
                    let showFields = isTrailChecked != null && isTrailChecked != undefined ? !isTrailChecked && !isMultiChecked : !isMultiChecked;
                    changeDisplayOfFieldNew('zqu__Certificate_ID__c',showFields,true);
                    changeDisplayOfFieldNew('Customer_Type__c',showFields,true);
                    changeDisplayOfFieldNew('Company_Vat_ID__c',showFields,true);
                    changeDisplayOfFieldNew('Company_Legal_Name__c',showFields,true);
                    setMandatoryOfFieldId('Company_Legal_Name__c', showFields);
                }
