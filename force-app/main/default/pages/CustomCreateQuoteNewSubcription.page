                function setQuoteField(fieldName, fieldValue){
                    var spanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                    if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].childNodes.length == 1 && spanList[0].parentNode.childNodes[0].childNodes[0].nodeType == 3) {
                        return;
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].classList.contains('dateOnlyInput')) {
                        spanList[0].parentNode.childNodes[0].childNodes[0].value = fieldValue;
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'input' && spanList[0].parentNode.childNodes[0].type == 'checkbox') {
                        if(fieldValue){
                            spanList[0].parentNode.childNodes[0].setAttribute('checked',undefined);
                        } else {
                            spanList[0].parentNode.childNodes[0].removeAttribute('checked');
                        }
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'select') {
                        spanList[0].parentNode.childNodes[0].value = fieldValue;
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].childNodes[0].tagName.toLowerCase() == 'select') {
                        spanList[0].parentNode.childNodes[0].childNodes[0].value = fieldValue;
                    } else {
                        var inputNode;
                        for (const child_i of spanList[0].parentNode.childNodes) {
                            if (child_i.tagName && child_i.tagName.toLowerCase() == 'input') {
                                inputNode = child_i;
                                break;
                            }
                        }
                        if (inputNode) {
                            inputNode.value = fieldValue;
                        }
                    }
                }

                function setQuoteFieldNew(fieldName, fieldValue, tagName){
                    var spanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                    if (!spanList || spanList.length < 1) {
                        return;
                    }
                    var parent = spanList[0].parentNode;
                    var selectElArr = parent.getElementsByTagName('select');
                    if (selectElArr && selectElArr.length > 0) {
                        var selectEl = selectElArr[0];
                        selectEl.value = fieldValue;
                        selectEl.dispatchEvent(new Event('change'));
                    } else {
                        if(tagName == 'textarea'){
                            selectElArr = parent.getElementsByTagName('textarea');
                        } else {
                            selectElArr = parent.getElementsByTagName('input');
                        }
                        if (selectElArr && selectElArr.length > 0) {
                            var selectEl = selectElArr[0];
                            if (selectEl.type == 'checkbox') {
                                selectEl.checked = fieldValue;
                            } else {
                                selectEl.value = fieldValue;
                            }
                        }
                    }
                }

                function getFormattedDate(date) {
                    let year = date.getFullYear();
                    let month = (1 + date.getMonth()).toString().padStart(2, '0');
                    let day = date.getDate().toString().padStart(2, '0');

                    return month + '/' + day + '/' + year;
                }

                function changeDisplayOfField(dataFieldNameString , isDisplayed, saveValue,hidePartially){
                    var spanList = document.querySelectorAll('[data-field-name='+ dataFieldNameString + ']');
                    if(spanList != undefined &&  spanList.length > 0){
                        var selectedSpan = spanList[0];
                        var childList = selectedSpan.parentNode.childNodes;
                    }
                    if(isDisplayed){
                        if(childList != undefined &&  childList.length > 0){
                            childList[0].style.display='inline-block';
                            var tdNode = selectedSpan.parentNode;
                            var trNode = tdNode.parentNode;
                            var indexOfTdNode = Array.from(trNode.childNodes).indexOf(tdNode);
                            if (indexOfTdNode > 0) {
                                var indexOfThNode = indexOfTdNode - 1;
                                if (!hidePartially) {
                                    trNode.childNodes[indexOfTdNode].style.display='';
                                    trNode.childNodes[indexOfThNode].style.display='';
                                } else {
                                    trNode.childNodes[indexOfThNode].childNodes[0].style.display='';
                                }
                            }
                        }
                    }
                    else {
                        if(childList != undefined &&  childList.length > 0){
                            if (!saveValue) {
                                if (childList[0].tagName.toLowerCase() == 'span' && childList[0].classList.contains('dateOnlyInput')) {
                                    childList[0].childNodes[0].value = '';
                                } else if (childList[0].tagName.toLowerCase() == 'input' && childList[0].type == 'checkbox') {
                                    childList[0].removeAttribute('checked');
                                } else  {
                                    childList[0].value='';
                                }
                            }
                            childList[0].style.display='none';
                            var tdNode = selectedSpan.parentNode;
                            var trNode = tdNode.parentNode;
                            var indexOfTdNode = Array.from(trNode.childNodes).indexOf(tdNode);
                            if (indexOfTdNode > 0) {
                                var indexOfThNode = indexOfTdNode - 1;
                                if (!hidePartially) {
                                    trNode.childNodes[indexOfTdNode].style.display='none';
                                    trNode.childNodes[indexOfThNode].style.display='none';
                                } else {
                                    trNode.childNodes[indexOfThNode].childNodes[0].style.display='none';
                                }
                            }
                        }
                    }
                }

