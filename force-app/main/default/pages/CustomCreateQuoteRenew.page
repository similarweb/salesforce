                function changeDisableOfField(dataFieldNameString , isDisplayed){
                    var spanList = document.querySelectorAll('[data-field-name='+ dataFieldNameString + ']');
                    if(spanList != undefined &&  spanList.length > 0){
                        var selectedSpan = spanList[0];
                        var childList = selectedSpan.parentNode.childNodes;
                    }
                    if(isDisplayed){
                        if(childList != undefined &&  childList.length > 0){
                            childList[0].disabled=false;
                        }
                    }
                    else {
                        if(childList != undefined &&  childList.length > 0){
                            childList[0].disabled=true;
                        }
                    }
                }

                function changeDisplayOfSection(dataSectionNameString , isDisplayed){
                    /* sectionSpanList = document.querySelectorAll('[data-section-name='+ dataSectionNameString + ']');
                    if (sectionSpanList!= undefined && sectionSpanList.length > 0) {
                        var sectionDivEl = sectionSpanList[0];
                        if (!sectionDivEl) {
                            return;
                        }
                        var sectionBeforeBufferEl = getSectionBeforeBuffer(sectionDivEl);
                        if (isDisplayed) {
                            sectionDivEl.style.display = 'inherit';
                            sectionBeforeBufferEl.style.display = 'inherit';
                        } else {
                            sectionDivEl.style.display = 'none';
                            sectionBeforeBufferEl.style.display = 'none';
                        }
                    } */
                }

                function getSectionBeforeBuffer(sectionDiv){
                    var sectionDivParent = sectionDiv.parentNode;
                    var indexOfSectionBeforeBuffer = Array.from(sectionDivParent.childNodes).indexOf(sectionDiv) - 1;
                    var sectionBeforeBuffer = sectionDivParent.childNodes[indexOfSectionBeforeBuffer];
                    return sectionBeforeBuffer;
                }

                function findElementByContainingPharse(tagName, targetOfSearch, phraseToSearch){
                    var xpath = "//" + tagName + "[contains(" + targetOfSearch +",'"+ phraseToSearch +"')]";
                    var matchingElement = document.evaluate(xpath, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
                    return matchingElement;
                }

                function hideBaseProductPicklist(){
                    var baseProductSpanList = document.querySelectorAll('[data-field-name=Base_Product_Test__c]');
                    if(baseProductSpanList != undefined &&  baseProductSpanList.length > 0){
                        changeDisplayOfField('Base_Product_Test__c',false);
                    }
                }

                function hideCustomerTypePicklist(){
                    changeDisplayOfField('Customer_Type__c',false,true);
                }

                function addHelpTextToLookups(){
                    addHelpTextToLookup('Bill to Contact', 'zqu__BillToContact__c');
                    addHelpTextToLookup('Admin User', 'zqu__SoldToContact__c');

                    function addHelpTextToLookup(lookupLabel,fieldName) {
                        var lookupLabelElement = findElementByContainingPharse('label', 'text()',lookupLabel);
                        Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.CreateQuotePageController.getHelpText}', 
                        fieldName,
                            function(result, event){
                                if (event.status) {
                                    var parentEl = lookupLabelElement.parentNode;
                                    parentEl.removeChild(lookupLabelElement);
                                    var spanEl = document.createElement('span');
                                    spanEl.classList.add('helpButton');
                                    spanEl.id = fieldName + '-_help';
                                    spanEl.appendChild(lookupLabelElement);

                                    var imgEl = document.createElement('img');
                                    var orgUrl = '{!orgUrl}';
                                    imgEl.src = orgUrl + '/img/s.gif';
                                    imgEl.classList.add('helpOrb');
                                    spanEl.appendChild(imgEl);

                                    var scriptEl = document.createElement('script');
                                    scriptEl.innerHTML = 'sfdcPage.setHelp("' + fieldName + '", "' + result + '");';
                                    spanEl.appendChild(scriptEl);
                                    parentEl.appendChild(spanEl);
                                } else if (event.type === 'exception') {
                                    /* document.getElementById("responseErrors").innerHTML = 
                                        event.message + "<br/>\n<pre>" + event.where + "</pre>"; */
                                } else {
                                    /* document.getElementById("responseErrors").innerHTML = event.message; */
                                }
                            }
                        );
                    }
                }

                function setMandatoryOfCertificateId(isMandatory){
                    var certificateIdSpanList = document.querySelectorAll('[data-field-name=zqu__Certificate_ID__c]');
                    if(certificateIdSpanList != undefined && certificateIdSpanList.length > 0){
                        var certificateIdSelectEl = certificateIdSpanList[0];
                        if (isMandatory) {
                            setFieldAsRequired(certificateIdSelectEl);
                            setNameOfInputElementInSessionStorage(certificateIdSelectEl);
                        } else {
                            setFieldAsNotRequired(certificateIdSelectEl);
                            storeNameOfInputElementInSessionStorage(certificateIdSelectEl);
                            clearNameOfInputElement(certificateIdSelectEl);
                        }
                    }
                }

                function setQuoteCurrencyUsdOnly (isUsdOnly){
                    var currencySpanList = document.querySelectorAll('[data-id=customRenderedCurrency]');
                    if(currencySpanList != undefined &&  currencySpanList.length > 0){
                        var currencySelectEl;
                        for (const currencySpanChld of currencySpanList[0].childNodes) {
                            if(currencySpanChld.tagName.toLowerCase() == 'select'){
                                currencySelectEl = currencySpanChld;
                                break;
                            }
                        }
                        if (currencySelectEl) {
                            for (const option_i of currencySelectEl.childNodes) {
                                if (!option_i.tagName || option_i.tagName.toLowerCase() != 'option') {
                                    continue;
                                }
                                var value = option_i.value;
                                if (value == 'USD') {
                                    continue;
                                }
                                if (!value || isUsdOnly) {
                                    option_i.style.display = 'none';
                                } else {
                                    option_i.style.display = 'inherit';
                                }
                            }
                        }
                    }
                }

                function setQuoteCurrencyDisability(isDisable){
                    var currencySpanList = document.querySelectorAll('[data-id=customRenderedCurrency]');
                    if(currencySpanList != undefined &&  currencySpanList.length > 0){
                        var currencySelectEl;
                        for (const currencySpanChld of currencySpanList[0].childNodes) {
                            if(currencySpanChld.tagName.toLowerCase() == 'select'){
                                currencySelectEl = currencySpanChld;
                                break;
                            }
                        }
                        if (currencySelectEl) {
                            if (isDisable) {
                                currencySelectEl.disabled=true;
                            } else {
                                currencySelectEl.disabled="";
                            }
                        }
                    }
                }

                function setFieldAsRequired(spanElement){
                    var parent = spanElement.parentNode;
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    parent.removeChild(inputNode);
                    var requiredInput = document.createElement("div");
                    requiredInput.classList.add('requiredInput');
                    var requiredBlock = document.createElement("div");
                    requiredBlock.classList.add('requiredBlock');
                    requiredInput.appendChild(requiredBlock);
                    requiredInput.appendChild(inputNode);
                    parent.appendChild(requiredInput);
                }

                function setFieldDatasetMode(spanElement, mode){
                    var parent = spanElement.parentNode;
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    inputNode.dataset.mode = mode;
                }

                function setFieldAsNotRequired(spanElement){
                    var parent = spanElement.parentNode;
                    var requiredInput;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'div') {
                            requiredInput = node_i;
                        }
                    }
                    if (!requiredInput) {
                        return;
                    }
                    var inputNode;
                    for (const node_i of requiredInput.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    parent.removeChild(requiredInput);
                    parent.appendChild(inputNode);
                }

                function setQuoteFieldLabel(node, labelToSet){
                    var parentTrNode = node.parentNode.parentNode;
                    var indexOfValueTd = Array.from(parentTrNode.childNodes).indexOf(node.parentNode);
                    var labelNode = parentTrNode.childNodes[indexOfValueTd - 1].childNodes[0];
                    labelNode.innerText = labelToSet;
                }

                function setSpanDatasetFieldname(node, fieldNameToSet){
                    node.dataset.fieldName = fieldNameToSet;
                }

                function storeNameOfInputElementInSessionStorage(spanElement){
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    if (inputNode.tagName.toLowerCase() == 'div') {
                        inputNode = inputNode.childNodes[1];
                    }
                    sessionStorage.setItem("nameOfCertificateIfInput", inputNode.name);
                }

                function clearNameOfInputElement(spanElement){
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    if (inputNode.tagName.toLowerCase() == 'div') {
                        inputNode = inputNode.childNodes[1];
                    }
                    inputNode.name = "";
                }

                function setNameOfInputElementInSessionStorage(spanElement){
                    var inputNode;
                    for (const node_i of spanElement.parentNode.childNodes) {
                        if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                            inputNode = node_i;
                        }
                    }
                    if (!inputNode) {
                        return;
                    }
                    if (inputNode.tagName.toLowerCase() == 'div') {
                        inputNode = inputNode.childNodes[1];
                    }
                    inputNode.name = sessionStorage.getItem("nameOfCertificateIfInput");
                }

                function getSoldToIdInputFromLabelElement(soldToLabelElement){
                    var parentTrNode = soldToLabelElement.parentNode.parentNode;
                    if (!parentTrNode) {
                        return '';
                    }
                    var indexOfLabel = Array.from(parentTrNode.childNodes).indexOf(soldToLabelElement.parentNode);
                    if (indexOfLabel < 0) {
                        return '';
                    }
                    var soldToNode = parentTrNode.childNodes[indexOfLabel + 1];
                    if (!soldToNode) {
                        return '';
                    }
                    var soldToNodeDivEl = soldToNode.querySelector('div[id]');
                    if (!soldToNodeDivEl) {
                        return;
                    }
                    var idInput = soldToNodeDivEl.querySelector('[id*="targetId"]');
                    return idInput;
                }

                function showMessage(el, mode, message){
                    var messageContainer = document.getElementById('certificateIdValidationMessage');
                    if (!messageContainer) {
                        var messageContainer = document.createElement("div");
                        messageContainer.id = 'certificateIdValidationMessage'
                    }
                    messageContainer.innerHTML = message;
                    if (mode == 'success') {
                        messageContainer.setAttribute('style', 'color:green !important');
                    } else if(mode == 'warning') {
                        messageContainer.setAttribute('style', 'color:red !important');
                    }
                    var elParent = el.parentNode;
                    var indexOfEl = Array.from(elParent.childNodes).indexOf(el); 
                    elParent.insertBefore(messageContainer,el);
                }

                function clearMessage(){
                    var messageContainer = document.getElementById('certificateIdValidationMessage');
                    if (messageContainer) {
                        messageContainer.remove();
                    }
                }

                function removePicklistValue(picklistNode,valueApiName){
                    if (!picklistNode) {
                        return;
                    }
                    for (const child_i of picklistNode.childNodes) {
                        if (child_i.innerText && child_i.innerText.toLowerCase() == valueApiName) {
                            picklistNode.removeChild(child_i);
                        }
                    }
                }

