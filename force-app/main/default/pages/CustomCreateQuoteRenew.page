<apex:page standardController="zqu__Quote__c" tabStyle="zqu__Quote__c" sidebar="false" extensions="CreateQuotePageController">
    <apex:composition template="zqu__QuoteWizardTemplateNoForm" >
        <apex:define name="PageBody" >

            <zqu:CreateQuote subscriptionId="{!$CurrentPage.parameters.subscriptionId}"
                             billingAccountId="{!$CurrentPage.parameters.billingAccountId}"
                             opportunityId="{!$CurrentPage.parameters.oppId}"
                             crmAccountId="{!$CurrentPage.parameters.crmAccountId}"
                             renderBackButton="true"
                             title="Create Quote" />
            <script>
                Date.prototype.addDays = function(days) {
                    var date = new Date(this.valueOf());
                    date.setDate(date.getDate() + days);
                    return date;
                }
                Date.prototype.addMonths = function(months) {
                    var date = new Date(this.valueOf());
                    date.setDate(date.getMonth() + months);
                    return date;
                }

                var relatedSubscriptionApexNextRenewalDateTimeRaw = '{!subscription.Zuora__NextRenewalDate__c}';
                var relatedSubscriptionApexNextRenewalDateTime = new Date(relatedSubscriptionApexNextRenewalDateTimeRaw);
                setQuoteField('zqu__TermStartDate__c', getFormattedDate(relatedSubscriptionApexNextRenewalDateTime));
                var customerAcceptanceFieldNode = document.querySelector('[data-id=customerAcceptanceInput]');
                if (customerAcceptanceFieldNode) {
                    customerAcceptanceFieldNode.value = getFormattedDate(relatedSubscriptionApexNextRenewalDateTime);
                }
                var serviceActivationFieldNode = document.querySelector('[data-id=serviceActivationInput]');
                if (serviceActivationFieldNode) {
                    serviceActivationFieldNode.value = getFormattedDate(relatedSubscriptionApexNextRenewalDateTime);
                }
                /* var startDateFieldNode = document.querySelector('[data-id=contractEffectiveInput]');
                if (startDateFieldNode) {
                    startDateFieldNode.value = getFormattedDate(new Date());
                } */


                listenStartDateField();
                addHelpTextToCurrency();
                setDefaultValues();
                removeCurrencyNoneValue();

                function addHelpTextToCurrency(){
                    var fieldName = 'zqu__Currency__c';
                    var currencyInputEl = getCurrncyInputField();
                    if (!currencyInputEl) {
                        return;
                    }
                    //return;
                    Visualforce.remoting.Manager.invokeAction(
                    '{!$RemoteAction.CreateQuotePageController.getHelpText}', 
                    fieldName,
                        function(result, event){
                            if (event.status) {
                                debugger;
                                var parentEl = currencyInputEl.parentNode;
                                var spanElArr = parentEl.getElementsByTagName('span');
                                if(!spanElArr || spanElArr.length < 1){
                                    return;
                                }
                                var spanParentEl = spanElArr[0];
                                var spanParentElChildArr=[];
                                for (const child_i of spanParentEl.childNodes) {
                                    spanParentElChildArr.push(child_i);
                                    spanParentEl.removeChild(child_i);
                                }
                                var spanEl = document.createElement('span');
                                spanEl.classList.add('helpButton');
                                spanEl.id = fieldName + '-_help';
                                for (const child_i of spanParentElChildArr) {
                                    spanEl.appendChild(child_i);
                                }
                                //spanEl.appendChild(currencyInputEl);

                                var imgEl = document.createElement('img');
                                var orgUrl = '{!orgUrl}';
                                imgEl.src = orgUrl + '/img/s.gif';
                                imgEl.classList.add('helpOrb');
                                spanEl.appendChild(imgEl);

                                var scriptEl = document.createElement('script');
                                scriptEl.innerHTML = 'sfdcPage.setHelp("' + fieldName + '", "' + result + '");';
                                spanEl.appendChild(scriptEl);
                                spanParentEl.appendChild(spanEl);

                                correctCurrencySpanStyling(spanParentEl);
                                correctLabelStyling(spanParentElChildArr[0]);
                            } else if (event.type === 'exception') {
                                /* document.getElementById("responseErrors").innerHTML = 
                                    event.message + "<br/>\n<pre>" + event.where + "</pre>"; */
                            } else {
                                /* document.getElementById("responseErrors").innerHTML = event.message; */
                            }
                        }
                    );

                    function getCurrncyInputField(){
                        var currencySpanList = document.querySelectorAll('[data-id=customRenderedCurrency]');
                        if(currencySpanList != undefined &&  currencySpanList.length > 0){
                            for (const currencySpanChld of currencySpanList[0].childNodes) {
                                if(currencySpanChld.tagName.toLowerCase() == 'select'){
                                    return currencySpanChld;
                                }
                            }
                        } else {
                            return;
                        }
                    }

                    function correctCurrencySpanStyling(spanEl){
                        spanEl.style["padding-right"] = "18px";
                    }
                    function correctLabelStyling(labelEl){
                        labelEl.setAttribute("style", "");
                    }
                }

                function listenStartDateField(){
                    var startDateSpanList = document.querySelectorAll('[data-field-name=zqu__StartDate__c]');
                    if(startDateSpanList != undefined &&  startDateSpanList.length > 0){
                        var selectValue = getQuoteFieldValue(startDateSpanList);
                        displayOrNotPicklist(selectValue);
                        var startDateNode =  getQuoteFileNode(startDateSpanList);
                        if (!startDateNode) {
                            return;
                        }
                        getQuoteFileNode(startDateSpanList).onchange = function(){ 
                            selectValue = event.target.value;
                            displayOrNotPicklist(selectValue); 
                            if (selectValue) {
                                var startDate = new Date(selectValue);   
                                setQuoteField('zqu__ValidUntil__c', getFormattedDate(startDate.addDays(7)));
                            }
                        };    
                        function displayOrNotPicklist(selectValue){
                            if (selectValue != undefined) {
                                setQuoteField('zqu__Service_Activation_Date__c', selectValue);
                                setQuoteField('zqu__Customer_Acceptance_Date__c', selectValue);
                            }
                        }
                    }
                }

                function setDefaultValues(){
                    setQuoteFieldNew('zqu__InitialTerm__c',12);
                    setQuoteFieldNew('zqu__RenewalTerm__c',12);
                }

                function removeCurrencyNoneValue(){
                    var currencySpanList = document.querySelectorAll('[data-id=customRenderedCurrency]');
                    if(currencySpanList != undefined &&  currencySpanList.length > 0){
                        var currencySelectEl;
                        for (const currencySpanChld of currencySpanList[0].childNodes) {
                            if(currencySpanChld.tagName.toLowerCase() == 'select'){
                                currencySelectEl = currencySpanChld;
                                break;
                            }
                        }
                        if (currencySelectEl) {
                            for (const option_i of currencySelectEl.childNodes) {
                                if (!option_i.tagName || option_i.tagName.toLowerCase() != 'option') {
                                    continue;
                                }
                                var value = option_i.value;
                                if (value == '') {
                                    currencySelectEl.removeChild(option_i);
                                }
                            }
                        }
                    }
                }

                function getQuoteFieldValue(spanList){
                    if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].classList.contains('dateOnlyInput')) {
                        return spanList[0].parentNode.childNodes[0].childNodes[0].value;
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'input' && spanList[0].parentNode.childNodes[0].type == 'checkbox') {
                        if (spanList[0].parentNode.childNodes[0].checked) {
                            return spanList[0].parentNode.childNodes[0].checked;
                        } else {
                            return false;
                        }
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'select') {
                        return spanList[0].parentNode.childNodes[0].value;
                    } else {
                        return '';
                    }                
                }

                function getQuoteFileNode(spanList){
                    if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].classList.contains('dateOnlyInput')) {
                        return spanList[0].parentNode.childNodes[0].childNodes[0];
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'input' && spanList[0].parentNode.childNodes[0].type == 'checkbox') {
                        /* if (spanList[0].parentNode.childNodes[0].checked) { */
                            return spanList[0].parentNode.childNodes[0];
                        /* } else {
                            return false;
                        } */
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'select') {
                        return spanList[0].parentNode.childNodes[0];
                    } else {
                        return undefined;
                    }
                }

                function getQuoteFieldData(fieldName){
                    var spanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                    if(spanList != undefined &&  spanList.length > 0){
                        if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].classList.contains('dateOnlyInput')) {
                            return;// spanList[0].parentNode.childNodes[0].childNodes[0];
                        } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'input' && spanList[0].parentNode.childNodes[0].type == 'checkbox') {
                            return;// spanList[0].parentNode.childNodes[0];
                        } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'select') {
                            var thNode = spanList[0].parentNode;
                            var tdNode;
                            var indexOfThNode = Array.from(thNode.parentNode.childNodes).indexOf(thNode);
                            if (indexOfTdNode > 0) {
                                var indexOfTdNode = indexOfThNode + 1;
                                tdNode = thNode.parentNode.childNodes[indexOfTdNode];
                            }
                            if (thNode && tdNode) {
                                var quoteFieldData = [];
                                quoteFieldData.push(thNode);
                                quoteFieldData.push(tdNode);
                                return quoteFieldData;
                            } else {
                                return;
                            }
                        } else {
                            return undefined;
                        }
                    }
                }

                function setQuoteField(fieldName, fieldValue){
                    var spanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                    if (!spanList || spanList.length < 1) {
                        return;
                    }
                    if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'span' && spanList[0].parentNode.childNodes[0].classList.contains('dateOnlyInput')) {
                        spanList[0].parentNode.childNodes[0].childNodes[0].value = fieldValue;   
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'input' && spanList[0].parentNode.childNodes[0].type == 'checkbox') {
                        if(fieldValue){
                            spanList[0].parentNode.childNodes[0].setAttribute('checked',undefined);
                        } else {
                            spanList[0].parentNode.childNodes[0].removeAttribute('checked');
                        }
                    } else if (spanList[0].parentNode.childNodes[0].tagName && spanList[0].parentNode.childNodes[0].tagName.toLowerCase() == 'select') {
                        spanList[0].parentNode.childNodes[0].value = fieldValue;
                    } else {
                        var inputNode;
                        for (const child_i of spanList[0].parentNode.childNodes) {
                            if (child_i.tagName && child_i.tagName.toLowerCase() == 'input') {
                                inputNode = child_i;
                                break;
                            }
                        }
                        if (inputNode) {
                            inputNode.value = fieldValue;
                        }
                    }              
                }

                function setQuoteFieldNew(fieldName, fieldValue){
                    var spanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                    if (!spanList || spanList.length < 1) {
                        return;
                    }
                    var parent = spanList[0].parentNode;
                    var selectElArr = parent.getElementsByTagName('select');
                    if (selectElArr && selectElArr.length > 0) {
                        var selectEl = selectElArr[0];
                        selectEl.value = fieldValue;
                    } else {
                        selectElArr = parent.getElementsByTagName('input');
                        if (selectElArr && selectElArr.length > 0) {
                            var selectEl = selectElArr[0];
                            selectEl.value = fieldValue;
                        }
                    }
                }

                function getFormattedDate(date) {
                    let year = date.getFullYear();
                    let month = (1 + date.getMonth()).toString().padStart(2, '0');
                    let day = date.getDate().toString().padStart(2, '0');
                
                    return month + '/' + day + '/' + year;
                }

