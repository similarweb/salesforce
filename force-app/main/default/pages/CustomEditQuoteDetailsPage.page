            function listenCertificateIdField(){
                var certificateIdSpanList = document.querySelectorAll('[data-field-name=zqu__Certificate_ID__c]');
                if(certificateIdSpanList != undefined &&  certificateIdSpanList.length > 0){
                    //setMandatoryOfCertificateId(false);
                    //changeDisplayOfFieldNew('zqu__Certificate_ID__c',false);
                    setFieldDatasetMode(certificateIdSpanList[0],'certificateId');
                    var selectValue = getQuoteFieldValueNew(certificateIdSpanList);
                    var certificateIdNode = getCertificateIdNode(certificateIdSpanList);
                    if (!certificateIdNode) {
                        return;
                    }
                    function executeCertificateIdValidation(selectValue,certificateIdNode){
                        const soldToLabelElement = findElementByContainingPharse('label', 'text()', 'Admin User');
                        const soldToIdInputElement = getSoldToIdInputFromLabelElement(soldToLabelElement);
                        if (!soldToIdInputElement) {
                            return;
                        }
                        var soldToCountryValue = '{!soldToCountryValue}';
                        if (!taxCountriesWithNoValidation.includes(soldToCountryValue)) {
                            if (selectValue) {
                                validateCertificateId(selectValue,soldToIdInputElement.value,certificateIdNode);
                            } else {
                                clearMessageUtil('certificateIdValidationMessage');
                            }
                        }
                    }
                    certificateIdNode.onchange = function(){
                        if (event.target.dataset.mode != 'certificateId') {
                            return;
                        }
                        selectValue = event.target.value;
                        executeCertificateIdValidation(selectValue,event.target);
                    };
                    executeCertificateIdValidation(selectValue,certificateIdNode);
                    function validateCertificateId(certificateId, soldToContactId,certificateIdEl){
                        if (soldToContactId) {
                            Visualforce.remoting.Manager.invokeAction(
                                '{!$RemoteAction.CreateQuotePageController.validateCertificateIdNew}',
                                soldToContactId, certificateId,
                                function(result, event){
                                    if (event.status) {
                                        if (result) {
                                            showMessageUtil(certificateIdEl,'success','Certificate Id is valid!','certificateIdValidationMessage');
                                        } else {
                                            showMessageUtil(certificateIdEl,'warning','Warning: Certificate Id is not valid!','certificateIdValidationMessage');
                                        }
                                    } else if (event.type === 'exception') {
                                        /* document.getElementById("responseErrors").innerHTML =
                                            event.message + "<br/>\n<pre>" + event.where + "</pre>"; */
                                    } else {
                                        /* document.getElementById("responseErrors").innerHTML = event.message; */
                                    }
                                }
                            );
                        }
                    }

                    function getCertificateIdNode(certificateIdSpanList){
                        var parent = certificateIdSpanList[0].parentNode;
                        var inputNode;
                        for (const node_i of parent.childNodes) {
                            if (node_i.tagName && node_i.tagName.toLowerCase() == 'input') {
                                inputNode = node_i;
                            }
                        }
                        if (!inputNode) {
                            return;
                        } else {
                            return inputNode
                        }
                    }
                }
            }

