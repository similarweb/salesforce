            var quoteRecordTypeName = '{!quoteRecordTypeName}';
            var quotePaymentMethod = '{!zqu__Quote__c.zqu__PaymentMethod__c}';
            var quoteBusinessType = '{!zqu__Quote__c.zqu__QuoteBusinessType__c}';
            var isLegalProfile = '{!isLegalProfile}';
            var isReadOnlyNewSaleCustomPageWithAdjustment =     quoteRecordTypeName == 'ReadOnly'
                && (quoteStatus == 'Approved By Billing' || quoteStatus == 'Pending Legal Or Billing request')
                && (quotePaymentMethod !='Wire Transfer' && quotePaymentMethod !='Credit Card' && quotePaymentMethod !='PayPal');
            var isCtuAmendmentCustomPage = quoteBusinessType == 'Co-Term Upsell' && (quoteStatus == 'Pending Legal Or Billing request' || quoteStatus == 'Approved By Billing') && quoteRecordTypeName == 'Amendment_ReadOnly';
            var isRenewalAmendmentCustomPage = quoteBusinessType == 'Renewal (with/without upsell)' && (quoteStatus == 'Pending Legal Or Billing request' || quoteStatus == 'Approved By Billing') && quoteRecordTypeName == 'Amendment_ReadOnly';
            var isCtuRenewalAmendmentCustomPageWithAddons = quoteBusinessType == 'Co-Term Upsell + Renewal' && (quoteStatus == 'Pending Legal Or Billing request' || quoteStatus == 'Approved By Billing') && quoteRecordTypeName == 'Amendment_ReadOnly';
            var isFeatureUpdateRenewalAmendmentCustomPageWithAddons = quoteBusinessType == 'Feature Update + Renewal (with/without upsell)' && (quoteStatus == 'Pending Legal Or Billing request' || quoteStatus == 'Approved By Billing') && quoteRecordTypeName == 'Amendment_ReadOnly';
            if (   isLegalProfile == 'false'
                && quoteRecordTypeName!= 'Default'
                && quoteRecordTypeName!= 'Amendment'
                && quoteRecordTypeName!= 'Cancellation'
                && isReadOnlyNewSaleCustomPageWithAdjustment == false
                && isCtuAmendmentCustomPage == false
                && isRenewalAmendmentCustomPage == false
                && isCtuRenewalAmendmentCustomPageWithAddons == false
                && isFeatureUpdateRenewalAmendmentCustomPageWithAddons == false)
            {
                return;
            }
            else if ( quoteRecordTypeName!= 'Default'
                && quoteRecordTypeName!= 'Amendment'
                && quoteRecordTypeName!= 'Cancellation'
                && (quoteStatus == 'Ready for Billing'
                    || quoteStatus == 'Sent To Zuora'
                    || quoteStatus == 'Contract Signed'
                    || quoteStatus == 'Contract Signed Manually'
                    || quoteStatus == 'Sent To Zuora'
                    || quoteStatus == 'Finalized'
                    || quoteStatus == 'Voided'))
            {
                return;
            }
            var url = window.location.href;
            if (!url.includes('EditMode=1')) {
                if (url.indexOf('?') > -1){
                    url += '&EditMode=1'
                }else{
                    url += '?EditMode=1'
                }
                window.location.href = url;
            } else {
                hideZuoraHeaderAndTitle();
                if (quoteRecordTypeName == 'Default' || quoteRecordTypeName == 'ReadOnly') {
                    newSubscriptionLogic();
                } else if (quoteRecordTypeName == 'Amendment' || quoteRecordTypeName == 'Amendment_ReadOnly') {
                    amendLogic();
                }
            }
        }

        function setSectionsAsReadonly(sectionName){
            var section = document.querySelectorAll('[data-section-name='+sectionName+']')[0];

            var allInputs = section.getElementsByTagName("input");
            var allSelects = section.getElementsByTagName("select");
            var allImgs = section.getElementsByTagName("img");
            var requiredFields = section.querySelectorAll(".requiredBlock");
            var dateFormats = section.querySelectorAll(".dateFormat");

            setElementsAsReadonly(allInputs);
            setElementsAsReadonly(allSelects);
            setElementsAsReadonly(allImgs);
            disableRequiredStatus(requiredFields);
            disableRequiredStatus(dateFormats);

            function disableRequiredStatus(reqElements){
                for(let el of reqElements){
                    el.style.display = 'none';
                }
            }
        }

        function setElementsAsReadonly(listOfElements){
            var listOfElementsClone = Array.from(listOfElements);

            for(let el of listOfElementsClone){
                var tag = el.tagName;
                if(tag == 'SELECT'){
                    createSpan(el,true);
                    el.disabled = true;
                    el.style.display = 'none';
                }else if(tag == 'INPUT'){
                    if(el.type == 'checkbox'){
                        el.disabled = true;
                    } else if(el.type == 'text'){
                        createSpan(el,false);
                    }
                }else if(tag == 'IMG'){
                    el.style.display = 'none';
                }

                function createSpan(elem,isSelect){
                    var inputValue;
                    if(elem.value.length == 0){
                        inputValue = '-';
                    } else{
                        inputValue = elem.value;
                    }
                    var newEl = document.createElement('span');
                    newEl.innerHTML = inputValue;
                    newEl.dataset.mode='readOnly';

                    var spanElArr = elem.parentNode.querySelectorAll('span[data-mode="readOnly"]');

                    if(!isSelect){
                        if (spanElArr && spanElArr.length>0) {
                            spanElArr[0].style.display='inline-block';
                            spanElArr[0].innerHTML = inputValue;
                        } else {
                            elem.parentNode.replaceChild(newEl, elem);
                        }
                    } else if(isSelect){
                        if(elem.style.display == 'none'){
                            return;
                        } else {
                            if (spanElArr && spanElArr.length>0) {
                                spanElArr[0].style.display='inline-block';
                                spanElArr[0].innerHTML = inputValue;
                            } else {
                                elem.style.display = 'none';
                                elem.parentNode.appendChild(newEl);
                            }
                        }
                    }
                }
            }
        }

        function setElementsAsWriteable(listOfElements){
            let listOfElementsClone = Array.from(listOfElements);

            for(let el of listOfElementsClone){
                let parentNode = el.parentNode;
                var spanElArr = parentNode.getElementsByTagName('span');
                var allInputs = parentNode.getElementsByTagName("input");
                var allSelects = parentNode.getElementsByTagName("select");
                var requiredFields = parentNode.querySelectorAll(".requiredBlock");
                var allImgs = parentNode.getElementsByTagName("img");
                //var requiredFields = section.querySelectorAll(".requiredBlock");
                //var dateFormats = section.querySelectorAll(".dateFormat");
                for (const spanEl_i of spanElArr) {
                    spanEl_i.style.display = 'none';
                }
                for (const ipuntEl_i of allInputs) {
                    if (ipuntEl_i.style.display == 'none') {
                        ipuntEl_i.style.display = 'inline-block';
                    }
                }
                for (const selectEl_i of allSelects) {
                    if (selectEl_i.style.display == 'none') {
                        selectEl_i.style.display = 'inline-block';
                    }
                }
                for (const requiredEl_i of requiredFields) {
                    if (requiredEl_i.style.display == 'none') {
                        requiredEl_i.style.display = 'block';
                    }
                }
            }
        }

