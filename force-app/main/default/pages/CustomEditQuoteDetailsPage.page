            function setFieldAsNotRequired(spanElement){
                var parent = spanElement.parentNode;
                var requiredInputArr = spanElement.parentNode.getElementsByTagName('div');
                if (!requiredInputArr || requiredInputArr.length < 1) {
                    return;
                }
                var requiredInput = requiredInputArr[0];

                var inputNodeArr = requiredInput.getElementsByTagName('input');
                if (inputNodeArr && inputNodeArr.length > 0) {
                    var inputNode = inputNodeArr[0];
                    parent.removeChild(requiredInput);
                    parent.appendChild(inputNode);
                } else {
                    var selectNodeArr = requiredInput.getElementsByTagName('select');
                    if (selectNodeArr && selectNodeArr.length > 0) {
                        var selectNode = selectNodeArr[0];
                        parent.removeChild(requiredInput);
                        parent.appendChild(selectNode);
                    }
                }
                if(inputNode !== undefined){
                    inputNode.setAttribute("is-mandatory","false");
                }
            }

