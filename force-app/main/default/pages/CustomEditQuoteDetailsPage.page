            function handleContractEffectiveDateChange(paymentMethod, quoteBusinessType,isQuoteExist){
                if(paymentMethod == 'Credit Card' || paymentMethod == 'PayPal'){
                    if(quoteBusinessType == 'Renewal (with/without upsell)'){
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                        setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    } else {
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                    }
                } else if(paymentMethod == 'Wire Transfer'){
                    changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                    changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                    if(quoteBusinessType == 'Feature Update'){
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                    } else if(quoteBusinessType == 'Co-Term Upsell'){
                        updateContractEffectiveDate('Signature Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                    } else if(quoteBusinessType == 'Renewal (with/without upsell)'){
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                        setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    }
                } else if(paymentMethod == 'Other') {
                    changeDisplayOfFieldNew('Contract_Start_Upon__c',true,true);
                    changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',false,true);
                    if(quoteBusinessType == 'Feature Update'){
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', false);
                    } else if(quoteBusinessType == 'Co-Term Upsell'){
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    } else if(quoteBusinessType == 'Co-Term Upsell + Renewal'){
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    } else if(quoteBusinessType == 'Feature Update + Renewal (with/without upsell)'){
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    } else if(quoteBusinessType == 'Renewal (with/without upsell)'){
                        changeDisplayOfFieldNew('zqu__SubscriptionTermStartDate__c',true,true);
                        setFieldAsReadOnly('zqu__SubscriptionTermStartDate__c');
                        changeDisplayOfFieldNew('Contract_Start_Upon__c',false,true);
                        updateContractEffectiveDate('Start Date', isQuoteExist)
                        changeDisableOfFieldNew('Contract_Start_Upon__c', true);
                    }
                }
            }

