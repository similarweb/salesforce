            function setCustomerRequestToPayImmediatelyCheckbox(){
                const businessType = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__QuoteBusinessType__c]'));
                if(businessType){
                    const isRenewalBusinessType = checkIfQuoteBusinessTypeIsRenewal(businessType);
                    if(isRenewalBusinessType){
                        const subTermStartDate = getQuoteFieldValueNew(document.querySelectorAll('[data-field-name=zqu__SubscriptionTermStartDate__c]'));
                        if(subTermStartDate){
                            const subscriptionTermStartDate = new Date(subTermStartDate);
                            let currentDate = new Date();
                            const subscriptionTermStartDateRangeStart = currentDate.addDays(-7);
                            const subscriptionTermStartDateRangeEnd = currentDate.addDays(7);
                            const isDateInRange = ((subscriptionTermStartDateRangeStart.getTime() < subscriptionTermStartDate.getTime())&& (subscriptionTermStartDate.getTime() < subscriptionTermStartDateRangeEnd.getTime()));
                            if(isDateInRange){
                                disableCustomerRequestsToPayImmedately();
                            } else {
                                changeDisableOfField('Customer_requests_to_pay_immediately__c', true);
                            }
                        }
                    } else {
                        changeDisableOfField('Customer_requests_to_pay_immediately__c', true);
                    }
                }
            }

            function checkIfQuoteBusinessTypeIsRenewal(businessType){
                const CO_TERM_UPSELL_RENEWAL = 'Co-Term Upsell + Renewal';
                const FEATURE_UPDATE_RENEWAL = 'Feature Update + Renewal (with/without upsell)';
                const RENEWAL = 'Renewal (with/without upsell)';

                const isCoTermRenewal = (businessType == CO_TERM_UPSELL_RENEWAL);
                const isFeatureRenewal = (businessType == FEATURE_UPDATE_RENEWAL);
                const isRenewal = (businessType == RENEWAL);
                return isCoTermRenewal || isFeatureRenewal || isRenewal;
            }

