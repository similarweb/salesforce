                if (!soldToIdInputElement) {
                    return;
                }
                var isMsaSentToZuoraEnabled = "{!isMsaSentToZuoraEnabled}";
                var isSalesOpsEnabled = "{!isSalesOpsEnabled}";
                //if (soldToIdInputElement.value) { MQ-1005. Even an empty field should not be editable.
                //setQuoteCurrencyDisability(true);
                checkSoldToCountry(soldToIdInputElement);
                if(isMsaSentToZuoraEnabled == "false" && isSalesOpsEnabled == 'false'){
                    var soldToIdInputViewElement = getSoldToIdInputFromLabelElement(soldToLabelElement,'targetNameDisplay');
                    if (soldToIdInputViewElement) {
                        soldToIdInputViewElement.disabled=true;
                        let lookupIcons = soldToIdInputViewElement.parentNode.getElementsByClassName('lookupIcon');
                        for (const lookupIcon of lookupIcons) {
                            lookupIcon.style.display = 'none'
                        }
                        let deleteIcons = soldToIdInputViewElement.parentNode.getElementsByClassName('deleteIcon');
                        for (const deleteIcon of deleteIcons) {
                            deleteIcon.style.display = 'none'
                        }
                    }
                    //}
                }
                var observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.type == "attributes" && mutation.attributeName == 'value') {
                            checkSoldToCountry(soldToIdInputElement);
                        }
                    });
                });

                observer.observe(soldToIdInputElement, {
                    attributes: true //configure it to listen to attribute changes
                });

