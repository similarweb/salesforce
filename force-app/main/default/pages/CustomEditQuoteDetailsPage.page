        function changeDisplayOfSection(dataSectionNameString , isDisplayed){
            sectionSpanList = document.querySelectorAll('[data-section-name='+ dataSectionNameString + ']');
            if (sectionSpanList!= undefined && sectionSpanList.length > 0) {
                var sectionDivEl = sectionSpanList[0];
                if (!sectionDivEl) {
                    return;
                }
                var sectionBeforeBufferEl = getSectionAfterBuffer(sectionDivEl);
                if (isDisplayed) {
                    sectionDivEl.style.display = 'inherit';
                    if (sectionBeforeBufferEl) {
                        sectionBeforeBufferEl.style.display = 'inherit';
                    }
                } else {
                    sectionDivEl.style.display = 'none';
                    if (sectionBeforeBufferEl) {
                        sectionBeforeBufferEl.style.display = 'none';
                    }
                }
            }
        }

        function getSectionAfterBuffer(sectionDiv){
            var sectionDivParent = sectionDiv.parentNode;
            var indexOfSectionBeforeBuffer = Array.from(sectionDivParent.childNodes).indexOf(sectionDiv) + 1;
            var sectionBeforeBuffer = sectionDivParent.childNodes[indexOfSectionBeforeBuffer];
            return sectionBeforeBuffer;
        }

