            function setDefaultValues(isQuoteExist){
                if (!isQuoteExist) {
                    let paymentTerm = "{!quotePaymentTerm}";
                    let defaultPaymentMethod = "{!defaultPaymentMethod}";
                    let paymentFrequency = "{!paymentFrequency}";
                    let initialTerm = "{!initialTerm}";
                    let renewTerm = "{!renewTerm}";

                    if (!!initialTerm) {
                        setQuoteFieldNew('zqu__InitialTerm__c', initialTerm);
                    } else {
                        setQuoteFieldNew('zqu__InitialTerm__c', 12);
                    }

                    if (!!renewTerm) {
                        setQuoteFieldNew('zqu__RenewalTerm__c', renewTerm);
                    } else {
                        setQuoteFieldNew('zqu__RenewalTerm__c', 12);
                    }

                    if (paymentTerm) {
