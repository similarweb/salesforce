                var elem;
                for (const span_i of document.querySelector("[data-field-name=Product_Compatibility__c]").parentNode.getElementsByTagName('span')) {
                    if (!span_i.dataset.elem) {
                        elem = span_i;
                        break;
                    }
                }
                if (!elem) {
                    return;
                }
                var observer3 = new MutationObserver(callback3)
                    .observe(elem, {childList : true});

                function callback3(mutations, observer) {
                    var target = mutations[0].target;
                    mutations.forEach(function(mutation) {
                        let noda = getQuoteFileNodeNew(document.querySelectorAll("[data-field-name=Product_Compatibility__c]"));
                        if(!readOnly){
                            if (target.childNodes[0].childNodes.length >= 2) {
                                setQuoteField('Product_Compatibility__c', target.childNodes[0].childNodes[1].value);
                            }
                        } else{
                            observer.disconnect();
                            var parent = noda.parentElement;
                            var selects = parent.getElementsByTagName("select");
                            selects[0].style.display = 'none';
                            var newEl = document.createElement('span');
                            newEl.innerHTML = selects[0].value;
                            parent.appendChild(newEl);
                        }
                    });
                }
            }

