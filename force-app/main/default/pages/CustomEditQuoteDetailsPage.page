            function setMandatoryOfFieldId(fieldName, isMandatory){
                var certificateIdSpanList = document.querySelectorAll('[data-field-name=' + fieldName + ']');
                if(certificateIdSpanList != undefined && certificateIdSpanList.length > 0){
                    var certificateIdSelectEl = certificateIdSpanList[0];
                    if (isMandatory && sessionStorage.getItem(fieldName)) {
                        setFieldAsRequired(certificateIdSelectEl);
                        setNameOfInputElementInSessionStorage(certificateIdSelectEl, fieldName);
                    } else {
                        setFieldAsNotRequired(certificateIdSelectEl);
                        storeNameOfInputElementInSessionStorage(certificateIdSelectEl, fieldName);
                        clearNameOfInputElement(certificateIdSelectEl);
                    }
                }
