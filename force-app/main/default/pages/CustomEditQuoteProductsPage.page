                                    if (event.status) {
                                        var validIds = result;
                                        createButtons(validIds);
                                    } else {
                                        console.log(event.message);
                                    }
                                }
                            );
                        }
                        // Get IDs from the rows and call the remote action to check valid IDs

                        createMyModalComponent();

                        function refreshMyModalComponent() {
                            // Destroy the existing component
                            var oldComponent = $A.getComponent(globalId);
                            if (oldComponent) {
                                oldComponent.destroy();
                            }

                            // Re-create the component
                            createMyModalComponent();
                        }

                        function getQuantityValue(){

                        }

                        // Create the Lightning component
                        function createMyModalComponent() {
                            $Lightning.use("c:MyModalApp", function() {
                                $Lightning.createComponent("c:MyModal",
                                    {
                                        onClose: refreshMyModalComponent,
                                    },
                                    "SelectValuesDiv",
                                    function(cmp, status, errorMessage) {
                                        globalId = cmp.getGlobalId();
                                    });
                            });
                        }

                        function extractIDsFromDivs() {
                            var divElements = document.querySelectorAll('div.panelStatusOriginal, div.panelStatusUpdated, div.panelStatusAdded');
                            var extractedIds = [];

                            divElements.forEach(function (div) {
                                var id = div.id.replace('_status', '');
                                extractedIds.push(id);
                            });

                            return extractedIds;
                        }


                        billingPeriodCheck(false);

                        console.log("Quote fields check!");
