                        console.log("{!zqu__Quote__c.Product_Compatibility_Amendment__c}");
                        console.log("{!zqu__Quote__c.Product_Compatibility__c}");
                        console.log("{!zqu__Quote__c.Product_Type_Amendment__c}");
                        console.log("{!zqu__Quote__c.New_solution_use_case__c}");
                        Visualforce.remoting.timeout = 120000;

                        backButtonLogic();
                        setErrorMessage();
                        /* if ({!deleteOriginal}) {
                            removeOriginalProductsOnAmend();
                        } */
                        var IS_ZUORA_SUBMIT_ALLOWED = false;
                        var spanList = document.querySelectorAll('[data-id=nextButton]');
                        if (spanList && spanList.length > 0 && spanList[0].innerText.toLowerCase() == 'submit') {
                            var saveOnClickFunction = spanList[0].onclick;
                            spanList[0].onclick = submitButtonClick;
                        }

                        function billingPeriodCheck(stop){
                            let timerId = setInterval(() => {
                                let fieldName = 'td.SPECIFIC_BILLING_PERIOD.editableCell.displayedText'
                                const rowsList = document.querySelectorAll(fieldName);
                                for(const rowValue of rowsList){
                                    if(rowValue.outerText != "{!zqu__Quote__c.zqu__InitialTerm__c}"){
                                        rowValue.textContent = "{!zqu__Quote__c.zqu__InitialTerm__c}";
                                        rowsChanged = true;
                                    }
                                }
                            }, 500);
                            if(stop){
                                clearInterval(timerId);
                            }
                        }

                        function submitButtonClick(){
                            if (IS_ZUORA_SUBMIT_ALLOWED) {
                                IS_ZUORA_SUBMIT_ALLOWED = false;
                                return;
                            }
                            event.stopImmediatePropagation(); // in order to prevent default Zuora "Submit" button logic
                            clickSaveButtonAndValidationAfter();
                        }

                        function clickSaveButtonAndValidationAfter(){
                            billingPeriodCheck(true);
                            var spanList = document.querySelectorAll('[data-id=saveButton]');
                            var saveButtonEl;
                            if (spanList && spanList.length > 0) {
                                saveButtonEl = spanList[0];
                                saveButtonEl.click();
                            }
                            if (!saveButtonEl) {
                                return;
                            }
                            var spanElToListen;
                            for (const child_i of saveButtonEl.childNodes) {
                                if (child_i.classList && [...child_i.classList].includes('running') && [...child_i.classList].includes('hidden')) {
                                    spanElToListen = child_i;
                                    break;
                                }
                            }
                            if (!spanElToListen) {
                                return;
                            }
                            var observer2 = new MutationObserver(callback)
                                    .observe(spanElToListen, {attributes: true, attributeOldValue: true});

                            function callback(mutations, observer2) {
                                var target = mutations[0].target;
                                mutations.forEach(function(mutation) {
                                    if (mutation.type == "attributes" && mutation.attributeName == 'style') {
                                        var sectionDivEl = mutation.target;
                                        if(sectionDivEl.style.display == 'none') {
                                            observer2.disconnect();
                                            runZuoraRulesValidation();
                                        }
                                    }
                                });
                            }
                        }

                        function runZuoraRulesValidation(){
                            console.log('runZuoraRulesValidation: ');
                            setLoadingOnZuoraButtons(true);
                            var spanList = document.querySelectorAll('[data-id=nextButton]');
                            if (spanList && spanList.length > 0 && spanList[0].innerText.toLowerCase() == 'submit') {
                                var saveOnClickFunction = spanList[0].onclick;
                                spanList[0].onclick = submitButtonClick;
                            }
                            Visualforce.remoting.Manager.invokeAction(
                                '{!$RemoteAction.CustomEditQuoteProductsController.validateQuote}',
                                '{!thisQuote}',
                                function(result, event){
                                    console.log('result: '+result);
                                    console.log('event: '+event);
                                    console.log('event.status: '+event.status);
                                    setLoadingOnZuoraButtons(false);
                                    if (event.status) {
                                        if (result.length > 0) {
                                            showAlertMessage(result);
                                            addAlertMessageToRulesEngineLogs(result);
                                        } else {
                                            //IS_ZUORA_SUBMIT_ALLOWED = true;
                                            //spanList[0].click();
                                            onSubmitButton();
                                            onRedirectToRecordPage();
                                        }
                                    } else if (event.type === 'exception') {
                                        /* document.getElementById("responseErrors").innerHTML =
                                            event.message + "<br/>\n<pre>" + event.where + "</pre>"; */
                                    } else {
                                        /* document.getElementById("responseErrors").innerHTML = event.message; */
                                    }
                                }
                            );

                            function setLoadingOnZuoraButtons(isLoading){
                                var zuoraButtonArray = getZuoraButtonArray();
                                for (const zuoraButton of zuoraButtonArray) {
                                    if (zuoraButton.dataset.id == 'calculateButton') {
                                        setSpinnerVisibilityOnCalculateButton(zuoraButton,isLoading);
                                    } else {
                                        if (isLoading) {
                                            zuoraButton.classList.add('disabled');
                                        } else {
                                            zuoraButton.classList.remove('disabled');
                                        }
                                    }
                                }

                                function getZuoraButtonArray(){
                                    var zuoraButtonArray = document.querySelectorAll('[data-id=cancelButton],[data-id=backButton],[data-id=calculateButton],[data-id=saveButton],[data-id=nextButton]');
                                    return zuoraButtonArray;
                                }

                                function setSpinnerVisibilityOnCalculateButton(calculatedButton, isLoading){
                                    var spanList = calculatedButton.getElementsByTagName('span');
                                    for (const childSpan_i of spanList) {
                                        if (childSpan_i.classList.contains('not-running')) {
                                            if (isLoading) {
                                                childSpan_i.style.display = 'none';
                                            } else {
                                                childSpan_i.style.display = 'block';
                                            }
                                        } else if (childSpan_i.classList.contains('running') && childSpan_i.classList.contains('hidden')){
                                            if (isLoading) {
                                                childSpan_i.style.display = 'inline';
                                            } else {
                                                childSpan_i.style.display = 'none';
                                            }
                                        }
                                    }

                                }
                            }

                            function showAlertMessage(validationErrorMessageArray){
                                var alertifyWarningMessage='';
                                alertifyWarningMessage += getStandartWarningMessage();
                                alertifyWarningMessage += getHtmlWrappedAlertMessageRaw(validationErrorMessageArray);
                                alertify.alert(alertifyWarningMessage);

                                function getStandartWarningMessage(){
                                    return 'There are validation errors that prevent your quote from being saved.';
                                }

                                function getHtmlWrappedAlertMessageRaw(validationErrorMessageArray){
                                    var htmlWrappedWarningMessage = '';
                                    htmlWrappedWarningMessage += '<ul class = "ul.scrollableNotification">';
                                    for (const validationErrorMessage of validationErrorMessageArray) {
                                        htmlWrappedWarningMessage += '<div class="rule-log type-ERROR action-VALIDATION">';
                                        htmlWrappedWarningMessage += validationErrorMessage;
                                        htmlWrappedWarningMessage += '</div>';
                                        htmlWrappedWarningMessage += '<br>';
                                    }
                                    htmlWrappedWarningMessage += '</ul>';
                                    htmlWrappedWarningMessage += '<p></p>';
                                    return htmlWrappedWarningMessage;
                                }
                            }

                            function addAlertMessageToRulesEngineLogs(validationErrorMessageArray){
                                var rulesEngineLogElement = document.getElementById('rulesEngineLogDetailInfo');
                                if (rulesEngineLogElement) {
                                    var rulesEngineLogWarningMessageArray = [];
                                    if (rulesEngineLogElement.hasChildNodes()) {
                                        markLogElementsAsOld(rulesEngineLogElement.childNodes);
                                        rulesEngineLogWarningMessageArray.push(getSeparator(rulesEngineLogElement));
                                    }
                                    rulesEngineLogWarningMessageArray = rulesEngineLogWarningMessageArray.concat(getHtmlWrappedRuleEngineLogWarningMessageArray(validationErrorMessageArray));
                                    for (const rulesEngineLogWarningMessage_i of rulesEngineLogWarningMessageArray) {
                                        rulesEngineLogElement.appendChild(rulesEngineLogWarningMessage_i);
                                    }
                                }

                                function markLogElementsAsOld(elementNodeList){
                                    for (const elementNode_i of elementNodeList) {
                                        if (elementNode_i.classList) {
                                            elementNode_i.classList.add('old');
                                        }
                                    }
                                }

                                function getSeparator(rulesEngineLogElement){
                                    var separator = document.createElement("span");
                                    separator.classList.add('RuleSeparator');
                                    separator.appendChild(document.createElement("hr"));
                                    return separator;
                                }

                                function getHtmlWrappedRuleEngineLogWarningMessageArray(validationErrorMessageArray){
                                    var rulesEngineLogWarningMessageArray = [];
                                    for (const validationErrorMessage of validationErrorMessageArray) {
                                        var ruleLogMessage = document.createElement("li");
                                        ruleLogMessage.classList.add('rule-log');
                                        ruleLogMessage.classList.add('type-ERROR');
                                        ruleLogMessage.classList.add('action-VALIDATION"');
                                        ruleLogMessage.innerHTML = validationErrorMessage
                                        rulesEngineLogWarningMessageArray.push(ruleLogMessage);
                                    }
                                    return rulesEngineLogWarningMessageArray;
                                }
                            }
                        }

                        function backButtonLogic(){
                            console.log("Quote fields check!");
                            showZuoraButtonFooter();
                            var backButtonSpanList = document.querySelectorAll('[data-id=backButton]');
                            var backButtonEl;
                            var defaultBackOnClickFunction;
                            if (backButtonSpanList && backButtonSpanList.length > 0) {
                                backButtonEl = backButtonSpanList[0];
                                defaultBackOnClickFunction = backButtonEl.onclick;
                                backButtonEl.onclick = onNavigateBack;
                            }
                            var flowElSpanList = document.querySelectorAll('[data-id=allFlows]');
                            if (flowElSpanList && flowElSpanList.length > 0) {
                                var flowEl = flowElSpanList[0];
                                var observer3 = new MutationObserver(function(mutations,observer3) {
                                mutations.forEach(
                                    function(mutation) {
                                        console.log('mutation fired');
                                        if (mutation.type == "attributes" && mutation.attributeName == 'style') {
                                            var sectionDivEl = mutation.target;
                                            if(sectionDivEl.style.display = 'none') {
                                                backButtonEl.onclick = defaultBackOnClickFunction;
                                                showTopBarSection();
                                                showCancelButton();
                                                showNextButton();
                                                showSaveButton();
                                                observer3.disconnect();
                                            }
                                        }
                                    });
                                });
                                observer3.observe(flowEl, {
                                    attributes: true //configure it to listen to attribute changes
                                });
                            }

                            function showZuoraButtonFooter(){
                                var allProductsSpanList = document.querySelectorAll('[data-id=allProducts]');
                                if (allProductsSpanList && allProductsSpanList.length > 0) {
                                    var allProductsSectionEl = allProductsSpanList[0];
                                    allProductsSectionEl.style.display="";
                                    hideTopBarSection();
                                    hideCancelButton();
                                    hideSaveButton();
                                    hideNextButton();
                                }
                            }

                            function showTopBarSection(){
                                var topBarHtmlList = document.getElementsByClassName('topBar');
                                if (topBarHtmlList && topBarHtmlList.length > 0) {
                                    var topBarEl = topBarHtmlList[0];
                                    topBarEl.style.display = "";
                                }
                            }

                            function hideTopBarSection(){
                                var topBarHtmlList = document.getElementsByClassName('topBar');
                                if (topBarHtmlList && topBarHtmlList.length > 0) {
                                    var topBarEl = topBarHtmlList[0];
                                    topBarEl.style.display = 'none';
                                }
                            }

                            function showCancelButton(){
                                showZuoraButton('cancelButton');
                            }

                            function hideCancelButton(){
                                hideZuoraButton('cancelButton');
                            }

                            function showSaveButton(){
                                showZuoraButton('saveButton');
                            }

                            function hideSaveButton(){
                                hideZuoraButton('saveButton');
                            }

                            function showNextButton(){
                                showZuoraButton('nextButton');
                            }

                            function hideNextButton(){
                                hideZuoraButton('nextButton');
                            }

                            function showZuoraButton(dataId){
                                var buttonSpanList = document.querySelectorAll('[data-id=' + dataId + ']');
                                if (buttonSpanList && buttonSpanList.length > 0) {
                                    var backButtonEl = buttonSpanList[0];
                                    backButtonEl.style.display="";
                                }
                            }

                            function hideZuoraButton(dataId){
                                var buttonSpanList = document.querySelectorAll('[data-id=' + dataId + ']');
                                if (buttonSpanList && buttonSpanList.length > 0) {
                                    var backButtonEl = buttonSpanList[0];
