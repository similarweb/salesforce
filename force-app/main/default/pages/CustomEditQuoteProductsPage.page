                        // Get a reference to the button
                        var saveButton = null;

                        var parentDiv = document.querySelector('.productSelectorFooter');

                        var saveButton = null;

                        // Iterate over child nodes of the parent div
                        if(parentDiv){
                            for (let child of parentDiv.childNodes) {
                                if ((child.tagName === 'BUTTON' || child.tagName === 'BUTTTON') && child.getAttribute('data-id') === 'saveButton') {
                                    saveButton = child;
                                    break;
                                }
                            }
                            //Create a callback for the MutationObserver
                            var callback = function(mutationsList, observer1) {
                                for(let mutation of mutationsList) {
                                    if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                                        // Check if "disabled" class is NOT present
                                        if (!saveButton.classList.contains('disabled')) {
                                            attachButton();
                                        }
                                    }
                                }
                            };

                            // Create an instance of the observer with the callback
                            var observer1 = new MutationObserver(callback);

                            observer1.observe(saveButton, {
                                attributes: true
