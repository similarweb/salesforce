<apex:page standardController="PA_Invoice__c" extensions="InvoicePDFController" showHeader="false" renderAs="pdf" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
    
    <html>
        <head>
            <style> 
                body {
                font-family: sans-serif;
                }
                .main_header {
                font-size: 30px;
                font-weight: bold;
                }
                .img {
                text-align:right;
                }
                .column_header {
                font-weight: bold;
                } 
                table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 20px;
                }
                table th {
                font-weight: 700;
                }
                table td, table th {
                padding: 6px 8px;
                text-align:right;
                border-bottom: none;
                }
                table td:first-child, table th:first-child {
                text-align:left;
                }
                .lineitems th, .lineitems td {
                border-bottom: 1px solid #ddd;
                }
                .bold {
                font-weight: 700 !important;
                }
                .text-left {
                text-align: left !important;
                }
                .text-right {
                text-align: right !important;
                }
                p {
                margin: 0 0 10px 0;
                }
                p.bold {
                margin-bottom: 3px;
                }
                tr.total td{
                padding: 0;
                }
                .balance {
                vertical-align: middle;
                border-radius: 3px;
                padding: 0 25px 0 8px;
                color: #fff;
                box-sizing: border-box;
                text-align: center;
                background-color: #2675A5;
                position: relative;
                left: -2px;
                height: 100%;
                display: inline-block;
                }
                .totals td:first-child {
                border-color: transparent;
                }
                hr {
                margin: 0.2rem 0;
                height: 2px;
                background: #ddd;
                border: none;
                }
            </style>
        </head>
        <body>
            <table>
                <tr>
                    <td class="main_header" width="60%">
                        Payment Request
                    </td>
                    <!--<td class="img" width="40%">
                        <apex:image url="{!URLFOR($Resource.CLCConsoleApp, 'SW_Primary_Logo_Full-Color-07.png')}" width="150px"  alt="SimilarWeb Logo"/>
                    </td> -->
                </tr>
            </table>
            <table>
                <tr>
                    <td width="30%" style="vertical-align:top">
                        <p class="bold">
                            From
                        </p>
                        <p>
                            {!inv.invoice.Account__r.Name}<br/>
                            {!inv.invoice.Account__r.BillingCountry}<br/>
                            {!inv.invoice.Account__r.BillingCity}<br/>
                            {!inv.invoice.Account__r.BillingStreet}<br/>
                        </p>
                        <p class="bold">
                            To
                        </p>
                        <p>
                            {!to}
                        </p>
                    </td>
                    <td width="70%"  style="vertical-align:top" class="text-left">
                        <p class="bold">
                            Payment Request No.
                        </p>
                        <p>
                            {!inv.name}
                        </p>
                        <p class="bold">
                            Date
                        </p>
                        <p>
                            <apex:outputText value="{0, date, MMM dd yyyy}">
                                <apex:param value="{!NOW()}" />
                            </apex:outputText>
                        </p>
                        <!-- <p class="bold">
                            Invoice Due
                        </p>
                        <p>
                            <apex:outputText value="{0, date, MMM dd yyyy}">
                                <apex:param value="{!inv.invoice.Invoice_Due__c}" />
                            </apex:outputText>
                        </p> -->
                    </td>
                </tr>
            </table>
            
            <br/>
            <p style="padding-left: 8px;">
                Email : {!email}
            </p>
            <br/>
            
            <table class="lineitems" width="100%" style="margin-bottom: 0;">
                <colgroup>
                    <col style="width:40%"/>
                    <col style="width:30%"/>
                    <col style="width:15%"/>
                    <col style="width:15%"/>
                </colgroup> 
                <tr>
                    <th>Name</th>
                    <th>Total DAU</th>
                    <th>Amount</th>
                </tr>      
                <apex:repeat value="{!inv.lineitems}" var="li">
                    <tr>
                        <td>{!li.Name__c}</td>
                        <td>{!li.Total_DAU__c}</td>
                        <td><apex:outputText value="{0, number, ###,###,###,###0.00}"><apex:param value="{!li.Amount__c}"/></apex:outputText></td>
                    </tr>
                </apex:repeat>
            </table>
            
            <table class="lineitems totals" width="100%">
                <colgroup>
                    <col style="width:50%"/>
                    <col style="width:15%"/>
                    <col style="width:15%"/>
                    <col style="width:20%"/>
                </colgroup> 
                
                <apex:variable var="showVat" value="" rendered="{!inv.israelAccount}" >
                    <tr>
                        <td><!--empty space--></td>
                        <td class="text-left">Sub Total</td>
                        <td><!--empty space--></td>
                        <td class="text-right">
                            {!defaultCurrency} <apex:outputText value="{0, number, ###,###,###0.00}"><apex:param value="{!inv.Total - inv.VAT}"/></apex:outputText>
                        </td>
                    </tr>
                     <tr>
                        <td><!--empty space--></td>
                        <td class="text-left">VAT</td>
                        <td class="text-right">{!VATPercent} %</td>
                        <td class="text-right">{!defaultCurrency} <apex:outputText value="{0, number, ###,###,###,###0.00}"><apex:param value="{!inv.VAT}"/></apex:outputText></td>
                    </tr>
                </apex:variable>
                <tr>
                    <td><!--empty space--></td>
                    <td class="text-left bold">Total</td>
                    <td><!--empty space--></td>
                    <td class="text-right bold">
                        <!--<apex:outputText value="{0, number, currency}"><apex:param value="{!inv.Total}"/></apex:outputText>-->
                        {!defaultCurrency} <apex:outputText value="{0, number, ###,###,###0.00}"><apex:param value="{!inv.Total}"/></apex:outputText>
                    </td>
                </tr>
                <!--
                <tr>
                    <td></td>
                    <td class="text-left bold">Paid to Date</td>
                    <td class="text-right bold">{!defaultCurrency} <apex:outputText value="{0, number, ###,###,###,###0.00}"><apex:param value="{!inv.PaidToDate}"/></apex:outputText></td>
                </tr>-->
                <tr class="total">
                    <td><!--empty space--></td>
                    <td style="border: 2px solid #2675A5;border-right: none;background-color: #2675A5; width: 220px;">
                            <span class="balance">Balance</span>
                    </td>
                    <td style="border-top: 2px solid #2675A5;border-bottom: 2px solid #2675A5;">
                        &#8291;
                    </td>
                    <td style="border: 2px solid #2675A5;border-left: none;">
                        <p class="text-right" style="width: 190px;height: 100%;padding: 12px 8px 12px 15px;margin-bottom: 0;">
                        {!defaultCurrency} <apex:outputText value="{0, number, ###,###,###0.00}"><apex:param value="{!inv.Balance}"/></apex:outputText>
                        </p>
                    </td>
                </tr>
            </table>
            <br/>
            <br/>
            <apex:variable var="note" value=""> <!-- rendered="{!NOT(ISNULL(inv.invoice.Invoice_Note__c))}" -->
            <table>
                <tr>
                    <th>
                        Payment Request Note
                    </th>
                </tr>
                <tr>
                    <td style="font-size: 14px;">
                       <apex:outputText value="{!SUBSTITUTE(inv.invoice.Invoice_Note__c,'\\n','<br/>')}" style="white-space:pre;" escape="false"/>
                    </td>
                </tr>
            </table>
            </apex:variable>
            
            <apex:variable var="bank_det" value="" > <!--  rendered="{!NOT(ISNULL(inv.invoice.Account__r.BankDetials__c))}" -->
                <table>
                    <tr>
                        <th>
                            Bank Details
                        </th>
                    </tr>
                    <tr>
                        <td style="font-size: 14px;">
                           <apex:outputText value="{!SUBSTITUTE(inv.invoice.Bank_Detials__c,'\\n','<br/>')}" style="white-space:pre;" escape="false"/>
                        </td>
                    </tr>
                </table>
            </apex:variable>
            <!-- <hr /> -->
            
        </body>
    </html>
</apex:page>