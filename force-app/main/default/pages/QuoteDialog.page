<apex:page standardController="Zuora__CustomerAccount__c" applyHtmlTag="false" applyBodyTag="false" showHeader="false" sidebar="false">
<style>
    .container .backgroundDialog {
        background-color : white;
        opacity:0.5;
        width:100%;
        height:100%;
        position:fixed;
        left:0px;
        top:0px;
        z-index:9999;
        
    }
    .container .contentDialog {
        position:fixed;
        left:25%;
        top:45%;
        width:50%;
        height:10%;
        z-index:10000;
    }
    .container .contentDialog .btn {
        text-decoration:none; 
        display:inline-block;
    }
    
    .container .contentDialog .waitSpan {
        display:inline-block;
        background:url(/img/loading.gif) no-repeat 0 0; 
        padding-left:20px; 
        margin-left:10px; 
        height:14px;
        width:20px;
    }
</style>
<div class="container">
    <div class="backgroundDialog"></div>
    <div class="contentDialog">
        <apex:pageBlock >
        <p>Payment method {!Zuora__CustomerAccount__c.Zuora__DefaultPaymentMethod__c} cannot be changed after creating a quote.<br/> 
        Press Yes if you wish to continue or contact billing if the payment method should be changed</p>
        <apex:pageBlockButtons location="bottom">
            <apex:outputLink value="javascript:window.redirect()" styleClass="btn">Yes</apex:outputLink>
            <span id="waitImg" class="waitSpan" style="display:none;"></span>
            <apex:outputLink value="javascript:window.cancel()" styleClass="btn">No</apex:outputLink> 
        </apex:pageBlockButtons>
        </apex:pageBlock>
    </div>
</div>
</apex:page>